---
import Base from '../layouts/Base.astro';
const token = Astro.url.searchParams.get('reset_password_token') ?? '';
---
<Base title="Reset Password">
  <section style="min-height: calc(100vh - 140px); display: flex; align-items: center; justify-content: center; padding: 3rem 1rem; background: linear-gradient(135deg, #f0fdff, white);">
    <div style="width: 100%; max-width: 400px;">
      <div class="card" style="padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🔑</div>
          <h1 style="font-size: 1.5rem; font-weight: 800; color: #162544; margin: 0 0 0.4rem;">Set new password</h1>
          <p style="color: #9ca3af; font-size: 0.875rem; margin: 0;">Choose a strong password for your account</p>
        </div>
        <form id="resetForm" style="display: flex; flex-direction: column; gap: 1rem;">
          <input type="hidden" id="token" value={token} />
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">New Password</label>
            <input type="password" id="password" required placeholder="Min 8 characters"
              style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
              onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Confirm Password</label>
            <input type="password" id="passwordConfirm" required placeholder="Repeat password"
              style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
              onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
          </div>
          <button type="submit" id="resetBtn" class="btn-primary" style="width: 100%; justify-content: center; font-size: 0.95rem; padding: 0.9rem;">Update Password</button>
          <div id="resetMsg" style="display: none; font-size: 0.8rem; padding: 0.75rem; border-radius: 0.75rem; text-align: center;"></div>
        </form>
      </div>
    </div>
  </section>
</Base>
<script>
  document.getElementById('resetForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('resetBtn') as HTMLButtonElement;
    const msg = document.getElementById('resetMsg') as HTMLElement;
    const token = (document.getElementById('token') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirm = (document.getElementById('passwordConfirm') as HTMLInputElement).value;
    if (password !== confirm) { msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = 'Passwords do not match'; return; }
    btn.textContent = 'Updating...'; btn.disabled = true;
    try {
      const res = await fetch('/api/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reset_password_token: token, password, password_confirmation: confirm }) });
      const data = await res.json();
      msg.style.display = 'block';
      if (data.success) { msg.style.background = '#dcfce7'; msg.style.color = '#15803d'; msg.textContent = 'Password updated! Redirecting...'; setTimeout(() => window.location.href = '/login', 2000); }
      else { msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = data.message ?? 'Reset failed. Try again.'; }
    } catch { msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = 'Network error.'; }
    finally { btn.textContent = 'Update Password'; btn.disabled = false; }
  });
</script>
