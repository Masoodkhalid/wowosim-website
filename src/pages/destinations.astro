  @keyframes ff2 { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(15px) rotate(-2deg)} }
  @keyframes ff3 { 0%,100%{transform:translateY(0) rotate(0deg)} 33%{transform:translateY(-10px) rotate(2deg)} 66%{transform:translateY(12px) rotate(-3deg)} }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .hero-globe { display: block; }
  @media (max-width:1024px) { .hero-globe { display: none; } }
  @media (max-width:640px) { #regionsGrid { grid-template-columns: repeat(2,1fr) !important; } #countriesGrid { grid-template-columns: repeat(3,1fr) !important; } #whyGrid { grid-template-columns: 1fr !important; } [style*="grid-template-columns:repeat(4,1fr)"] { grid-template-columns: repeat(2,1fr) !important; } }
  @media (max-width:400px) { #countriesGrid { grid-template-columns: repeat(2,1fr) !important; } }
</style>
