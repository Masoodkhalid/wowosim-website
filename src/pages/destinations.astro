---

<Base title="All eSIM Destinations — 195+ Countries | WoWo SIM" description="Browse WoWo SIM eSIM plans for 195+ countries. Local and regional plans. Find your destination.">

  <!-- HERO -->
  <section style="background:linear-gradient(135deg,#0f1f3d 0%,#162544 50%,#1a2d50 100%);padding:5rem 2rem 4rem;position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;">

    <!-- Dot grid background -->
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.08) 1px,transparent 1px);background-size:24px 24px;pointer-events:none;"></div>

    <!-- Glowing orbs -->
    <div style="position:absolute;top:-100px;right:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(3,222,243,0.1),transparent 70%);border-radius:50%;"></div>
    <div style="position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(255,95,0,0.06),transparent 70%);border-radius:50%;"></div>

    <!-- Floating flags -->
    <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden;" aria-hidden="true">
      <span class="ff" style="position:absolute;font-size:2rem;top:10%;left:8%;animation:ff1 8s ease-in-out infinite;opacity:0.25;">🇫🇷</span>
      <span class="ff" style="position:absolute;font-size:1.5rem;top:20%;right:12%;animation:ff2 10s ease-in-out infinite;opacity:0.2;">🇯🇵</span>
      <span class="ff" style="position:absolute;font-size:1.75rem;top:60%;left:5%;animation:ff3 7s ease-in-out infinite;opacity:0.2;">🇺🇸</span>
      <span class="ff" style="position:absolute;font-size:2.25rem;top:70%;right:8%;animation:ff1 9s ease-in-out infinite reverse;opacity:0.2;">🇬🇧</span>
      <span class="ff" style="position:absolute;font-size:1.5rem;top:35%;left:15%;animation:ff2 6s ease-in-out infinite;opacity:0.18;">🇦🇺</span>
      <span class="ff" style="position:absolute;font-size:1.25rem;top:15%;left:45%;animation:ff3 11s ease-in-out infinite;opacity:0.15;">🇮🇳</span>
      <span class="ff" style="position:absolute;font-size:2rem;top:80%;left:35%;animation:ff1 8s ease-in-out infinite;opacity:0.18;">🇧🇷</span>
      <span class="ff" style="position:absolute;font-size:1.5rem;top:45%;right:20%;animation:ff2 9s ease-in-out infinite;opacity:0.2;">🇩🇪</span>
      <span class="ff" style="position:absolute;font-size:1.75rem;top:25%;right:35%;animation:ff3 7s ease-in-out infinite;opacity:0.15;">🇮🇹</span>
      <span class="ff" style="position:absolute;font-size:1.25rem;top:55%;left:25%;animation:ff1 12s ease-in-out infinite;opacity:0.17;">🇰🇷</span>
      <span class="ff" style="position:absolute;font-size:2rem;top:5%;right:25%;animation:ff2 8s ease-in-out infinite;opacity:0.15;">🇸🇬</span>
      <span class="ff" style="position:absolute;font-size:1.5rem;top:88%;right:30%;animation:ff3 10s ease-in-out infinite;opacity:0.2;">🇦🇪</span>
    </div>

    <!-- Character — traveler with suitcase and map pin -->
    <div class="hero-globe" style="position:absolute;right:5%;bottom:0;pointer-events:none;" aria-hidden="true">
      <svg width="210" height="370" viewBox="0 0 210 370" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Ground -->
        <rect x="10" y="348" width="190" height="16" rx="8" fill="#c8e6a0" opacity="0.45"/>
        <!-- Suitcase (rolling) -->
        <rect x="128" y="260" width="58" height="80" rx="10" fill="#03def3"/>
        <rect x="142" y="254" width="30" height="10" rx="4" fill="#0bafc0"/>
        <line x1="157" y1="270" x2="157" y2="335" stroke="#0bafc0" stroke-width="3"/>
        <line x1="138" y1="302" x2="176" y2="302" stroke="#0bafc0" stroke-width="3"/>
        <!-- Suitcase wheels -->
        <circle cx="143" cy="344" r="7" fill="#0d3d52"/>
        <circle cx="171" cy="344" r="7" fill="#0d3d52"/>
        <!-- Suitcase handle bar -->
        <rect x="148" y="240" width="18" height="18" rx="5" fill="none" stroke="#0bafc0" stroke-width="3"/>
        <!-- Legs -->
        <rect x="60" y="240" width="28" height="108" rx="12" fill="#374151"/>
        <rect x="92" y="245" width="28" height="103" rx="12" fill="#2d3748"/>
        <!-- Feet -->
        <ellipse cx="74" cy="350" rx="18" ry="8" fill="#1a1a2e"/>
        <ellipse cx="106" cy="350" rx="18" ry="8" fill="#1a1a2e"/>
        <!-- Body (orange jacket) -->
        <rect x="44" y="148" width="112" height="102" rx="18" fill="#FF5F00"/>
        <!-- Backpack hint (darker patch on back) -->
        <rect x="94" y="155" width="60" height="88" rx="12" fill="rgba(0,0,0,0.15)"/>
        <!-- Left arm — raising passport/document up -->
        <path d="M44 162 Q12 148 10 120" stroke="#FF5F00" stroke-width="20" stroke-linecap="round" fill="none"/>
        <circle cx="10" cy="116" r="12" fill="#c68642"/>
        <!-- Right arm — pulling suitcase handle -->
        <path d="M156 165 Q180 190 175 220" stroke="#FF5F00" stroke-width="20" stroke-linecap="round" fill="none"/>
        <circle cx="174" cy="224" r="12" fill="#c68642"/>
        <!-- Neck -->
        <rect x="86" y="135" width="28" height="18" rx="7" fill="#c68642"/>
        <!-- Head -->
        <circle cx="100" cy="105" r="44" fill="#c68642"/>
        <!-- Hair (medium wavy) -->
        <path d="M56 92 Q60 54 100 51 Q140 54 144 92 Q138 66 100 63 Q62 66 56 92Z" fill="#3d1f00"/>
        <ellipse cx="56" cy="88" rx="10" ry="18" fill="#3d1f00"/>
        <ellipse cx="144" cy="88" rx="10" ry="18" fill="#3d1f00"/>
        <!-- Eyes -->
        <ellipse cx="86" cy="102" rx="6" ry="6.5" fill="white"/>
        <ellipse cx="114" cy="102" rx="6" ry="6.5" fill="white"/>
        <circle cx="87" cy="103" r="3.5" fill="#1a0d00"/>
        <circle cx="115" cy="103" r="3.5" fill="#1a0d00"/>
        <circle cx="88.5" cy="101.5" r="1.2" fill="white"/>
        <circle cx="116.5" cy="101.5" r="1.2" fill="white"/>
        <!-- Smile (excited) -->
        <path d="M86 118 Q100 130 114 118" stroke="#a0552a" stroke-width="3" stroke-linecap="round" fill="none"/>
        <!-- Passport in raised hand -->
        <rect x="0" y="96" width="20" height="28" rx="4" fill="#1e3a6e"/>
        <rect x="2" y="99" width="16" height="22" rx="2" fill="#2a4f8a"/>
        <text x="10" y="114" font-size="8" text-anchor="middle" font-family="sans-serif" fill="white" font-weight="700">WW</text>
        <!-- Floating map pins -->
        <path d="M22 46 Q22 28 32 22 Q42 16 52 22 Q62 28 62 46 Q62 60 37 78 Q12 60 22 46Z" fill="#FF5F00"/>
        <circle cx="37" cy="46" r="10" fill="white" opacity="0.9"/>
        <circle cx="37" cy="46" r="6" fill="#FF5F00"/>
        <!-- Second pin -->
        <path d="M150 25 Q150 13 158 8 Q166 3 174 8 Q182 13 182 25 Q182 36 162 48 Q142 36 150 25Z" fill="#03def3" opacity="0.85"/>
        <circle cx="162" cy="25" r="7" fill="white" opacity="0.9"/>
        <circle cx="162" cy="25" r="4" fill="#03def3"/>
      </svg>
    </div>

    <div style="max-width:680px;margin:0 auto;text-align:center;position:relative;z-index:2;width:100%;">
      <span style="display:inline-block;background:rgba(3,222,243,0.15);border:1px solid rgba(3,222,243,0.3);color:#03def3;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;padding:0.35rem 1rem;border-radius:9999px;margin-bottom:1.5rem;">✈️ 195+ Destinations Available</span>

      <h1 style="font-size:3.25rem;font-weight:900;color:white;margin:0 0 1rem;line-height:1.1;letter-spacing:-1.5px;">
        Where Are You<br/>
        <span style="background:linear-gradient(90deg,#03def3,#42BFCA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Travelling Next?</span>
      </h1>

      <p style="color:rgba(255,255,255,0.65);font-size:1rem;margin:0 0 2.5rem;line-height:1.6;">Instant eSIM data for every destination. Buy before you fly — no physical SIM needed.</p>

      <!-- Search -->
      <div style="position:relative;max-width:520px;margin:0 auto 1.5rem;">
        <div style="background:white;border-radius:1rem;padding:0.4rem 0.4rem 0.4rem 1.1rem;display:flex;align-items:center;gap:0.75rem;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2.2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.2-5.2m0 0A7.5 7.5 0 105.2 15.8 7.5 7.5 0 0015.8 15.8z"/></svg>
          <input id="destSearch" type="text" placeholder="Search any country, region, or city..." autocomplete="off"
            style="flex:1;background:none;border:none;outline:none;color:#162544;font-size:0.9rem;font-family:inherit;min-width:0;" />
          <button onclick="filterCards()" style="background:linear-gradient(135deg,#162544,#1e3a6e);color:white;font-weight:700;padding:0.65rem 1.5rem;border-radius:0.75rem;border:none;cursor:pointer;font-size:0.85rem;white-space:nowrap;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Search</button>
        </div>
      </div>

      <!-- Popular searches pills -->
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:center;align-items:center;">
        <span style="font-size:0.72rem;color:rgba(255,255,255,0.45);font-weight:600;">Popular:</span>
        {['Japan','USA','Europe','Thailand','UAE'].map(term => (
          <button
            onclick={`document.getElementById('destSearch').value='${term}';filterCards();document.getElementById('allCountries').scrollIntoView({behavior:'smooth',block:'start'})`}
            style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);font-size:0.75rem;font-weight:600;padding:0.3rem 0.8rem;border-radius:9999px;cursor:pointer;transition:all 0.2s;"
            onmouseover="this.style.background='rgba(3,222,243,0.2)';this.style.borderColor='rgba(3,222,243,0.5)';this.style.color='#03def3'"
            onmouseout="this.style.background='rgba(255,255,255,0.1)';this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='rgba(255,255,255,0.85)'">
            {term}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="background:linear-gradient(135deg,#0f1f3d,#162544);border-bottom:1px solid rgba(3,222,243,0.15);padding:0;">
    <div style="max-width:80rem;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);">
      {[
        { icon:'🌍', value:'195+', label:'Countries', color:'#03def3' },
        { icon:'🗺️', value:'8', label:'Regional Plans', color:'#FF5F00' },
        { icon:'💰', value:'$3.50', label:'Plans from', color:'#03def3' },
        { icon:'⚡', value:'<2 min', label:'Instant Setup', color:'#FF5F00' },
      ].map((s, i) => (
        <div style={`padding:1.5rem 2rem;text-align:center;${i > 0 ? 'border-left:1px solid rgba(255,255,255,0.08);' : ''}`}>
          <div style="font-size:1.4rem;margin-bottom:0.3rem;">{s.icon}</div>
          <div style={`font-size:1.45rem;font-weight:900;color:${s.color};line-height:1;`}>{s.value}</div>
          <div style="font-size:0.72rem;color:rgba(255,255,255,0.5);margin-top:0.2rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Regional Plans Section -->
  <section style="padding:4rem 2rem;background:#f9fafb;">
    <div style="max-width:80rem;margin:0 auto;">

      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <span style="color:#03def3;font-weight:700;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:0.4rem;">Multi-Country Coverage</span>
          <h2 style="font-size:2rem;font-weight:900;color:#162544;margin:0;letter-spacing:-0.5px;">Regional eSIM Plans</h2>
          <p style="color:#6b7280;font-size:0.875rem;margin:0.4rem 0 0;">One plan, multiple countries. No SIM swapping.</p>
        </div>
