<script>
  const search = document.getElementById('destSearch') as HTMLInputElement;
  const grid = document.getElementById('countriesGrid') as HTMLElement;
  const noResults = document.getElementById('noResults') as HTMLElement;
  const countLabel = document.getElementById('countryCount') as HTMLElement;
  const cards = Array.from(grid.querySelectorAll('a[data-region]')) as HTMLElement[];
  let activeRegion = 'All';

  function filterCards() {
    const q = (search?.value ?? '').toLowerCase().trim();
    let visible = 0;
    cards.forEach(card => {
      const name = card.querySelector('span:nth-child(2)')?.textContent?.toLowerCase() ?? '';
      const region = card.dataset.region ?? '';
      const matchSearch = !q || name.includes(q);
      const matchRegion = activeRegion === 'All' || region === activeRegion;
      const show = matchSearch && matchRegion;
      card.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });
    noResults.style.display = visible === 0 ? 'block' : 'none';
    if (countLabel) countLabel.textContent = String(visible);
  }

  // Make filterCards global for onclick
  (window as any).filterCards = filterCards;

  search?.addEventListener('input', filterCards);

  document.querySelectorAll('.rf').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.rf').forEach((b: any) => {
        b.style.background = 'white'; b.style.color = '#6b7280'; b.style.borderColor = '#e5e7eb';
        b.classList.remove('active');
      });
      (btn as HTMLElement).style.background = '#162544';
      (btn as HTMLElement).style.color = 'white';
      (btn as HTMLElement).style.borderColor = '#162544';
      btn.classList.add('active');
      activeRegion = (btn as HTMLElement).dataset.r ?? 'All';
      filterCards();
    });
  });
</script>

