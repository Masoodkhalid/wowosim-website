---
import Base from '../layouts/Base.astro';
import { isLoggedIn } from '../lib/auth';

const loggedIn = isLoggedIn(Astro.cookies);
---

<Base title="Checkout">
  <section style="min-height: calc(100vh - 140px); background: #f9fafb; padding: 3rem 1rem;">
    <div style="max-width: 960px; margin: 0 auto;">
      <h1 style="font-size: 1.75rem; font-weight: 800; color: #162544; margin: 0 0 2rem;">Checkout</h1>

      <div style="display: grid; grid-template-columns: 1fr 380px; gap: 2rem; align-items: start;">

        <!-- Left: Auth + Payment -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">

          {!loggedIn && (
            <div class="card">
              <h2 style="font-size: 1.1rem; font-weight: 700; color: #162544; margin: 0 0 0.25rem;">Sign in to continue</h2>
              <p style="color: #9ca3af; font-size: 0.825rem; margin: 0 0 1.5rem;">You need an account to complete your purchase</p>
              <div style="display: flex; gap: 0.75rem;">
                <a href="/login" class="btn-primary" style="flex: 1; justify-content: center; font-size: 0.875rem;">Sign In</a>
                <a href="/signup" class="btn-outline" style="flex: 1; justify-content: center; font-size: 0.875rem;">Create Account</a>
              </div>
            </div>
          )}

          {loggedIn && (
            <div class="card">
              <h2 style="font-size: 1.1rem; font-weight: 700; color: #162544; margin: 0 0 1.25rem;">Payment</h2>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <button id="payCardBtn" class="btn-primary" style="width: 100%; justify-content: center; font-size: 0.9rem; padding: 0.9rem;">
                  💳 Pay with Card
                </button>
                <button id="payPaypalBtn" style="width: 100%; padding: 0.9rem; border-radius: 9999px; border: 2px solid #e5e7eb; background: white; font-size: 0.9rem; font-weight: 600; color: #374151; cursor: pointer; transition: all 0.2s;"
                   onmouseover="this.style.borderColor='#003087'; this.style.color='#003087'" onmouseout="this.style.borderColor='#e5e7eb'; this.style.color='#374151'">
                  🅿️ Pay with PayPal
                </button>
              </div>
              <div id="checkoutMsg" style="display: none; margin-top: 1rem; font-size: 0.8rem; padding: 0.75rem; border-radius: 0.65rem; text-align: center;"></div>
            </div>
          )}

          <!-- Coupon -->
          {loggedIn && (
            <div class="card">
              <h2 style="font-size: 1rem; font-weight: 700; color: #162544; margin: 0 0 1rem;">Have a coupon?</h2>
              <div style="display: flex; gap: 0.5rem;">
                <input type="text" id="couponInput" placeholder="Enter coupon code"
                  style="flex: 1; padding: 0.7rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none; transition: border 0.2s;"
                  onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
                <button id="applyCoupon" class="btn-primary" style="font-size: 0.85rem; padding: 0.7rem 1.25rem; border-radius: 0.65rem; white-space: nowrap;">Apply</button>
              </div>
              <div id="couponMsg" style="display: none; margin-top: 0.6rem; font-size: 0.78rem;"></div>
            </div>
          )}
        </div>

        <!-- Right: Cart Summary -->
        <div class="card" id="cartSummary">
          <h2 style="font-size: 1rem; font-weight: 700; color: #162544; margin: 0 0 1rem;">Order Summary</h2>
          <div id="cartItems" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem;">
            <p style="color: #9ca3af; font-size: 0.85rem; text-align: center; padding: 1.5rem 0;">Your cart is empty</p>
          </div>
          <div style="border-top: 1px solid #f3f4f6; padding-top: 1rem;">
            <div style="display: flex; justify-content: space-between; font-weight: 700; color: #162544;">
              <span>Total</span>
              <span id="cartTotal">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  // Load cart from cookie
  function getCart() {
    try {
      const raw = document.cookie.match(/wordpress_cart=([^;]+)/)?.[1];
      return raw ? JSON.parse(decodeURIComponent(raw)) : [];
    } catch { return []; }
  }

  const cart = getCart();
  const itemsEl = document.getElementById('cartItems');
  const totalEl = document.getElementById('cartTotal');

  if (cart.length > 0 && itemsEl) {
    let total = 0;
    itemsEl.innerHTML = '';
    cart.forEach((item: any) => {
      total += parseFloat(item.price ?? 0) * (item.quantity ?? 1);
      const div = document.createElement('div');
      div.style.cssText = 'display:flex; justify-content:space-between; align-items:center;';
      div.innerHTML = `<div><p style="font-size:0.85rem;font-weight:600;color:#162544;margin:0;">${item.name ?? 'eSIM Plan'}</p><p style="font-size:0.75rem;color:#9ca3af;margin:0;">${item.data ?? ''} · ${item.duration ?? ''}</p></div><span style="font-weight:700;color:#162544;font-size:0.875rem;">$${parseFloat(item.price ?? 0).toFixed(2)}</span>`;
      itemsEl.appendChild(div);
    });
    if (totalEl) totalEl.textContent = `$${total.toFixed(2)}`;
  }

  // Card pay
  document.getElementById('payCardBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('payCardBtn') as HTMLButtonElement;
    const msg = document.getElementById('checkoutMsg') as HTMLElement;
    btn.textContent = 'Processing...'; btn.disabled = true;
    try {
      const res = await fetch('/api/checkout', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line_items: getCart() }),
      });
      const data = await res.json();
      if (data.redirect_url || data.url) {
        window.location.href = data.redirect_url ?? data.url;
      } else {
        msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626';
        msg.textContent = data.error ?? 'Payment failed. Please try again.';
      }
    } catch {
      msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626';
      msg.textContent = 'Network error. Please try again.';
    } finally { btn.textContent = '💳 Pay with Card'; btn.disabled = false; }
  });
</script>
