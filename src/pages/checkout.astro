---
import Base from '../layouts/Base.astro';
import { isLoggedIn } from '../lib/auth';

const loggedIn = isLoggedIn(Astro.cookies);
// Stripe publishable key — set PUBLIC_STRIPE_KEY in .env
const stripeKey = import.meta.env.PUBLIC_STRIPE_KEY ?? '';
---

<Base title="Checkout" description="Complete your WoWo SIM eSIM purchase securely.">
  <section style="min-height:calc(100vh - 140px);background:#f9fafb;padding:3rem 1rem;">
    <div style="max-width:960px;margin:0 auto;">

      <!-- Page header -->
      <div style="margin-bottom:2rem;">
        <a href="/" style="display:inline-flex;align-items:center;gap:0.3rem;color:#9ca3af;font-size:0.8rem;text-decoration:none;margin-bottom:0.5rem;transition:color 0.15s;" onmouseover="this.style.color='#162544'" onmouseout="this.style.color='#9ca3af'">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Continue Shopping
        </a>
        <h1 style="font-size:1.75rem;font-weight:900;color:#162544;margin:0;letter-spacing:-0.5px;">Checkout</h1>
      </div>

      <div style="display:grid;grid-template-columns:1fr 380px;gap:2rem;align-items:start;">

        <!-- Left: Auth + Payment -->
        <div style="display:flex;flex-direction:column;gap:1.5rem;">

          <!-- Not logged in -->
          {!loggedIn && (
            <div class="card">
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
                <div style="width:40px;height:40px;background:#fef9c3;border-radius:0.875rem;display:flex;align-items:center;justify-content:center;">
                  <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#d97706" stroke-width="2.2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                  </svg>
                </div>
                <div>
                  <h2 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 0.1rem;">Sign in to continue</h2>
                  <p style="color:#9ca3af;font-size:0.8rem;margin:0;">You need an account to complete your purchase</p>
                </div>
              </div>
              <div style="display:flex;gap:0.75rem;">
                <a href="/login?next=/checkout" class="btn-primary" style="flex:1;justify-content:center;font-size:0.875rem;padding:0.75rem;">Sign In</a>
                <a href="/signup" class="btn-outline" style="flex:1;justify-content:center;font-size:0.875rem;padding:0.75rem;">Create Account</a>
              </div>
            </div>
          )}

          <!-- Logged in: Payment options -->
          {loggedIn && (
            <div class="card" id="paymentCard">
              <h2 style="font-size:1.1rem;font-weight:800;color:#162544;margin:0 0 1.25rem;">Payment Method</h2>

              <!-- Step 1: Choose payment — shown initially -->
              <div id="payChoose" style="display:flex;flex-direction:column;gap:0.75rem;">
                <button id="payCardBtn" class="btn-primary" style="width:100%;justify-content:center;font-size:0.925rem;padding:0.9rem;border-radius:0.875rem;gap:0.6rem;">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                  </svg>
                  Pay with Card
                </button>
                <button id="payPaypalBtn"
                  style="width:100%;padding:0.9rem;border-radius:0.875rem;border:2px solid #e5e7eb;background:white;font-size:0.925rem;font-weight:700;color:#003087;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:0.6rem;"
                  onmouseover="this.style.borderColor='#003087';this.style.background='#f0f4ff'" onmouseout="this.style.borderColor='#e5e7eb';this.style.background='white'">
                  <svg width="18" height="14" viewBox="0 0 24 18" fill="none">
                    <text y="14" font-size="13" font-weight="800" fill="#003087">Pay</text>
                    <text x="28" y="14" font-size="13" font-weight="800" fill="#009cde">Pal</text>
                  </svg>
                  Pay with PayPal
                </button>
              </div>

              <!-- Step 2: Stripe Elements form — shown after client_secret is received -->
              <div id="stripeFormWrap" style="display:none;">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.25rem;">
                  <button id="stripeBack" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:0.8rem;padding:0;display:flex;align-items:center;gap:0.3rem;" type="button">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                    Back
                  </button>
                  <span style="font-size:0.9rem;font-weight:700;color:#162544;">Enter Card Details</span>
                  <img src="https://js.stripe.com/v3/fingerprinted/img/visa-365725566f9578a9589553aa9296d178.svg" alt="Visa" style="height:20px;margin-left:auto;" />
                  <img src="https://js.stripe.com/v3/fingerprinted/img/mastercard-4d8844094130711885b5e41b28c9848f.svg" alt="MC" style="height:20px;" />
                </div>
                <!-- Stripe mounts the payment element here -->
                <div id="stripe-payment-element" style="margin-bottom:1.25rem;"></div>
                <button id="stripeConfirmBtn" class="btn-primary" style="width:100%;justify-content:center;font-size:0.95rem;padding:0.9rem;border-radius:0.875rem;gap:0.5rem;" type="button">
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  Confirm Payment
                </button>
                <p style="font-size:0.7rem;color:#9ca3af;text-align:center;margin:0.75rem 0 0;display:flex;align-items:center;justify-content:center;gap:0.3rem;">
                  <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  Secured by Stripe
                </p>
              </div>

              <div id="checkoutMsg" style="display:none;margin-top:1rem;font-size:0.8rem;padding:0.75rem;border-radius:0.75rem;text-align:center;"></div>
            </div>
          )}

          <!-- Coupon code -->
          {loggedIn && (
            <div class="card">
              <h2 style="font-size:1rem;font-weight:700;color:#162544;margin:0 0 1rem;">Have a promo code?</h2>
              <div style="display:flex;gap:0.5rem;">
                <input type="text" id="couponInput" placeholder="Enter promo code"
                  class="form-input" style="flex:1;" />
                <button id="applyCoupon" class="btn-primary" style="font-size:0.85rem;padding:0.7rem 1.25rem;border-radius:0.75rem;white-space:nowrap;">Apply</button>
              </div>
              <div id="couponMsg" style="display:none;margin-top:0.6rem;font-size:0.78rem;"></div>
            </div>
          )}

          <!-- Trust signals -->
          <div style="display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;padding:1rem 0;">
            {[
              { icon: '🔒', text: '256-bit SSL encryption' },
              { icon: '⚡', text: 'Instant activation' },
              { icon: '💬', text: '24/7 support' },
            ].map(t => (
              <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.75rem;color:#9ca3af;">
                <span style="font-size:1rem;">{t.icon}</span>
                {t.text}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Order Summary -->
        <div class="card" id="cartSummary" style="position:sticky;top:80px;">
          <h2 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 1.25rem;">Order Summary</h2>
          <div id="cartItems" style="display:flex;flex-direction:column;gap:0.875rem;margin-bottom:1rem;min-height:60px;">
            <p style="color:#9ca3af;font-size:0.85rem;text-align:center;padding:1.5rem 0;" id="cartEmptyMsg">
              Your cart is empty
            </p>
          </div>

          <div style="border-top:1.5px solid #f3f4f6;padding-top:1rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
              <span style="font-size:0.85rem;color:#9ca3af;">Subtotal</span>
              <span id="cartSubtotal" style="font-size:0.875rem;color:#374151;font-weight:600;">$0.00</span>
            </div>
            <div id="discountRow" style="display:none;flex-direction:row;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
              <span style="font-size:0.85rem;color:#22c55e;">Promo discount</span>
              <span id="discountAmount" style="font-size:0.875rem;color:#22c55e;font-weight:700;">-$0.00</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding-top:0.75rem;border-top:1px solid #f3f4f6;">
              <span style="font-size:1rem;font-weight:800;color:#162544;">Total</span>
              <span id="cartTotal" style="font-size:1.5rem;font-weight:900;color:#162544;letter-spacing:-0.5px;">$0.00</span>
            </div>
          </div>

          <p style="font-size:0.72rem;color:#9ca3af;text-align:center;margin:0.75rem 0 0;">
            Secure checkout. Instant delivery to your email.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  interface CartItem {
    name?: string;
    country?: string;
    flag?: string;
    quota?: number | string;
    valadity?: number | string;
    price_usd?: number | string;
    price?: number | string;
    quantity?: number;
  }

  function getCart(): CartItem[] {
    try {
      const raw = document.cookie.match(/wordpress_cart=([^;]+)/)?.[1];
      return raw ? JSON.parse(decodeURIComponent(raw)) : [];
    } catch { return []; }
  }

  function getPrice(item: CartItem): number {
    return parseFloat(String(item.price_usd ?? item.price ?? 0));
  }

  function renderCart() {
    const cart = getCart();
    const itemsEl   = document.getElementById('cartItems') as HTMLElement;
    const totalEl   = document.getElementById('cartTotal') as HTMLElement;
    const subtotalEl = document.getElementById('cartSubtotal') as HTMLElement;
    const emptyMsg  = document.getElementById('cartEmptyMsg') as HTMLElement;

    if (!itemsEl) return;

    if (cart.length === 0) {
      if (emptyMsg) emptyMsg.style.display = 'block';
      return;
    }

    if (emptyMsg) emptyMsg.style.display = 'none';

    let total = 0;
    const rows = cart.map((item, idx) => {
      const price = getPrice(item);
      const qty   = item.quantity ?? 1;
      total += price * qty;
      const name  = item.name ?? item.country ?? 'eSIM Plan';
      const data  = item.quota ? `${item.quota}GB` : '';
      const days  = item.valadity ? `${item.valadity} days` : '';
      const meta  = [data, days].filter(Boolean).join(' · ');
      const flagHtml = item.flag
        ? `<img src="${item.flag}" alt="" style="width:28px;height:20px;border-radius:3px;object-fit:cover;" />`
        : `<span style="font-size:1.1rem;">🌐</span>`;

      return `
        <div style="display:flex;align-items:center;gap:0.75rem;padding-bottom:0.875rem;border-bottom:1px solid #f9fafb;">
          <div style="width:44px;height:44px;background:#f0fdff;border-radius:0.75rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            ${flagHtml}
          </div>
          <div style="flex:1;min-width:0;">
            <p style="font-size:0.875rem;font-weight:700;color:#162544;margin:0;">${name}</p>
            ${meta ? `<p style="font-size:0.75rem;color:#9ca3af;margin:0.1rem 0 0;">${meta}</p>` : ''}
          </div>
          <div style="text-align:right;flex-shrink:0;">
            <p style="font-size:0.975rem;font-weight:800;color:#162544;margin:0;">$${price.toFixed(2)}</p>
            ${qty > 1 ? `<p style="font-size:0.72rem;color:#9ca3af;margin:0;">×${qty}</p>` : ''}
          </div>
        </div>
      `;
    });

    // Remove old rows but keep empty msg
    const existingRows = itemsEl.querySelectorAll('.cart-row');
    existingRows.forEach(r => r.remove());

    const wrapper = document.createElement('div');
    wrapper.className = 'cart-row';
    wrapper.style.display = 'flex';
    wrapper.style.flexDirection = 'column';
    wrapper.style.gap = '0.875rem';
    wrapper.innerHTML = rows.join('');
    itemsEl.insertBefore(wrapper, emptyMsg);

    if (totalEl) totalEl.textContent = `$${total.toFixed(2)}`;
    if (subtotalEl) subtotalEl.textContent = `$${total.toFixed(2)}`;
  }

  renderCart();

  // ── Stripe publishable key (from server env, or from portal response) ──
  const STRIPE_KEY_ENV = (import.meta as any).env?.PUBLIC_STRIPE_KEY ?? '';
  let _stripeInstance: any = null;
  let _stripeElements: any = null;

  function showMsg(text: string, type: 'error' | 'info' | 'success' = 'error') {
    const msg = document.getElementById('checkoutMsg') as HTMLElement;
    if (!msg) return;
    msg.style.display = 'block';
    msg.style.background = type === 'error' ? '#fee2e2' : type === 'success' ? '#dcfce7' : '#dbeafe';
    msg.style.color     = type === 'error' ? '#dc2626' : type === 'success' ? '#166534' : '#1d4ed8';
    msg.textContent = text;
  }
  function hideMsg() {
    const msg = document.getElementById('checkoutMsg') as HTMLElement;
    if (msg) msg.style.display = 'none';
  }
  function setLoading(btnId: string, loading: boolean, origHtml = '') {
    const btn = document.getElementById(btnId) as HTMLButtonElement;
    if (!btn) return;
    btn.disabled = loading;
    if (loading) btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 0.8s linear infinite;"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Processing…`;
    else if (origHtml) btn.innerHTML = origHtml;
  }

  /** Load Stripe.js lazily, return Stripe instance */
  async function loadStripe(publishableKey: string): Promise<any> {
    if (_stripeInstance) return _stripeInstance;
    if (!(window as any).Stripe) {
      await new Promise<void>((resolve, reject) => {
        const s = document.createElement('script');
        s.src = 'https://js.stripe.com/v3/';
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('Failed to load Stripe.js'));
        document.head.appendChild(s);
      });
    }
    _stripeInstance = (window as any).Stripe(publishableKey);
    return _stripeInstance;
  }

  /** Show the Stripe Elements card form with the given client_secret */
  async function mountStripeForm(clientSecret: string, publishableKey: string) {
    try {
      const stripe = await loadStripe(publishableKey);
      _stripeElements = stripe.elements({ clientSecret, appearance: { theme: 'stripe', variables: { colorPrimary: '#162544', borderRadius: '8px' } } });
      const payEl = _stripeElements.create('payment');
      payEl.mount('#stripe-payment-element');

      // Switch view: hide choose buttons, show form
      (document.getElementById('payChoose') as HTMLElement).style.display = 'none';
      (document.getElementById('stripeFormWrap') as HTMLElement).style.display = 'block';
      hideMsg();
    } catch (e: any) {
      showMsg('Failed to load payment form. Please refresh and try again.');
      console.error('[WoWo] Stripe Elements mount error:', e);
    }
  }

  // ── Pay with Card button ──
  document.getElementById('payCardBtn')?.addEventListener('click', async () => {
    const origHtml = (document.getElementById('payCardBtn') as HTMLButtonElement)?.innerHTML ?? '';
    setLoading('payCardBtn', true);
    hideMsg();

    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line_items: getCart() }),
      });
      const data = await res.json();
      console.log('[WoWo] Checkout response:', JSON.stringify(data, null, 2));

      // ── PaymentIntent flow (portal returns client_secret) ──
      if (data.client_secret) {
        const pubKey = data.publishable_key || STRIPE_KEY_ENV;
        if (!pubKey || pubKey.startsWith('pk_live_REPLACE')) {
          showMsg('Stripe is not configured yet. Please contact support.');
          return;
        }
        await mountStripeForm(data.client_secret, pubKey);
        return; // Don't re-enable button — form is now shown
      }

      // ── Checkout Session flow (portal returns redirect URL) ──
      const redirectUrl = data.redirect_url ?? data.url ?? data.checkout_url ?? null;
      if (redirectUrl) {
        window.location.href = redirectUrl;
        return;
      }

      // Neither — show error
      const errText = data.error ?? 'Payment could not be initiated. Please try again.';
      showMsg(errText);
      console.error('[WoWo] Checkout error:', errText);
      console.error('[WoWo] Debug:', JSON.stringify(data.debug ?? data, null, 2));
    } catch (e) {
      showMsg('Network error. Please check your connection and try again.');
      console.error('[WoWo] Checkout network error:', e);
    } finally {
      setLoading('payCardBtn', false, origHtml);
    }
  });

  // ── Stripe Elements confirm payment ──
  document.getElementById('stripeConfirmBtn')?.addEventListener('click', async () => {
    if (!_stripeInstance || !_stripeElements) return;
    const origHtml = (document.getElementById('stripeConfirmBtn') as HTMLButtonElement)?.innerHTML ?? '';
    setLoading('stripeConfirmBtn', true);
    hideMsg();

    const { error } = await _stripeInstance.confirmPayment({
      elements: _stripeElements,
      confirmParams: {
        return_url: window.location.origin + '/checkout/success',
      },
    });

    // If we reach here, payment failed or requires action
    if (error) {
      showMsg(error.message ?? 'Payment failed. Please check your card details.');
      console.error('[WoWo] Stripe confirmPayment error:', error);
    }
    setLoading('stripeConfirmBtn', false, origHtml);
  });

  // ── Back button in Stripe form ──
  document.getElementById('stripeBack')?.addEventListener('click', () => {
    (document.getElementById('payChoose') as HTMLElement).style.display = 'flex';
    (document.getElementById('stripeFormWrap') as HTMLElement).style.display = 'none';
    (document.getElementById('stripe-payment-element') as HTMLElement).innerHTML = '';
    _stripeElements = null;
    hideMsg();
  });

  // ── Pay with PayPal ──
  document.getElementById('payPaypalBtn')?.addEventListener('click', () => {
    showMsg('PayPal integration coming soon. Please use card payment.', 'info');
  });

  // Coupon apply
  let appliedDiscount = 0;
  let appliedType = 'percent';

  function updateTotals() {
    const cart = getCart();
    const subtotal = cart.reduce((s, i) => s + getPrice(i) * (i.quantity ?? 1), 0);
    const subtotalEl = document.getElementById('cartSubtotal') as HTMLElement;
    const totalEl = document.getElementById('cartTotal') as HTMLElement;
    const discountRow = document.getElementById('discountRow') as HTMLElement;
    const discountAmountEl = document.getElementById('discountAmount') as HTMLElement;

    if (subtotalEl) subtotalEl.textContent = `$${subtotal.toFixed(2)}`;

    let discount = 0;
    if (appliedDiscount > 0) {
      discount = appliedType === 'percent' ? subtotal * appliedDiscount / 100 : appliedDiscount;
      if (discountRow) discountRow.style.display = 'flex';
      if (discountAmountEl) discountAmountEl.textContent = `-$${discount.toFixed(2)}`;
    } else {
      if (discountRow) discountRow.style.display = 'none';
    }
    if (totalEl) totalEl.textContent = `$${Math.max(0, subtotal - discount).toFixed(2)}`;
  }

  document.getElementById('applyCoupon')?.addEventListener('click', async () => {
    const code = (document.getElementById('couponInput') as HTMLInputElement)?.value.trim();
    const msg  = document.getElementById('couponMsg') as HTMLElement;
    const btn  = document.getElementById('applyCoupon') as HTMLButtonElement;
    if (!code) {
      msg.style.display = 'block'; msg.style.color = '#dc2626';
      msg.textContent = 'Please enter a promo code.'; return;
    }
    msg.style.display = 'block'; msg.style.color = '#6b7280'; msg.textContent = 'Checking code…';
    btn.disabled = true;
    const cart = getCart();
    const subtotal = cart.reduce((s, i) => s + getPrice(i) * (i.quantity ?? 1), 0);
    try {
      const res = await fetch('/api/coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, subtotal }),
      });
      const data = await res.json();
      if (data.valid) {
        appliedDiscount = data.discount;
        appliedType = data.type;
        msg.style.color = '#15803d';
        msg.textContent = `✓ ${data.label} applied! You save $${data.discountAmount?.toFixed(2) ?? '—'}`;
        updateTotals();
      } else {
        msg.style.color = '#dc2626';
        msg.textContent = data.message ?? 'Promo code not found or expired.';
      }
    } catch {
      msg.style.color = '#dc2626'; msg.textContent = 'Could not validate code. Try again.';
    } finally {
      btn.disabled = false;
    }
  });

  // Update totals on load
  updateTotals();
</script>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @media (max-width: 768px) {
    section > div > div:last-child { grid-template-columns: 1fr !important; }
    #cartSummary { position: static !important; }
  }
</style>
