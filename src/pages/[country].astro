---
import Base from '../layouts/Base.astro';
import { portalFetch } from '../lib/api';

const { country } = Astro.params;

const slugToIso3: Record<string, string> = {
  // A
  'afghanistan':'AFG','albania':'ALB','algeria':'DZA','argentina':'ARG','armenia':'ARM',
  'australia':'AUS','austria':'AUT','azerbaijan':'AZE',
  // B
  'bahrain':'BHR','bangladesh':'BGD','belgium':'BEL','bolivia':'BOL','brazil':'BRA',
  'bulgaria':'BGR',
  // C
  'cambodia':'KHM','canada':'CAN','chile':'CHL','china':'CHN','colombia':'COL',
  'costa-rica':'CRI','croatia':'HRV','cyprus':'CYP','czech-republic':'CZE',
  // D
  'denmark':'DNK',
  // E
  'ecuador':'ECU','egypt':'EGY','estonia':'EST','ethiopia':'ETH',
  // F
  'finland':'FIN','france':'FRA',
  // G
  'georgia':'GEO','germany':'DEU','ghana':'GHA','greece':'GRC',
  // H
  'hong-kong':'HKG','hungary':'HUN',
  // I
  'iceland':'ISL','india':'IND','indonesia':'IDN','ireland':'IRL','israel':'ISR',
  'italy':'ITA',
  // J
  'japan':'JPN','jordan':'JOR',
  // K
  'kazakhstan':'KAZ','kenya':'KEN','kuwait':'KWT',
  // L
  'laos':'LAO','latvia':'LVA','lithuania':'LTU','luxembourg':'LUX',
  // M
  'macau':'MAC','malaysia':'MYS','malta':'MLT','mexico':'MEX','mongolia':'MNG',
  'morocco':'MAR','myanmar':'MMR',
  // N
  'nepal':'NPL','netherlands':'NLD','new-zealand':'NZL','nigeria':'NGA','norway':'NOR',
  // O
  'oman':'OMN',
  // P
  'pakistan':'PAK','panama':'PAN','peru':'PER','philippines':'PHL','poland':'POL',
  'portugal':'PRT',
  // Q
  'qatar':'QAT',
  // R
  'romania':'ROU','russia':'RUS',
  // S
  'saudi-arabia':'SAU','serbia':'SRB','singapore':'SGP','slovakia':'SVK',
  'slovenia':'SVN','south-africa':'ZAF','south-korea':'KOR','spain':'ESP',
  'sri-lanka':'LKA','sweden':'SWE','switzerland':'CHE',
  // T
  'taiwan':'TWN','tanzania':'TZA','thailand':'THA','turkey':'TUR',
  // U
  'uae':'ARE','ukraine':'UKR','united-arab-emirates':'ARE','united-kingdom':'GBR',
  'united-states':'USA','uruguay':'URY','uzbekistan':'UZB',
  // V
  'venezuela':'VEN','vietnam':'VNM',
  // Z
  'zimbabwe':'ZWE',
  // Regions — ISO3 codes from portal API
  'europe':'EUROPE','asia-pacific':'ASIA_20','asia-20':'ASIA_20','asia-18':'ASIA_18',
  'asia-12':'ASIA_12','asia-7':'ASIA_7','north-america':'NAM','latin-america':'LATAM',
  'middle-east':'MENA','middle-east-north-africa':'MENA','gulf':'GULF',
  'caribbean':'CAR','caucasus':'CAU','caucasus-region':'CAU',
  'global-120':'GLOBAL_120','global-140':'GLOBAL_140','global':'GLOBAL_140',
};

const slugToName: Record<string, string> = {
  'afghanistan':'Afghanistan','albania':'Albania','algeria':'Algeria','argentina':'Argentina',
  'armenia':'Armenia','australia':'Australia','austria':'Austria','azerbaijan':'Azerbaijan',
  'bahrain':'Bahrain','bangladesh':'Bangladesh','belgium':'Belgium','bolivia':'Bolivia',
  'brazil':'Brazil','bulgaria':'Bulgaria','cambodia':'Cambodia','canada':'Canada',
  'chile':'Chile','china':'China','colombia':'Colombia','costa-rica':'Costa Rica',
  'croatia':'Croatia','cyprus':'Cyprus','czech-republic':'Czech Republic','denmark':'Denmark',
  'ecuador':'Ecuador','egypt':'Egypt','estonia':'Estonia','ethiopia':'Ethiopia',
  'finland':'Finland','france':'France','georgia':'Georgia','germany':'Germany',
  'ghana':'Ghana','greece':'Greece','hong-kong':'Hong Kong','hungary':'Hungary',
  'iceland':'Iceland','india':'India','indonesia':'Indonesia','ireland':'Ireland',
  'israel':'Israel','italy':'Italy','japan':'Japan','jordan':'Jordan',
  'kazakhstan':'Kazakhstan','kenya':'Kenya','kuwait':'Kuwait','laos':'Laos',
  'latvia':'Latvia','lithuania':'Lithuania','luxembourg':'Luxembourg','macau':'Macau',
  'malaysia':'Malaysia','malta':'Malta','mexico':'Mexico','mongolia':'Mongolia',
  'morocco':'Morocco','myanmar':'Myanmar','nepal':'Nepal','netherlands':'Netherlands',
  'new-zealand':'New Zealand','nigeria':'Nigeria','norway':'Norway','oman':'Oman',
  'pakistan':'Pakistan','panama':'Panama','peru':'Peru','philippines':'Philippines',
  'poland':'Poland','portugal':'Portugal','qatar':'Qatar','romania':'Romania',
  'russia':'Russia','saudi-arabia':'Saudi Arabia','serbia':'Serbia',
  'singapore':'Singapore','slovakia':'Slovakia','slovenia':'Slovenia',
  'south-africa':'South Africa','south-korea':'South Korea','spain':'Spain',
  'sri-lanka':'Sri Lanka','sweden':'Sweden','switzerland':'Switzerland','taiwan':'Taiwan',
  'tanzania':'Tanzania','thailand':'Thailand','turkey':'Turkey','uae':'UAE',
  'united-arab-emirates':'United Arab Emirates','ukraine':'Ukraine',
  'united-kingdom':'United Kingdom','united-states':'United States','uruguay':'Uruguay',
  'uzbekistan':'Uzbekistan','venezuela':'Venezuela','vietnam':'Vietnam','zimbabwe':'Zimbabwe',
  'europe':'Europe','asia-pacific':'Asia Pacific','north-america':'North America',
  'latin-america':'Latin America','middle-east':'Middle East','caribbean':'Caribbean',
  'caucasus-region':'Caucasus Region','global':'Global',
};

// Countries covered per region
const regionCountries: Record<string, string[]> = {
  'EUR': ['France','Germany','Italy','Spain','Netherlands','Belgium','Portugal','Greece',
          'Austria','Switzerland','Sweden','Norway','Denmark','Finland','Poland','Czech Republic',
          'Hungary','Romania','Croatia','Slovakia','Slovenia','Bulgaria','Estonia','Latvia',
          'Lithuania','Luxembourg','Malta','Cyprus','Iceland','Ireland','Serbia','Albania'],
  'ASIA': ['Japan','South Korea','Australia','New Zealand','Singapore','Malaysia','Thailand',
           'Vietnam','Philippines','Indonesia','India','Hong Kong','Taiwan','Macau',
           'Cambodia','Myanmar','Laos','Mongolia','Bangladesh','Nepal','Sri Lanka'],
  'NAM': ['United States','Canada','Mexico'],
  'LAM': ['Brazil','Argentina','Chile','Colombia','Peru','Bolivia','Ecuador','Uruguay',
          'Venezuela','Paraguay','Costa Rica','Panama','Guatemala','Honduras','El Salvador'],
  'MDE': ['UAE','Saudi Arabia','Qatar','Kuwait','Bahrain','Oman','Jordan','Israel','Egypt','Turkey'],
  'CAR': ['Bahamas','Jamaica','Trinidad and Tobago','Barbados','Cayman Islands','Bermuda',
          'Dominican Republic','Puerto Rico','Aruba','Curaçao','Sint Maarten'],
  'CAU': ['Georgia','Armenia','Azerbaijan'],
  'GLOBAL': ['195+ countries worldwide'],
};

const iso3 = slugToIso3[country ?? ''];
const countryName = slugToName[country ?? ''] ?? (country?.replace(/-/g,' ') ?? '');
if (!iso3) return Astro.redirect('/');

let plans: any[] = [];
let flagUrl = '';
let networkName = '';

const apiAttempts = [
  `/plans?q[iso3_eq]=${iso3}`,
  `/plans?q[iso3_eq]=${iso3.toLowerCase()}`,
  `/plans?iso3=${iso3}`,
  `/plans?region=${iso3.toLowerCase()}`,
];

for (const endpoint of apiAttempts) {
  try {
    const res = await portalFetch(endpoint);
    if (res.ok) {
      const d = await res.json();
      const found = (d.plans ?? d.data ?? d ?? []);
      if (Array.isArray(found) && found.length > 0) {
        plans = found.filter((p: any) => p.is_active !== false);
        if (plans.length > 0) {
          flagUrl = plans[0].flag ?? '';
          networkName = plans[0].network ?? '';
          break;
        }
      }
    }
  } catch {}
}

if (plans.length > 0) {
  const bestIdx = plans.reduce((best, p, i) =>
    ((p.quota || 0) / (p.price_usd || 1)) > ((plans[best].quota || 0) / (plans[best].price_usd || 1)) ? i : best, 0);
  plans[bestIdx]._bestValue = true;
}

const minPrice = plans.length > 0 ? Math.min(...plans.map((p:any) => parseFloat(p.price_usd) || 0)) : 0;
const isRegion = ['EUR','ASIA','NAM','LAM','MDE','CAR','CAU','GLOBAL'].includes(iso3);
const coveredCountries = regionCountries[iso3] ?? [];

// For regional plans: detect coverage tier from plan data
function getPlanCoverageCount(plan: any): number {
  if (Array.isArray(plan.countries)) return plan.countries.length;
  if (typeof plan.countries_count === 'number') return plan.countries_count;
  if (typeof plan.country_count === 'number') return plan.country_count;
  // Try to extract from name e.g. "Asia 7 Countries" or "7 Countries"
  const nameMatch = String(plan.name ?? plan.title ?? '').match(/(\d+)\s*countr/i);
  if (nameMatch) return parseInt(nameMatch[1]);
  return 0;
}

// Group regional plans by coverage tier
type PlanGroup = { count: number; label: string; plans: any[] };
const planGroups: PlanGroup[] = [];
if (isRegion) {
  const grouped = new Map<number, any[]>();
  for (const p of plans) {
    const cnt = getPlanCoverageCount(p);
    if (!grouped.has(cnt)) grouped.set(cnt, []);
    grouped.get(cnt)!.push(p);
  }
  // Sort groups: 0 (unknown) last, others ascending
  const sorted = [...grouped.entries()].sort((a, b) => {
    if (a[0] === 0) return 1;
    if (b[0] === 0) return -1;
    return a[0] - b[0];
  });
  for (const [count, groupPlans] of sorted) {
    let label = count > 0 ? `${count} Countries` : countryName;
    planGroups.push({ count, label, plans: groupPlans });
  }
}

// Tier color map for regional plans
const tierColors = ['#03def3', '#FF5F00', '#42BFCA', '#6366f1'];

const faqs = [
  {
    q: `How does ${countryName} eSIM work?`,
    a: `Purchase a plan online, receive a QR code by email instantly. Scan it in your phone Settings → Mobile Data → Add eSIM. Data activates automatically when you arrive in ${countryName}. The whole process takes less than 2 minutes.`,
  },
  {
    q: `Which networks does WoWo SIM use in ${countryName}?`,
    a: networkName
      ? `WoWo SIM connects to ${networkName} in ${countryName}, giving you excellent 4G LTE and 5G coverage across the country.`
      : `WoWo SIM connects to top local networks in ${countryName} for maximum coverage and speed.`,
  },
  {
    q: 'Can I keep using my regular phone number?',
    a: 'Yes! Your physical SIM card stays active for calls and SMS. The eSIM only handles mobile data. You can receive calls and texts on your regular number while using WoWo SIM data.',
  },
  {
    q: 'What happens when my data runs out?',
    a: "You'll receive a notification when you're running low. Simply log in to your dashboard and purchase a new plan — it activates within seconds. No service interruption.",
  },
  {
    q: 'Can I use it as a hotspot/tethering?',
    a: 'Yes, WoWo SIM plans support hotspot and tethering on most compatible devices, so you can share your connection with laptops, tablets, and other devices.',
  },
  {
    q: `Do I need to buy the plan before I arrive in ${isRegion ? 'the region' : countryName}?`,
    a: `We recommend purchasing before you travel so your eSIM is ready to go the moment you land. However, you can also buy and install it on arrival as long as you have a Wi-Fi connection.`,
  },
];
---

<Base
  title={`${countryName} eSIM — Plans from $${minPrice.toFixed(2)} | WoWo SIM`}
  description={`Buy ${countryName} eSIM instantly. ${plans.length} plans from $${minPrice.toFixed(2)}. ${networkName ? networkName + ' network. ' : ''}Instant QR code delivery. No contracts, no roaming fees.`}
>

<!-- Breadcrumb + Hero -->
<section style="background:linear-gradient(135deg,#0f1f3d 0%,#162544 60%,#1a2d50 100%);padding:3.5rem 1.5rem 4rem;position:relative;overflow:hidden;">
  <div style="position:absolute;top:-80px;right:-80px;width:320px;height:320px;background:rgba(3,222,243,0.06);border-radius:50%;filter:blur(50px);pointer-events:none;"></div>
  <div style="position:absolute;bottom:-60px;left:-60px;width:240px;height:240px;background:rgba(59,130,246,0.05);border-radius:50%;filter:blur(40px);pointer-events:none;"></div>

  <div style="max-width:72rem;margin:0 auto;position:relative;z-index:1;">
    <nav style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;font-size:0.75rem;color:#6b7280;">
      <a href="/" style="color:#9ca3af;text-decoration:none;" onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">Home</a>
      <span>›</span>
      {isRegion ? (
        <>
          <a href="/#plans" style="color:#9ca3af;text-decoration:none;" onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">Regions</a>
          <span>›</span>
        </>
      ) : (
        <>
          <a href="/#plans" style="color:#9ca3af;text-decoration:none;" onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">Countries</a>
          <span>›</span>
        </>
      )}
      <span style="color:#03def3;">{countryName}</span>
    </nav>

    <div style="display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;">
      <div>
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;">
          {flagUrl && <img src={flagUrl} alt={countryName} style="width:52px;height:36px;object-fit:cover;border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,0.3);" loading="eager" />}
          <h1 style="font-size:2.5rem;font-weight:900;color:white;margin:0;letter-spacing:-0.5px;line-height:1.1;">
            {countryName} eSIM
          </h1>
        </div>

        <p style="color:#9ca3af;font-size:1rem;max-width:520px;margin:0 0 1.5rem;line-height:1.6;">
          {isRegion
            ? `One eSIM covering all ${countryName} countries. No SIM swapping, no roaming fees. Stay connected across ${coveredCountries.length > 0 ? coveredCountries.length + '+' : 'multiple'} destinations.`
            : `Stay connected in ${countryName} with instant data. ${networkName ? `Powered by ${networkName}.` : ''} No physical SIM needed, no contracts.`
          }
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:1.5rem;">
          {[
            { icon:'⚡', text:'Instant QR delivery' },
            { icon:'📶', text: networkName || '4G LTE / 5G' },
            { icon:'🔒', text:'No contracts' },
            isRegion ? { icon:'🌍', text:`${coveredCountries.length}+ countries` } : { icon:'💬', text:'24/7 support' },
          ].map(b => (
            <div style="display:flex;align-items:center;gap:0.4rem;color:#9ca3af;font-size:0.82rem;">
              <span>{b.icon}</span><span>{b.text}</span>
            </div>
          ))}
        </div>
      </div>

      {plans.length > 0 && (
        <div style="background:rgba(3,222,243,0.1);border:1px solid rgba(3,222,243,0.2);border-radius:1.25rem;padding:1.5rem 2rem;text-align:center;flex-shrink:0;">
          <p style="color:#9ca3af;font-size:0.75rem;margin:0 0 0.25rem;text-transform:uppercase;letter-spacing:0.05em;">Starting from</p>
          <p style="color:white;font-size:2.75rem;font-weight:900;margin:0 0 0.25rem;line-height:1;">${minPrice.toFixed(2)}</p>
          <p style="color:#03def3;font-size:0.78rem;font-weight:600;margin:0;">{plans.length} plans available</p>
        </div>
      )}
    </div>
  </div>
</section>

<!-- Plans Grid -->
<section style="padding:3rem 1.5rem;background:#f9fafb;" id="plans">
  <div style="max-width:72rem;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;">
      <h2 style="font-size:1.4rem;font-weight:800;color:#162544;margin:0;">
        {plans.length > 0 ? `${plans.length} Plans Available` : 'Available Plans'}
      </h2>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;" id="sortBtns">
        {['Popular','Data','Price','Duration'].map((s,i) => (
          <button class="sort-btn" data-sort={s.toLowerCase()}
            style={`padding:0.35rem 0.75rem;border-radius:9999px;font-size:0.75rem;font-weight:600;cursor:pointer;border:1.5px solid ${i===0?'#03def3':'#e5e7eb'};background:${i===0?'#03def3':'white'};color:${i===0?'#162544':'#6b7280'};transition:all 0.2s;`}>
            {s}
          </button>
        ))}
      </div>
    </div>

    {plans.length === 0 ? (
      <div style="text-align:center;padding:4rem;background:white;border-radius:1.25rem;border:1px solid #f3f4f6;">
        <div style="font-size:3rem;margin-bottom:1rem;">📡</div>
        <h3 style="font-size:1.1rem;font-weight:700;color:#162544;margin:0 0 0.5rem;">Plans coming soon</h3>
        <p style="color:#9ca3af;font-size:0.875rem;margin:0 0 1.5rem;">No plans are available for this destination right now.</p>
        <a href="/" class="btn-primary">Browse Other Destinations →</a>
      </div>
    ) : isRegion && planGroups.length > 1 ? (
      <!-- Regional grouped display -->
      <div style="display:flex;flex-direction:column;gap:2.5rem;" id="plansGrid">
        {planGroups.map((group, gi) => (
          <div>
            <!-- Tier header -->
            <div style={`display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;padding:1rem 1.25rem;background:white;border-radius:1rem;border-left:4px solid ${tierColors[gi % tierColors.length]};box-shadow:0 1px 4px rgba(0,0,0,0.06);`}>
              <div style={`width:40px;height:40px;border-radius:0.75rem;background:${tierColors[gi % tierColors.length]}20;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                <span style="font-size:1.2rem;">{gi === 0 ? '🌏' : gi === 1 ? '🌍' : '🌐'}</span>
              </div>
              <div style="flex:1;">
                <h3 style={`font-size:1rem;font-weight:800;color:#162544;margin:0 0 0.1rem;`}>
                  {group.count > 0 ? `${group.label} Coverage` : `${countryName} Plans`}
                </h3>
                <p style="font-size:0.78rem;color:#9ca3af;margin:0;">
                  {group.count > 0
                    ? `Works in ${group.count} countries across the region`
                    : `All ${countryName} plans`}
                  &nbsp;·&nbsp;{group.plans.length} plan{group.plans.length > 1 ? 's' : ''} available
                </p>
              </div>
              {group.count > 0 && (
                <span style={`font-size:0.72rem;font-weight:700;padding:0.25rem 0.65rem;border-radius:9999px;background:${tierColors[gi % tierColors.length]}15;color:${tierColors[gi % tierColors.length]};border:1px solid ${tierColors[gi % tierColors.length]}40;`}>
                  {group.count} Countries
                </span>
              )}
            </div>
            <!-- Plans in this tier -->
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;">
              {group.plans.map((plan: any) => (
                <div class="plan-card"
                     style={`background:white;border-radius:1.25rem;border:${plan._bestValue?`2px solid ${tierColors[gi % tierColors.length]}`:'1.5px solid #f3f4f6'};padding:1.5rem;position:relative;transition:all 0.25s;box-shadow:${plan._bestValue?`0 4px 20px ${tierColors[gi % tierColors.length]}25`:'0 1px 4px rgba(0,0,0,0.06)'};`}
                     data-quota={plan.quota} data-price={plan.price_usd} data-days={plan.valadity}>
                  {plan._bestValue && (
                    <div style={`position:absolute;top:-1px;right:1rem;background:${tierColors[gi % tierColors.length]};color:${gi===0?'#162544':'white'};font-size:0.65rem;font-weight:800;padding:0.25rem 0.6rem;border-radius:0 0 0.5rem 0.5rem;text-transform:uppercase;letter-spacing:0.05em;`}>
                      Best Value
                    </div>
                  )}
                  {plan.discount_percentage > 0 && (
                    <div style="position:absolute;top:1rem;left:1rem;background:#fef3c7;color:#d97706;font-size:0.65rem;font-weight:700;padding:0.2rem 0.5rem;border-radius:9999px;">
                      -{plan.discount_percentage}% OFF
                    </div>
                  )}
                  <div style={`text-align:center;padding:1.5rem 0 1rem;margin-bottom:1rem;border-bottom:1px solid #f3f4f6;${plan.discount_percentage>0?'padding-top:2rem;':''}`}>
                    <p style="font-size:3rem;font-weight:900;color:#162544;margin:0;line-height:1;">{plan.quota}<span style="font-size:1.25rem;color:#6b7280;font-weight:600;">GB</span></p>
                    <p style="color:#9ca3af;font-size:0.8rem;margin:0.3rem 0 0;">{plan.valadity} days validity</p>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.25rem;">
                    {[
                      { icon:'📶', label:'Network',  val: plan.network ?? '—' },
                      { icon:'⚡', label:'Speed',    val: plan.speed ?? '4G LTE/5G' },
                      { icon:'🔄', label:'Type',     val: 'Data Only' },
                      { icon:'🌍', label:'Coverage', val: group.count > 0 ? `${group.count} Countries` : `${countryName} Region` },
                    ].map(row => (
                      <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:0.78rem;color:#9ca3af;display:flex;align-items:center;gap:0.3rem;">{row.icon} {row.label}</span>
                        <span style="font-size:0.78rem;font-weight:600;color:#374151;text-align:right;max-width:55%;">{row.val}</span>
                      </div>
                    ))}
                  </div>
                  <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;">
                    <div>
                      <p style="font-size:1.6rem;font-weight:900;color:#162544;margin:0;line-height:1;">${plan.price_usd}</p>
                      {plan.price_regular > plan.price_usd && (
                        <p style="font-size:0.75rem;color:#9ca3af;margin:0.1rem 0 0;text-decoration:line-through;">${plan.price_regular}</p>
                      )}
                    </div>
                    <button class="add-to-cart btn-primary" style="font-size:0.82rem;padding:0.6rem 1rem;flex-shrink:0;"
                      data-plan={JSON.stringify({
                        id: plan.id, system_id: plan.system_id,
                        topup_id: plan.topup_id ?? null,
                        name: plan.name ?? countryName + ' eSIM',
                        country: plan.country ?? countryName,
                        flag: plan.flag ?? flagUrl,
                        quota: plan.quota, valadity: plan.valadity,
                        price_usd: plan.price_usd, price: plan.price_usd,
                        quantity: 1,
                      })}>
                      Buy Now
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;" id="plansGrid">
        {plans.map((plan: any) => (
          <div class="plan-card"
