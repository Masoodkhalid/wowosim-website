<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${countryName} eSIM`,
  "description": `eSIM data plans for ${countryName}. Instant activation, no contracts.`,
  "brand": { "@type": "Brand", "name": "WoWo SIM" },
  "offers": plans.map((p:any) => ({
    "@type": "Offer",
    "name": p.name,
    "price": p.price_usd,
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
  })),
})} />

<script>
  // ── Topup mode: detect ?iccid= in URL ──
  const _urlParams  = new URLSearchParams(window.location.search);
  const _topupIccid = _urlParams.get('iccid') ?? '';

  if (_topupIccid) {
    // Show topup banner above the plans section
    const banner = document.createElement('div');
    banner.id = 'topupBanner';
    banner.innerHTML = `
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
        <span style="font-size:1.25rem;">➕</span>
        <div>
          <p style="margin:0;font-size:0.9rem;font-weight:800;color:#162544;">Adding Top-Up Data</p>
          <p style="margin:0;font-size:0.78rem;color:#6b7280;">Select a plan below to add more data to eSIM <strong style="color:#162544;font-family:monospace;">${_topupIccid}</strong></p>
        </div>
        <a href="/dashboard/esim/${_topupIccid}" style="margin-left:auto;font-size:0.75rem;color:#9ca3af;text-decoration:none;" onmouseover="this.style.color='#162544'" onmouseout="this.style.color='#9ca3af'">← Back to eSIM</a>
      </div>`;
    banner.style.cssText = 'background:#f0fdf9;border:2px solid #03def3;border-radius:1rem;padding:1rem 1.25rem;margin-bottom:1.5rem;max-width:72rem;margin-left:auto;margin-right:auto;';
    // Insert before the first plans section
    const plansSection = document.querySelector('#plansGrid, [id^="tier-"]');
    if (plansSection) {
      plansSection.closest('section')?.insertBefore(banner, plansSection.closest('section')?.firstChild ?? null);
    }
  }

  // Add to cart
  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', () => {
      const plan = JSON.parse((btn as HTMLElement).dataset.plan ?? '{}');

      // ── If topup mode: use topup_id and inject iccid ──
      if (_topupIccid && plan.topup_id) {
        plan.topup_id = plan.topup_id;  // already set
        plan.iccid    = _topupIccid;    // which eSIM to top up
        plan.is_topup = true;
        // Name it clearly in cart
        plan.name = plan.name + ' (Top-Up)';
      }

      let cart: any[] = [];
      try {
        const raw = document.cookie.match(/wordpress_cart=([^;]+)/)?.[1];
        if (raw) cart = JSON.parse(decodeURIComponent(raw));
      } catch {}
      // Dedup: topup plans keyed by topup_id+iccid, regular plans by id
      const cartKey = plan.is_topup ? `topup_${plan.topup_id}_${plan.iccid}` : plan.id;
      const exists = cart.findIndex((i:any) => {
        const k = i.is_topup ? `topup_${i.topup_id}_${i.iccid}` : i.id;
        return k === cartKey;
      });
      if (exists >= 0) cart[exists].quantity = (cart[exists].quantity ?? 1) + 1;
      else cart.push(plan);
      document.cookie = `wordpress_cart=${encodeURIComponent(JSON.stringify(cart))};path=/;max-age=86400`;

      const el = btn as HTMLElement;
      const orig = el.textContent;
      el.textContent = '✓ Added!';
      el.style.background = '#dcfce7'; el.style.color = '#15803d';
      setTimeout(() => { el.textContent = orig ?? 'Buy Now'; el.style.background = ''; el.style.color = ''; }, 1500);

      const countEl = document.getElementById('cartCount');
      if (countEl) {
        const c = parseInt(countEl.textContent ?? '0') + 1;
        countEl.textContent = String(c);
        countEl.style.display = 'flex';
      }

      // Open cart drawer
      const overlay = document.getElementById('cartOverlay');
      const drawer = document.getElementById('cartDrawer');
      if (overlay) { overlay.style.display = 'block'; overlay.classList.add('open'); }
      if (drawer) drawer.classList.add('open');
      document.body.style.overflow = 'hidden';
      if (typeof (window as any).renderCartDrawer === 'function') (window as any).renderCartDrawer();
    });
  });

  // Sort plans
  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sort-btn').forEach((b:any) => {
        b.style.background = 'white'; b.style.color = '#6b7280'; b.style.borderColor = '#e5e7eb';
      });
      (btn as HTMLElement).style.background = '#03def3';
      (btn as HTMLElement).style.color = '#162544';
      (btn as HTMLElement).style.borderColor = '#03def3';
      const sort = (btn as HTMLElement).dataset.sort;
      const grid = document.getElementById('plansGrid');
      if (!grid) return;
      const cards = Array.from(grid.querySelectorAll('.plan-card'));
      cards.sort((a:any, b:any) => {
        if (sort === 'data')     return parseFloat(b.dataset.quota) - parseFloat(a.dataset.quota);
        if (sort === 'price')    return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
        if (sort === 'duration') return parseFloat(b.dataset.days) - parseFloat(a.dataset.days);
        return 0;
      });
      cards.forEach(c => grid.appendChild(c));
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const body = item.querySelector('.faq-body') as HTMLElement;
      const arrow = item.querySelector('.faq-arrow') as HTMLElement;
      const isOpen = body.style.display === 'block';
      document.querySelectorAll('.faq-body').forEach((b:any) => b.style.display = 'none');
      document.querySelectorAll('.faq-arrow').forEach((a:any) => { a.textContent = '+'; a.style.transform = ''; });
      if (!isOpen) { body.style.display = 'block'; arrow.textContent = '×'; arrow.style.transform = 'rotate(45deg)'; }
    });
  });

  // Compatible devices tabs
  document.querySelectorAll('.compat-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target;
      document.querySelectorAll('.compat-tab-btn').forEach((b:any) => {
        b.style.background = 'white'; b.style.color = '#6b7280'; b.style.borderColor = '#e5e7eb';
      });
      (btn as HTMLElement).style.background = '#03def3';
      (btn as HTMLElement).style.color = '#162544';
      (btn as HTMLElement).style.borderColor = '#03def3';
      document.querySelectorAll('.compat-content').forEach((c:any) => c.style.display = 'none');
      const el = document.getElementById(target ?? '');
      if (el) el.style.display = 'block';
    });
  });
</script>

<style>
  .step-item:hover .step-icon { background:#03def3; transform:scale(1.1); }
  .plan-card:hover { transform:translateY(-3px); box-shadow:0 12px 35px rgba(0,0,0,0.1) !important; }
  @media (max-width:768px) {
    section > div { padding: 0 !important; }
    [style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; }
    [style*="grid-template-columns:1fr auto"] { grid-template-columns: 1fr !important; }
    [style*="font-size:2.5rem"][style*="font-weight:900"] { font-size:1.75rem !important; }
  }
</style>
