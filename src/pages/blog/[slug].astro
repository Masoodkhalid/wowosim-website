      <span style="display:inline-block;background:rgba(3,222,243,0.15);border:1px solid rgba(3,222,243,0.3);color:#03def3;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:0.3rem 0.9rem;border-radius:9999px;margin-bottom:1rem;">{post.category}</span>
