const post = posts[slug ?? ''];
if (!post) return Astro.redirect('/blog');

const relatedPosts = (post.related ?? []).map((s: string) => posts[s]).filter(Boolean);
---

<Base title={`${post.title} | WoWo SIM Blog`} description={post.desc}>

  <!-- Hero -->
  <div style="background:linear-gradient(135deg,#0f1f3d,#162544,#1a2d50);padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.06) 1px,transparent 1px);background-size:24px 24px;pointer-events:none;"></div>
    <div style="position:absolute;top:-80px;right:-80px;width:320px;height:320px;background:rgba(3,222,243,0.05);border-radius:50%;filter:blur(60px);pointer-events:none;"></div>
