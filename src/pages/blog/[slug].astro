      <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;font-size:0.78rem;color:#9ca3af;flex-wrap:wrap;">
        <span style="display:flex;align-items:center;gap:0.3rem;">📅 {post.date}</span>
        <span style="width:3px;height:3px;background:#4b5563;border-radius:50%;"></span>
        <span style="display:flex;align-items:center;gap:0.3rem;">⏱️ {post.readTime}</span>
      </div>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div style="background:white;border-bottom:1px solid #f3f4f6;padding:0.6rem 1.5rem;">
    <div style="max-width:980px;margin:0 auto;display:flex;align-items:center;gap:0.5rem;font-size:0.73rem;color:#9ca3af;">
      <a href="/" style="color:#9ca3af;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">Home</a>
      <span>›</span>
      <a href="/blog" style="color:#9ca3af;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">Blog</a>
      <span>›</span>
      <span style="color:#374151;font-weight:500;">{post.title.slice(0, 50)}{post.title.length > 50 ? '…' : ''}</span>
    </div>
  </div>

  <!-- 2-column layout wrapper -->
  <div style="background:#f9fafb;min-height:60vh;">
    <div id="blog-layout" style="max-width:980px;margin:0 auto;padding:2.5rem 1.5rem;display:grid;grid-template-columns:240px 1fr;gap:2.5rem;align-items:start;">

      <!-- TOC Sidebar -->
      <aside id="toc-sidebar" style="position:sticky;top:1.5rem;">
        <div style="background:white;border:1.5px solid #f0f0f0;border-radius:1.25rem;padding:1.25rem;box-shadow:0 1px 6px rgba(0,0,0,0.05);">
          <p style="font-size:0.7rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#9ca3af;margin:0 0 0.875rem;">Contents</p>
          <nav id="toc-nav">
            {post.sections.map((section: any, idx: number) => (
              <a href={`#section-${idx}`} class="toc-link" data-idx={idx}
                 style="display:block;font-size:0.78rem;font-weight:500;color:#6b7280;text-decoration:none;padding:0.35rem 0.6rem;border-radius:0.5rem;margin-bottom:0.1rem;border-left:2px solid transparent;transition:all 0.2s;line-height:1.4;">
                {section.h}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <!-- Article content -->
      <article>

        <!-- Lead / desc -->
        <p style="font-size:1.05rem;color:#374151;line-height:1.85;margin:0 0 2.5rem;font-weight:400;padding-bottom:2rem;border-bottom:2px solid #f3f4f6;">{post.desc}</p>

        <!-- Sections -->
        {post.sections.map((section: any, idx: number) => (
          <section id={`section-${idx}`} style="margin-bottom:2.75rem;scroll-margin-top:1.5rem;">
            <h2 style="font-size:1.3rem;font-weight:800;color:#162544;margin:0 0 1.1rem;letter-spacing:-0.3px;padding-bottom:0.6rem;border-bottom:2px solid #f3f4f6;display:flex;align-items:center;gap:0.5rem;">
              <span style="display:inline-block;width:4px;height:1.2em;background:linear-gradient(180deg,#03def3,#0bafc0);border-radius:2px;flex-shrink:0;"></span>
              {section.h}
            </h2>
            <div class="prose-body" set:html={(() => {
              const text: string = section.body;
              if (!text) return '';
              const lines = text.split('\n');
              let html = '';
              let inUl = false;
              let inOl = false;

              const formatInline = (t: string) =>
                t.replace(/\*\*(.+?)\*\*/g, '<strong style="font-weight:700;color:#162544;">$1</strong>');

              const closeLists = () => {
                if (inUl) { html += '</ul>'; inUl = false; }
                if (inOl) { html += '</ol>'; inOl = false; }
              };

              for (const line of lines) {
                if (line.trim() === '') {
                  closeLists();
                  continue;
                }
                const numMatch = line.match(/^(\d+)\.\s+(.+)/);
                if (numMatch) {
                  if (inUl) { html += '</ul>'; inUl = false; }
                  if (!inOl) { html += '<ol style="margin:0.75rem 0 1.1rem 1.5rem;display:flex;flex-direction:column;gap:0.4rem;">'; inOl = true; }
                  html += `<li style="font-size:0.95rem;color:#374151;line-height:1.75;">${formatInline(numMatch[2])}</li>`;
                  continue;
                }
                if (line.match(/^[•*]\s/)) {
                  if (inOl) { html += '</ol>'; inOl = false; }
                  if (!inUl) { html += '<ul style="margin:0.75rem 0 1.1rem 1.5rem;display:flex;flex-direction:column;gap:0.4rem;list-style:disc;">'; inUl = true; }
                  const content = line.replace(/^[•*]\s+/, '');
                  html += `<li style="font-size:0.95rem;color:#374151;line-height:1.75;">${formatInline(content)}</li>`;
                  continue;
                }
                closeLists();
                html += `<p style="margin:0 0 1rem;font-size:0.95rem;color:#374151;line-height:1.8;">${formatInline(line)}</p>`;
              }
              closeLists();
              return html;
            })()} />
          </section>
        ))}

        <!-- CTA box -->
        <div style="background:linear-gradient(135deg,#0f1f3d,#162544);border-radius:1.5rem;padding:2.5rem 2rem;margin:3rem 0;text-align:center;position:relative;overflow:hidden;">
          <div style="position:absolute;top:-40px;right:-40px;width:180px;height:180px;background:rgba(3,222,243,0.07);border-radius:50%;filter:blur(30px);pointer-events:none;"></div>
          <div style="font-size:2rem;margin-bottom:0.75rem;">📶</div>
          <h2 style="font-size:1.4rem;font-weight:800;color:white;margin:0 0 0.6rem;">Ready to travel connected?</h2>
          <p style="color:#9ca3af;font-size:0.875rem;margin:0 0 1.75rem;line-height:1.6;">Get instant eSIM data from $3.50. Instant QR code delivery. No contracts.</p>
          <a href={post.cta_dest} class="btn-primary" style="font-size:0.9rem;padding:0.85rem 2rem;">{post.cta_text} →</a>
        </div>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <div style="margin-bottom:2rem;">
            <h3 style="font-size:0.85rem;font-weight:800;color:#162544;margin:0 0 1.25rem;text-transform:uppercase;letter-spacing:0.08em;">Related Articles</h3>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;">
              {relatedPosts.map((rp: any) => (
                <a href={`/blog/${post.related[relatedPosts.indexOf(rp)]}`}
                   style="background:white;border-radius:1.1rem;padding:1.25rem;text-decoration:none;border:1.5px solid #f0f0f0;transition:all 0.2s;display:flex;flex-direction:column;gap:0.4rem;box-shadow:0 1px 4px rgba(0,0,0,0.04);"
                   onmouseover="this.style.borderColor='#03def3';this.style.background='#f0fdff';this.style.boxShadow='0 6px 20px rgba(3,222,243,0.12)'" onmouseout="this.style.borderColor='#f0f0f0';this.style.background='white';this.style.boxShadow='0 1px 4px rgba(0,0,0,0.04)'">
                  <span style="font-size:1.75rem;line-height:1;">{rp.emoji}</span>
                  <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#03def3;letter-spacing:0.06em;">{rp.category}</span>
                  <span style="font-size:0.85rem;font-weight:600;color:#162544;line-height:1.4;">{rp.title}</span>
                  <span style="font-size:0.75rem;color:#9ca3af;margin-top:auto;">{rp.date}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Back to blog -->
        <div style="padding-top:1.5rem;border-top:1px solid #f3f4f6;">
          <a href="/blog" style="display:inline-flex;align-items:center;gap:0.4rem;color:#9ca3af;font-size:0.8rem;font-weight:500;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#162544'" onmouseout="this.style.color='#9ca3af'">
            ← Back to Blog
          </a>
        </div>

      </article>
    </div>
  </div>

</Base>

