<script>
  // IntersectionObserver for TOC active highlighting
  const tocLinks = Array.from(document.querySelectorAll('.toc-link')) as HTMLAnchorElement[];
  const sections = tocLinks.map(l => document.getElementById(l.dataset.idx !== undefined ? `section-${l.dataset.idx}` : '')).filter(Boolean) as HTMLElement[];

  if (sections.length > 0 && 'IntersectionObserver' in window) {
    let activeIdx = 0;

    const setActive = (idx: number) => {
      tocLinks.forEach((l, i) => l.classList.toggle('active', i === idx));
      activeIdx = idx;
    };

    setActive(0);

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const idx = sections.indexOf(entry.target as HTMLElement);
          if (idx !== -1) setActive(idx);
        }
      }
    }, { rootMargin: '-20% 0px -60% 0px', threshold: 0 });

    sections.forEach(s => observer.observe(s));
  } else {
    // Fallback: highlight first link
    if (tocLinks.length > 0) tocLinks[0].classList.add('active');
  }
</script>
