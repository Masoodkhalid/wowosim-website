---
import Base from '../../layouts/Base.astro';

const categories = ['All', 'Travel Tips', 'Informative', 'Featured'];

const posts = [
  { title: 'Best eSIM for Europe 2026: Compare Prices, Coverage & Plans', category: 'Featured', date: 'Apr 14, 2026', slug: 'best-esim-europe-2026', emoji: '🇪🇺', desc: 'Find the best eSIM for your European trip with our detailed comparison of plans, prices and coverage across 30+ countries.' },
  { title: 'China Festivals April & May 2026: Celebrations, Culture & Top Visiting Countries', category: 'Travel Tips', date: 'Apr 14, 2026', slug: 'china-festivals-april-may-2026', emoji: '🇨🇳', desc: 'Discover the biggest spring festivals in China and how to stay connected during your visit to this incredible destination.' },
  { title: 'Japan Visa for Americans: Do You Need One? 2026 Entry Guide', category: 'Travel Tips', date: 'Apr 13, 2026', slug: 'japan-visa-americans-2026', emoji: '🇯🇵', desc: 'Complete guide to Japan entry requirements for US citizens in 2026 including visa-free travel rules and connectivity tips.' },
  { title: 'Morocco Visa for Europeans: Do You Need One? 2026 Entry Guide', category: 'Travel Tips', date: 'Apr 8, 2026', slug: 'morocco-visa-europeans-2026', emoji: '🇲🇦', desc: 'Everything European travelers need to know about visiting Morocco in 2026 — entry rules, visa requirements, and how to stay connected.' },
  { title: 'Indonesia Visa for Australians: Do You Need One? 2026 Entry Guide', category: 'Informative', date: 'Apr 7, 2026', slug: 'indonesia-visa-australians-2026', emoji: '🇮🇩', desc: 'Complete guide for Australian travelers planning a trip to Indonesia in 2026, including Bali visa-on-arrival rules.' },
  { title: 'China Visa Requirements for European Citizens: Complete 2026 Entry Guide', category: 'Informative', date: 'Apr 6, 2026', slug: 'china-visa-europeans-2026', emoji: '🇨🇳', desc: 'Detailed visa requirements, application process, and connectivity guide for European citizens visiting China in 2026.' },
  { title: 'How to Make a Travel Itinerary: A Step-by-Step Guide for Smarter Trips', category: 'Travel Tips', date: 'Mar 27, 2026', slug: 'how-to-make-travel-itinerary', emoji: '📋', desc: 'Step-by-step guide to planning the perfect travel itinerary for any destination, including staying connected on the road.' },
  { title: 'Esports Gaming Without Limits: How Global Connectivity Powers Competitive Players', category: 'Informative', date: 'Mar 26, 2026', slug: 'esports-gaming-global-connectivity', emoji: '🎮', desc: 'How eSIM technology is revolutionizing connectivity for competitive gamers who travel internationally for tournaments.' },
  { title: 'Best eSIM for Turkey 2026: Cheap Plans That Actually Work', category: 'Travel Tips', date: 'Mar 25, 2026', slug: 'best-esim-turkey-2026', emoji: '🇹🇷', desc: 'Honest review of the best eSIM options for Turkey in 2026. Compare prices, coverage, and find the cheapest plan that works.' },
  { title: 'Internet in Thailand for Travelers (2026): Your Complete Connectivity Guide', category: 'Travel Tips', date: 'Mar 9, 2026', slug: 'internet-thailand-travelers-2026', emoji: '🇹🇭', desc: 'Everything you need to know about staying connected in Thailand in 2026 — eSIM vs local SIM, 5G coverage, and top tips.' },
  { title: 'Global Connectivity for Digital Nomads: The Complete 2026 Guide', category: 'Informative', date: 'Mar 9, 2026', slug: 'global-connectivity-digital-nomads-2026', emoji: '💻', desc: 'The complete guide to staying connected as a digital nomad in 2026. eSIM, VPNs, co-working spaces, and productivity tools.' },
  { title: 'What is an eSIM and How Does It Work?', category: 'Informative', date: 'Mar 9, 2026', slug: 'what-is-esim-how-does-it-work', emoji: '📱', desc: 'A complete beginner\'s guide to understanding eSIM technology — what it is, how to install one, and why travelers love it.' },
  { title: 'Best eSIM for International Travel in 2026 – Complete Guide for Travelers', category: 'Featured', date: 'Mar 9, 2026', slug: 'best-esim-international-travel-2026', emoji: '✈️', desc: 'Our comprehensive comparison of the best eSIM providers for international travel in 2026. Prices, coverage, and honest reviews.' },
];
---

<Base title="Blog — Travel Tips & eSIM Guides | WoWo SIM" description="Travel tips, eSIM guides, visa information, and destination guides from the WoWo SIM blog.">

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#162544,#0d1b36);padding:4rem 2rem;text-align:center;">
    <div style="max-width:560px;margin:0 auto;">
      <span style="color:#03def3;font-weight:600;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:0.75rem;">Blog</span>
      <h1 style="font-size:2.5rem;font-weight:900;color:white;margin:0 0 0.75rem;letter-spacing:-0.5px;">Travel Tips & eSIM Guides</h1>
      <p style="color:#9ca3af;font-size:0.95rem;margin:0;">Destination guides, visa information, travel advice, and everything you need to stay connected.</p>
    </div>
  </section>

  <!-- Category filters -->
  <section style="padding:1.5rem 2rem;background:white;border-bottom:1px solid #f3f4f6;position:sticky;top:64px;z-index:40;">
    <div style="max-width:80rem;margin:0 auto;display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
      {categories.map((cat, i) => (
        <button class="cat-btn" data-cat={cat}
          style={`padding:0.4rem 1rem;border-radius:9999px;font-size:0.8rem;font-weight:600;cursor:pointer;transition:all 0.2s;border:1.5px solid ${i===0?'#03def3':'#e5e7eb'};background:${i===0?'#03def3':'white'};color:${i===0?'#162544':'#6b7280'};`}>
          {cat}
        </button>
      ))}
      <span style="margin-left:auto;font-size:0.78rem;color:#9ca3af;" id="postCount">{posts.length} posts</span>
    </div>
  </section>

  <!-- Posts Grid -->
  <section style="padding:3rem 2rem;background:#f9fafb;">
    <div style="max-width:80rem;margin:0 auto;">
      <div id="postsGrid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;"></div>
    </div>
  </section>

</Base>

<script define:vars={{ posts }}>
  function renderPosts(filter) {
    const grid = document.getElementById('postsGrid');
    const countEl = document.getElementById('postCount');
    const filtered = filter === 'All' ? posts : posts.filter(p => p.category === filter);
    if (countEl) countEl.textContent = filtered.length + ' posts';
    if (filtered.length === 0) {
      grid.innerHTML = '<p style="text-align:center;padding:3rem;color:#9ca3af;grid-column:1/-1;">No posts in this category yet.</p>';
      return;
    }
    grid.innerHTML = filtered.map(p => `
      <a href="/blog/${p.slug}" style="background:white;border-radius:1.25rem;overflow:hidden;border:1.5px solid #f0f0f0;text-decoration:none;display:flex;flex-direction:column;transition:all 0.25s;box-shadow:0 1px 4px rgba(0,0,0,0.05);"
         onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,0.1)';this.style.transform='translateY(-3px)';this.style.borderColor='#e5e7eb'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,0.05)';this.style.transform='';this.style.borderColor='#f0f0f0'">
        <div style="background:linear-gradient(135deg,#f0fdff,#e0f9ff);padding:2.5rem;text-align:center;font-size:3rem;">${p.emoji}</div>
        <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;">
          <span style="font-size:0.7rem;font-weight:700;text-transform:uppercase;color:#03def3;letter-spacing:0.05em;margin-bottom:0.5rem;display:block;">${p.category}</span>
          <h2 style="font-size:0.95rem;font-weight:700;color:#162544;margin:0 0 0.6rem;line-height:1.4;">${p.title}</h2>
          <p style="font-size:0.82rem;color:#9ca3af;line-height:1.5;margin:0 0 1rem;flex:1;">${p.desc}</p>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:0.75rem;color:#9ca3af;">${p.date}</span>
            <span style="font-size:0.75rem;color:#03def3;font-weight:600;">Read more →</span>
          </div>
        </div>
      </a>
    `).join('');
  }

  renderPosts('All');

  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => {
        b.style.background = 'white'; b.style.color = '#6b7280'; b.style.borderColor = '#e5e7eb';
      });
      btn.style.background = '#03def3';
      btn.style.color = '#162544';
      btn.style.borderColor = '#03def3';
      renderPosts(btn.dataset.cat ?? 'All');
    });
  });
</script>

<style>
  @media (max-width: 900px) { #postsGrid { grid-template-columns: repeat(2,1fr) !important; } }
  @media (max-width: 600px) { #postsGrid { grid-template-columns: 1fr !important; } }
</style>
