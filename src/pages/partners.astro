---
import Base from '../layouts/Base.astro';
---
<Base title="Partner with WoWo SIM">
  <section style="padding: 5rem 2rem; background: linear-gradient(135deg, #f0fdff, white);">
    <div style="max-width: 72rem; margin: 0 auto; text-align: center; margin-bottom: 4rem;">
      <span style="color: #03def3; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em;">Partner Program</span>
      <h1 style="font-size: 3rem; font-weight: 900; color: #162544; margin: 0.5rem 0 1rem; letter-spacing: -0.5px;">Grow Your Business<br/>with WoWo SIM</h1>
      <p style="color: #6b7280; font-size: 1rem; max-width: 520px; margin: 0 auto 2rem;">Join the eSIM revolution. Earn passive income with zero investment. 500+ partners already onboard.</p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="#apply" class="btn-primary" style="font-size: 1rem; padding: 1rem 2rem;">Start Partnership</a>
        <a href="/contact" class="btn-outline" style="font-size: 1rem; padding: 1rem 2rem;">Contact Sales</a>
      </div>
    </div>

    <!-- Stats -->
    <div style="max-width: 72rem; margin: 0 auto 4rem; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
      {[
        { n: '195+', l: 'Countries' }, { n: '500+', l: 'Partners' },
        { n: '95%', l: 'Satisfaction' }, { n: '$500K+', l: 'Earnings Paid' },
      ].map(s => (
        <div class="card" style="text-align: center;">
          <p style="font-size: 2rem; font-weight: 900; color: #162544; margin: 0 0 0.25rem;">{s.n}</p>
          <p style="color: #9ca3af; font-size: 0.85rem; margin: 0;">{s.l}</p>
        </div>
      ))}
    </div>

    <!-- Tiers -->
    <div style="max-width: 72rem; margin: 0 auto 4rem;">
      <h2 style="font-size: 1.75rem; font-weight: 800; color: #162544; text-align: center; margin: 0 0 2rem;">Commission Tiers</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
        {[
          { tier: 'Starter', rate: '$1.00', vol: '100 eSIMs/mo', earn: '$100', color: '#f3f4f6' },
          { tier: 'Growth',  rate: '$1.25', vol: '500 eSIMs/mo', earn: '$625', color: '#f0fdff', featured: true },
          { tier: 'Premium', rate: '$1.75', vol: '1000+ eSIMs/mo', earn: '$1,750+', color: '#f3f4f6' },
        ].map(t => (
          <div class="card" style={`text-align: center; background: ${t.featured ? 'linear-gradient(135deg, #f0fdff, white)' : 'white'}; ${t.featured ? 'border: 2px solid #03def3;' : ''}`}>
            <p style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #9ca3af; margin: 0 0 0.5rem;">{t.tier}</p>
            <p style="font-size: 2.5rem; font-weight: 900; color: #162544; margin: 0 0 0.25rem;">{t.rate}</p>
            <p style="color: #9ca3af; font-size: 0.8rem; margin: 0 0 1rem;">per activation</p>
            <p style="font-size: 0.85rem; color: #374151; margin: 0 0 0.25rem;">{t.vol}</p>
            <p style="font-size: 0.85rem; font-weight: 600; color: #03def3;">Up to {t.earn}/month</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Form -->
    <div id="apply" style="max-width: 560px; margin: 0 auto;">
      <div class="card" style="padding: 2.5rem;">
        <h2 style="font-size: 1.5rem; font-weight: 800; color: #162544; margin: 0 0 0.5rem; text-align: center;">Apply Now</h2>
        <p style="color: #9ca3af; font-size: 0.875rem; text-align: center; margin: 0 0 2rem;">We'll review and get back to you within 24 hours.</p>
        <form id="partnerForm" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Full Name *</label>
              <input type="text" id="pName" required placeholder="John Doe" style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Email *</label>
              <input type="email" id="pEmail" required placeholder="you@company.com" style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Phone</label>
              <input type="tel" id="pPhone" placeholder="+1 555 000 0000" style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Business Type *</label>
              <input type="text" id="pBusiness" required placeholder="Travel Agency, Blog..." style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Message</label>
            <textarea id="pMessage" rows="3" placeholder="Tell us about your audience..." style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none; resize: vertical;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'"></textarea>
          </div>
          <button type="submit" id="partnerBtn" class="btn-primary" style="width: 100%; justify-content: center; font-size: 0.95rem; padding: 0.9rem;">Submit Application</button>
          <div id="partnerMsg" style="display: none; font-size: 0.8rem; padding: 0.75rem; border-radius: 0.65rem; text-align: center;"></div>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  document.getElementById('partnerForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('partnerBtn') as HTMLButtonElement;
    const msg = document.getElementById('partnerMsg') as HTMLElement;
    btn.textContent = 'Submitting...'; btn.disabled = true;
    try {
      const res = await fetch('/api/partner-form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (document.getElementById('pName') as HTMLInputElement).value,
          email: (document.getElementById('pEmail') as HTMLInputElement).value,
          phone: (document.getElementById('pPhone') as HTMLInputElement).value,
          business: (document.getElementById('pBusiness') as HTMLInputElement).value,
          message: (document.getElementById('pMessage') as HTMLTextAreaElement).value,
        }),
      });
      const data = await res.json();
      msg.style.display = 'block';
      if (data.success) { msg.style.background = '#dcfce7'; msg.style.color = '#15803d'; msg.textContent = data.message; (e.target as HTMLFormElement).reset(); }
      else { msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = data.message ?? 'Error. Please try again.'; }
    } catch { msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = 'Network error.'; }
    finally { btn.textContent = 'Submit Application'; btn.disabled = false; }
  });
</script>
