  @media (max-width:600px) { #categoriesGrid { grid-template-columns: 1fr !important; } #devicesGrid { grid-template-columns: 1fr !important; } }
  @media (max-width:768px) { [style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; } }
</style>
