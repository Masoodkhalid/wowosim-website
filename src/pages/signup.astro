---
import Base from '../layouts/Base.astro';
import { isLoggedIn } from '../lib/auth';
if (isLoggedIn(Astro.cookies)) return Astro.redirect('/dashboard');
---

<Base title="Create Account" description="Create your free WoWo SIM account and start your connected travels today.">
  <section style="min-height:calc(100vh - 140px);display:flex;align-items:center;justify-content:center;padding:3rem 1rem;background:linear-gradient(150deg,#ffffff 0%,#f0fdff 50%,#e0f9ff 100%);">
    <div style="width:100%;max-width:460px;">

      <!-- Logo top -->
      <div style="text-align:center;margin-bottom:2rem;">
        <a href="/" style="font-size:1.75rem;font-weight:900;color:#162544;text-decoration:none;letter-spacing:-1px;">
          WoWo<span style="color:#03def3;">SIM</span>
        </a>
      </div>

      <div class="card" style="padding:2.5rem;">
        <div style="text-align:center;margin-bottom:2rem;">
          <div style="width:64px;height:64px;background:linear-gradient(135deg,#03def3,#0ea5e9);border-radius:1.25rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <svg width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <h1 style="font-size:1.5rem;font-weight:900;color:#162544;margin:0 0 0.35rem;letter-spacing:-0.5px;">Create your account</h1>
          <p style="color:#9ca3af;font-size:0.875rem;margin:0;">Start connecting in minutes. It's free.</p>
        </div>

        <form id="signupForm" style="display:flex;flex-direction:column;gap:1rem;" novalidate>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
            <div>
              <label class="form-label" for="firstName">First name</label>
              <input type="text" id="firstName" name="firstName" required placeholder="John" autocomplete="given-name"
                class="form-input" />
            </div>
            <div>
              <label class="form-label" for="lastName">Last name</label>
              <input type="text" id="lastName" name="lastName" required placeholder="Doe" autocomplete="family-name"
                class="form-input" />
            </div>
          </div>

          <div>
            <label class="form-label" for="email">Email address</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email"
              class="form-input" />
          </div>

          <div>
            <label class="form-label" for="password">Password</label>
            <div style="position:relative;">
              <input type="password" id="password" name="password" required placeholder="Min. 8 characters" autocomplete="new-password"
                class="form-input" style="padding-right:2.75rem;" />
              <button type="button" id="togglePw"
                style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;padding:0.2rem;display:flex;align-items:center;"
                aria-label="Toggle password visibility">
                <svg id="eyeOpen" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              </button>
            </div>
            <!-- Password strength indicator -->
            <div id="pwStrength" style="margin-top:0.4rem;display:none;">
              <div style="height:3px;background:#f3f4f6;border-radius:9999px;overflow:hidden;">
                <div id="pwStrengthBar" style="height:100%;width:0%;border-radius:9999px;transition:all 0.3s;background:#ef4444;"></div>
              </div>
              <p id="pwStrengthLabel" style="font-size:0.7rem;color:#9ca3af;margin:0.25rem 0 0;"></p>
            </div>
          </div>

          <div>
            <label class="form-label" for="passwordConfirm">Confirm password</label>
            <input type="password" id="passwordConfirm" name="passwordConfirm" required placeholder="Repeat your password" autocomplete="new-password"
              class="form-input" />
          </div>

          <!-- Terms -->
          <label style="display:flex;align-items:flex-start;gap:0.6rem;font-size:0.8rem;color:#6b7280;cursor:pointer;user-select:none;">
            <input type="checkbox" id="agreeTerms" name="agreeTerms" required
              style="width:16px;height:16px;accent-color:#03def3;flex-shrink:0;margin-top:0.1rem;" />
            <span>
              I agree to the
              <a href="/terms" style="color:#162544;font-weight:600;text-decoration:none;" target="_blank">Terms of Service</a>
              and
              <a href="/privacy-policy" style="color:#162544;font-weight:600;text-decoration:none;" target="_blank">Privacy Policy</a>
            </span>
          </label>

          <button type="submit" id="signupBtn" class="btn-primary"
            style="width:100%;justify-content:center;font-size:0.95rem;padding:0.9rem;border-radius:0.875rem;margin-top:0.25rem;">
            <svg id="signupSpinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none;animation:spin 0.8s linear infinite;">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
            Create Free Account
          </button>

          <div id="signupError"   class="alert-error"   style="display:none;text-align:center;"></div>
          <div id="signupSuccess" class="alert-success" style="display:none;text-align:center;"></div>
        </form>

        <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:#9ca3af;">
          Already have an account?
          <a href="/login" style="color:#162544;font-weight:700;text-decoration:none;margin-left:0.3rem;"
             onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#162544'">
            Sign in →
          </a>
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
  // Password visibility toggle
  const togglePw = document.getElementById('togglePw') as HTMLButtonElement;
  const pwInput  = document.getElementById('password') as HTMLInputElement;
  const eyeOpen  = document.getElementById('eyeOpen') as HTMLElement;
  togglePw?.addEventListener('click', () => {
    const show = pwInput.type === 'password';
    pwInput.type = show ? 'text' : 'password';
    eyeOpen.style.opacity = show ? '0.5' : '1';
  });

  // Password strength
  const pwStrength      = document.getElementById('pwStrength') as HTMLElement;
  const pwStrengthBar   = document.getElementById('pwStrengthBar') as HTMLElement;
  const pwStrengthLabel = document.getElementById('pwStrengthLabel') as HTMLElement;

  pwInput?.addEventListener('input', () => {
    const val = pwInput.value;
    if (!val) { pwStrength.style.display = 'none'; return; }
    pwStrength.style.display = 'block';
    let score = 0;
    if (val.length >= 8) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
      { label: 'Too short',  color: '#ef4444', pct: '20%' },
      { label: 'Weak',       color: '#f97316', pct: '40%' },
      { label: 'Fair',       color: '#eab308', pct: '60%' },
      { label: 'Good',       color: '#22c55e', pct: '80%' },
      { label: 'Strong',     color: '#16a34a', pct: '100%' },
    ];
    const lvl = levels[Math.min(score, 4)];
    pwStrengthBar.style.width = lvl.pct;
    pwStrengthBar.style.background = lvl.color;
    pwStrengthLabel.textContent = lvl.label;
    pwStrengthLabel.style.color = lvl.color;
  });

  // Form submit
  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn     = document.getElementById('signupBtn') as HTMLButtonElement;
    const spinner = document.getElementById('signupSpinner') as HTMLElement;
    const err     = document.getElementById('signupError') as HTMLElement;
    const suc     = document.getElementById('signupSuccess') as HTMLElement;

    const firstName = (document.getElementById('firstName') as HTMLInputElement).value.trim();
    const lastName  = (document.getElementById('lastName') as HTMLInputElement).value.trim();
    const email     = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password  = (document.getElementById('password') as HTMLInputElement).value;
    const passwordConfirm = (document.getElementById('passwordConfirm') as HTMLInputElement).value;
    const agreeTerms = (document.getElementById('agreeTerms') as HTMLInputElement).checked;

    err.style.display = 'none';
    suc.style.display = 'none';

    if (!firstName || !lastName || !email || !password) {
      err.textContent = 'Please fill in all required fields.';
      err.style.display = 'block';
      return;
    }
    if (password.length < 8) {
      err.textContent = 'Password must be at least 8 characters.';
      err.style.display = 'block';
      return;
    }
    if (password !== passwordConfirm) {
      err.textContent = 'Passwords do not match.';
      err.style.display = 'block';
      return;
    }
    if (!agreeTerms) {
      err.textContent = 'Please accept the Terms of Service to continue.';
      err.style.display = 'block';
      return;
    }

    btn.disabled = true;
    spinner.style.display = 'inline-block';
    const btnText = btn.childNodes[btn.childNodes.length - 1] as Text;
    const origText = btnText.textContent ?? 'Create Free Account';
    btnText.textContent = ' Creating account...';

    try {
      const res = await fetch('/api/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user: { first_name: firstName, last_name: lastName, email, password } }),
      });
      const data = await res.json();
      if (data.success) {
        suc.textContent = '🎉 Account created! Please check your email to verify, then sign in.';
        suc.style.display = 'block';
        (document.getElementById('signupForm') as HTMLFormElement).reset();
        setTimeout(() => { window.location.href = '/login'; }, 3000);
      } else {
        err.textContent = data.message ?? 'Could not create account. Email may already be registered.';
        err.style.display = 'block';
      }
    } catch {
      err.textContent = 'Network error. Please check your connection and try again.';
      err.style.display = 'block';
    } finally {
      btn.disabled = false;
      spinner.style.display = 'none';
      btnText.textContent = origText;
    }
  });
</script>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
