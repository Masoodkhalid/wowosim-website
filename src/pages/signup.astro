---
import Base from '../layouts/Base.astro';
import { isLoggedIn } from '../lib/auth';
if (isLoggedIn(Astro.cookies)) return Astro.redirect('/dashboard');
---

<Base title="Create Account">
  <section style="min-height: calc(100vh - 140px); display: flex; align-items: center; justify-content: center; padding: 3rem 1rem; background: linear-gradient(135deg, #f0fdff, white);">
    <div style="width: 100%; max-width: 420px;">
      <div class="card" style="padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🚀</div>
          <h1 style="font-size: 1.5rem; font-weight: 800; color: #162544; margin: 0 0 0.4rem;">Create your account</h1>
          <p style="color: #9ca3af; font-size: 0.875rem; margin: 0;">Start connecting in minutes</p>
        </div>

        <form id="signupForm" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">First name</label>
              <input type="text" id="firstName" required placeholder="John"
                style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
                onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Last name</label>
              <input type="text" id="lastName" required placeholder="Doe"
                style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
                onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Email address</label>
            <input type="email" id="email" required placeholder="you@example.com"
              style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
              onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Password</label>
            <input type="password" id="password" required placeholder="Min 8 characters"
              style="width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 0.75rem; font-size: 0.875rem; outline: none; transition: border 0.2s;"
              onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
          </div>
          <button type="submit" id="signupBtn" class="btn-primary" style="width: 100%; justify-content: center; font-size: 0.95rem; padding: 0.9rem;">
            Create Account
          </button>
          <div id="signupError" style="display: none; background: #fee2e2; color: #dc2626; font-size: 0.8rem; padding: 0.75rem 1rem; border-radius: 0.75rem; text-align: center;"></div>
          <div id="signupSuccess" style="display: none; background: #dcfce7; color: #15803d; font-size: 0.8rem; padding: 0.75rem 1rem; border-radius: 0.75rem; text-align: center;"></div>
        </form>

        <p style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: #9ca3af;">
          Already have an account?
          <a href="/login" style="color: #162544; font-weight: 600; text-decoration: none; margin-left: 0.25rem;">Sign in →</a>
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('signupBtn') as HTMLButtonElement;
    const err = document.getElementById('signupError') as HTMLElement;
    const suc = document.getElementById('signupSuccess') as HTMLElement;

    btn.textContent = 'Creating account...';
    btn.disabled = true;
    err.style.display = 'none';
    suc.style.display = 'none';

    const firstName = (document.getElementById('firstName') as HTMLInputElement).value;
    const lastName = (document.getElementById('lastName') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user: { first_name: firstName, last_name: lastName, email, password } }),
      });
      const data = await res.json();
      if (data.success) {
        suc.textContent = 'Account created! Please check your email to verify.';
        suc.style.display = 'block';
        setTimeout(() => window.location.href = '/login', 2000);
      } else {
        err.textContent = data.message ?? 'Could not create account. Please try again.';
        err.style.display = 'block';
      }
    } catch {
      err.textContent = 'Network error. Please try again.';
      err.style.display = 'block';
    } finally {
      btn.textContent = 'Create Account';
      btn.disabled = false;
    }
  });
</script>
