---
import Base from '../../layouts/Base.astro';
import { getJwt, isLoggedIn } from '../../lib/auth';
import { portalFetch } from '../../lib/api';

if (!isLoggedIn(Astro.cookies)) return Astro.redirect('/login?next=/dashboard');

const jwt = getJwt(Astro.cookies);
let user: any = null;
let esimCount = 0;

try {
  const [meRes, esimsRes] = await Promise.all([
    portalFetch('/me', {}, jwt),
    portalFetch('/esims', {}, jwt),
  ]);
  if (meRes.ok) user = await meRes.json();
  if (esimsRes.ok) {
    const d = await esimsRes.json();
    const esims = d.esims ?? d ?? [];
    esimCount = Array.isArray(esims) ? esims.filter((e: any) => e.state === 'ENABLED').length : 0;
  }
} catch {}

const initials = (user?.first_name?.[0] ?? user?.email?.[0] ?? 'U').toUpperCase();
const fullName = [user?.first_name, user?.last_name].filter(Boolean).join(' ') || 'Traveler';
const path = Astro.url.pathname;
---

<Base title="Dashboard">
  <div class="dash-layout">

    <!-- Sidebar -->
    <aside class="dash-sidebar">
      <!-- User pill -->
      <div style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;background:linear-gradient(135deg,#f0fdff,#e0f9ff);border-radius:1rem;margin-bottom:1rem;">
        <div style="width:38px;height:38px;background:linear-gradient(135deg,#03def3,#0ea5e9);border-radius:9999px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#162544;font-size:0.9rem;flex-shrink:0;">
          {initials}
        </div>
        <div style="min-width:0;">
          <p style="font-weight:700;color:#162544;font-size:0.825rem;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{fullName}</p>
          <p style="color:#9ca3af;font-size:0.72rem;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{user?.email ?? ''}</p>
        </div>
      </div>

      <nav>
        <a href="/dashboard" class={`dash-nav-item ${path === '/dashboard' ? 'active' : ''}`}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Overview
        </a>
        <a href="/dashboard/esims" class={`dash-nav-item ${path === '/dashboard/esims' ? 'active' : ''}`}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          My eSIMs
          {esimCount > 0 && <span style="margin-left:auto;background:#03def3;color:#162544;font-size:0.65rem;font-weight:800;padding:0.1rem 0.4rem;border-radius:9999px;">{esimCount}</span>}
        </a>
        <a href="/dashboard/invoices" class={`dash-nav-item ${path === '/dashboard/invoices' ? 'active' : ''}`}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Invoices
        </a>
        <a href="/dashboard/profile" class={`dash-nav-item ${path === '/dashboard/profile' ? 'active' : ''}`}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Profile
        </a>

        <div style="border-top:1px solid #f0f0f0;margin:0.5rem 0;"></div>

        <a href="/" class="dash-nav-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-9H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.6.6-.2 1.7.7 1.7H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          Buy eSIM
        </a>
        <button id="sidebarLogout" class="dash-nav-item" style="color:#ef4444;" onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background=''">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Sign Out
        </button>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="dash-main">

      <!-- Page header -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <h1 style="font-size:1.75rem;font-weight:900;color:#162544;margin:0 0 0.25rem;letter-spacing:-0.5px;">
            Good day, {user?.first_name ?? 'Traveler'} 👋
          </h1>
          <p style="color:#9ca3af;font-size:0.875rem;margin:0;">Welcome to your WoWo SIM dashboard</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <a href="/" class="btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Buy eSIM
          </a>
          <button id="logoutBtn" class="btn-outline" style="font-size:0.8rem;padding:0.6rem 1.1rem;">Sign Out</button>
        </div>
      </div>

      <!-- Stats Cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:2rem;">
        {[
          { icon: '📱', label: 'Active eSIMs', value: String(esimCount), href: '/dashboard/esims', color: '#f0fdff' },
          { icon: '🌍', label: 'Countries Covered', value: '195+', href: '/', color: '#f0fdff' },
          { icon: '⚡', label: 'Setup Time', value: '< 2 min', href: '/', color: '#fef9c3' },
          { icon: '🔒', label: 'Account Status', value: 'Active', href: '/dashboard/profile', color: '#dcfce7' },
        ].map(stat => (
          <a href={stat.href}
             style={`background:${stat.color};border-radius:1.25rem;padding:1.25rem;text-decoration:none;display:block;border:1.5px solid rgba(0,0,0,0.04);transition:all 0.2s;`}
             onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
            <div style="font-size:1.75rem;margin-bottom:0.5rem;">{stat.icon}</div>
            <p style="font-size:1.4rem;font-weight:900;color:#162544;margin:0;letter-spacing:-0.5px;">{stat.value}</p>
            <p style="font-size:0.75rem;color:#6b7280;margin:0.2rem 0 0;font-weight:500;">{stat.label}</p>
          </a>
        ))}
      </div>

      <!-- Quick navigation cards -->
      <h2 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 1rem;">Quick Access</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-bottom:2rem;">
        {[
          {
            icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
            title: 'My eSIMs',
            desc: 'View and manage your active plans',
            href: '/dashboard/esims',
          },
          {
            icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
            title: 'Invoices',
            desc: 'Download and view receipts',
            href: '/dashboard/invoices',
          },
          {
            icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
            title: 'Profile',
            desc: 'Update your account details',
            href: '/dashboard/profile',
          },
          {
            icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
            title: 'Help Center',
            desc: 'Find answers and get support',
            href: '/help-center',
          },
        ].map(item => (
          <a href={item.href} class="card"
             style="text-decoration:none;display:flex;align-items:flex-start;gap:0.875rem;transition:all 0.2s;"
             onmouseover="this.style.boxShadow='0 8px 28px rgba(0,0,0,0.1)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='';this.style.transform=''">
            <div style="width:44px;height:44px;background:#f0fdff;border-radius:0.875rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <Fragment set:html={item.icon} />
            </div>
            <div>
              <p style="font-size:0.9rem;font-weight:700;color:#162544;margin:0 0 0.2rem;">{item.title}</p>
              <p style="font-size:0.78rem;color:#9ca3af;margin:0;line-height:1.4;">{item.desc}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Profile summary card -->
      <h2 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 1rem;">Account Details</h2>
      <div class="card" style="display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1.5rem;padding:1.5rem;">
        <div style="width:56px;height:56px;background:linear-gradient(135deg,#03def3,#0ea5e9);border-radius:9999px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#162544;font-size:1.25rem;flex-shrink:0;">
          {initials}
        </div>
        <div>
          <p style="font-size:1.05rem;font-weight:800;color:#162544;margin:0 0 0.2rem;">{fullName}</p>
          <p style="font-size:0.825rem;color:#9ca3af;margin:0;">{user?.email ?? 'Loading...'}</p>
          {user?.phone && <p style="font-size:0.8rem;color:#6b7280;margin:0.2rem 0 0;">{user.phone}</p>}
        </div>
        <a href="/dashboard/profile" class="btn-outline" style="font-size:0.8rem;padding:0.55rem 1.1rem;white-space:nowrap;">
          Edit Profile
        </a>
      </div>
    </main>
  </div>
</Base>

<script>
  // Logout button(s)
  async function doLogout() {
    try {
      await fetch('/api/logout', { method: 'POST' });
    } catch {}
    window.location.href = '/';
  }
  document.getElementById('logoutBtn')?.addEventListener('click', doLogout);
  document.getElementById('sidebarLogout')?.addEventListener('click', doLogout);
</script>
