---
import Base from '../../layouts/Base.astro';
import { getJwt, isLoggedIn, clearAuthCookie } from '../../lib/auth';
import { portalFetch } from '../../lib/api';

if (!isLoggedIn(Astro.cookies)) return Astro.redirect('/login');

const jwt = getJwt(Astro.cookies);
let user: any = {};

try {
  const res = await portalFetch('/me', {}, jwt);
  if (res.ok) user = await res.json();
} catch {}
---

<Base title="My Profile">
  <div style="min-height: calc(100vh - 140px); background: #f9fafb; padding: 2rem 1rem;">
    <div style="max-width: 560px; margin: 0 auto;">
      <a href="/dashboard" style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; display: block; margin-bottom: 0.5rem;">← Dashboard</a>
      <h1 style="font-size: 1.75rem; font-weight: 800; color: #162544; margin: 0 0 2rem;">My Profile</h1>

      <!-- Avatar -->
      <div class="card" style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem;">
        <div style="width: 64px; height: 64px; background: linear-gradient(135deg, #03def3, #162544); border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 700; color: white; flex-shrink: 0;">
          {(user.first_name?.[0] ?? user.email?.[0] ?? 'U').toUpperCase()}
        </div>
        <div>
          <p style="font-weight: 700; color: #162544; margin: 0 0 0.2rem; font-size: 1rem;">{user.first_name} {user.last_name}</p>
          <p style="color: #9ca3af; font-size: 0.825rem; margin: 0;">{user.email}</p>
        </div>
      </div>

      <!-- Edit Form -->
      <div class="card" style="margin-bottom: 1.5rem;">
        <h2 style="font-size: 1rem; font-weight: 700; color: #162544; margin: 0 0 1.25rem;">Personal Information</h2>
        <form id="profileForm" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">First name</label>
              <input type="text" id="firstName" value={user.first_name ?? ''} style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
            <div>
              <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Last name</label>
              <input type="text" id="lastName" value={user.last_name ?? ''} style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none;" onfocus="this.style.borderColor='#03def3'" onblur="this.style.borderColor='#e5e7eb'" />
            </div>
          </div>
          <div>
            <label style="display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem;">Email</label>
            <input type="email" id="email" value={user.email ?? ''} style="width: 100%; padding: 0.7rem 0.9rem; border: 1.5px solid #e5e7eb; border-radius: 0.65rem; font-size: 0.85rem; outline: none; background: #f9fafb;" disabled />
          </div>
          <button type="submit" id="saveBtn" class="btn-primary" style="align-self: flex-start; font-size: 0.875rem; padding: 0.65rem 1.5rem;">Save Changes</button>
          <div id="profileMsg" style="display: none; font-size: 0.8rem; padding: 0.65rem 1rem; border-radius: 0.65rem;"></div>
        </form>
      </div>

      <!-- Danger Zone -->
      <div class="card" style="border: 1px solid #fee2e2;">
        <h2 style="font-size: 1rem; font-weight: 700; color: #dc2626; margin: 0 0 0.5rem;">Danger Zone</h2>
        <p style="color: #9ca3af; font-size: 0.8rem; margin: 0 0 1rem;">Permanently delete your account and all associated data. This cannot be undone.</p>
        <button id="deleteBtn" style="background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; padding: 0.6rem 1.25rem; border-radius: 0.65rem; font-size: 0.825rem; font-weight: 600; cursor: pointer; transition: background 0.2s;"
           onmouseover="this.style.background='#dc2626'; this.style.color='white'" onmouseout="this.style.background='#fee2e2'; this.style.color='#dc2626'">
          Delete Account
        </button>
      </div>
    </div>
  </div>
</Base>

<script>
  document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('saveBtn') as HTMLButtonElement;
    const msg = document.getElementById('profileMsg') as HTMLElement;
    btn.textContent = 'Saving...'; btn.disabled = true;
    try {
      const res = await fetch('/api/profile-update', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user: { first_name: (document.getElementById('firstName') as HTMLInputElement).value, last_name: (document.getElementById('lastName') as HTMLInputElement).value } }),
      });
      const data = await res.json();
      msg.style.display = 'block';
      if (data.success) { msg.style.background = '#dcfce7'; msg.style.color = '#15803d'; msg.textContent = 'Profile updated successfully!'; }
      else { msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = 'Update failed. Please try again.'; }
    } catch { msg.style.display = 'block'; msg.style.background = '#fee2e2'; msg.style.color = '#dc2626'; msg.textContent = 'Network error.'; }
    finally { btn.textContent = 'Save Changes'; btn.disabled = false; }
  });

  document.getElementById('deleteBtn')?.addEventListener('click', async () => {
    if (!confirm('Are you sure? This will permanently delete your account.')) return;
    await fetch('/api/profile-delete', { method: 'POST' });
    window.location.href = '/';
  });
</script>
