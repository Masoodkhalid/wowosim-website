---
import Base from '../../layouts/Base.astro';
import { getJwt, isLoggedIn } from '../../lib/auth';
import { portalFetch } from '../../lib/api';

if (!isLoggedIn(Astro.cookies)) return Astro.redirect('/login');

const jwt = getJwt(Astro.cookies);
let esims: any[] = [];
try {
  const res = await portalFetch('/esims', {}, jwt);
  if (res.ok) { const d = await res.json(); esims = d.esims ?? d ?? []; }
} catch {}

const statusMap: Record<string, { label: string; badge: string }> = {
  ENABLED:  { label: 'Active',             badge: 'badge-success' },
  RELEASED: { label: 'Awaiting Activation',badge: 'badge-warning' },
  DISABLED: { label: 'Inactive',           badge: 'badge-danger' },
  deleted:  { label: 'Expired',            badge: 'badge-danger' },
};
---

<Base title="My eSIMs">
  <div style="min-height: calc(100vh - 140px); background: #f9fafb; padding: 2rem 1rem;">
    <div style="max-width: 72rem; margin: 0 auto;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
        <div>
          <a href="/dashboard" style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; display: block; margin-bottom: 0.25rem;">← Dashboard</a>
          <h1 style="font-size: 1.75rem; font-weight: 800; color: #162544; margin: 0;">My eSIMs</h1>
        </div>
        <a href="/" class="btn-primary" style="font-size: 0.85rem; padding: 0.6rem 1.25rem;">+ Buy New eSIM</a>
      </div>

      {esims.length === 0 ? (
        <div class="card" style="text-align: center; padding: 4rem;">
          <div style="font-size: 3.5rem; margin-bottom: 1rem;">📱</div>
          <h2 style="font-size: 1.25rem; font-weight: 700; color: #162544; margin: 0 0 0.5rem;">No eSIMs yet</h2>
          <p style="color: #9ca3af; font-size: 0.875rem; margin: 0 0 1.5rem;">Purchase your first eSIM and start travelling connected.</p>
          <a href="/" class="btn-primary">Browse Plans →</a>
        </div>
      ) : (
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {esims.map((esim: any) => {
            const status = statusMap[esim.state] ?? { label: esim.state, badge: 'badge-info' };
            return (
              <a href={`/dashboard/esim/${esim.iccid}`} class="card" style="display: flex; align-items: center; justify-content: space-between; text-decoration: none; transition: all 0.2s;"
                 onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,0.1)'; this.style.transform='translateY(-1px)'" onmouseout="this.style.boxShadow=''; this.style.transform=''">
                <div style="display: flex; align-items: center; gap: 1rem;">
                  <div style="width: 48px; height: 48px; background: linear-gradient(135deg, #f0fdff, #e0f9ff); border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    📶
                  </div>
                  <div>
                    <p style="font-weight: 700; color: #162544; margin: 0 0 0.25rem; font-size: 0.9rem;">{esim.iccid}</p>
                    <p style="color: #9ca3af; font-size: 0.78rem; margin: 0;">{esim.country ?? 'eSIM'}</p>
                  </div>
                </div>
                <div style="display: flex; align-items: center; gap: 1rem;">
                  <span class={status.badge}>{status.label}</span>
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>
</Base>
