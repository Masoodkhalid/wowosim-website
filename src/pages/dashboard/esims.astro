---
import Base from '../../layouts/Base.astro';
import { getJwt, isLoggedIn } from '../../lib/auth';
import { portalFetch } from '../../lib/api';

if (!isLoggedIn(Astro.cookies)) return Astro.redirect('/login?next=/dashboard/esims');

const jwt = getJwt(Astro.cookies);
let user: any = null;
let esims: any[] = [];

try {
  const [meRes, esimsRes] = await Promise.all([
    portalFetch('/me', {}, jwt),
    portalFetch('/esims', {}, jwt),
  ]);
  if (meRes.ok) user = await meRes.json();
  if (esimsRes.ok) {
    const d = await esimsRes.json();
    esims = d.esims ?? d ?? [];
    if (!Array.isArray(esims)) esims = [];
  }
} catch {}

const statusMap: Record<string, { label: string; badge: string; dotColor: string }> = {
  ENABLED:  { label: 'Active',              badge: 'badge-success', dotColor: '#22c55e' },
  RELEASED: { label: 'Awaiting Activation', badge: 'badge-warning', dotColor: '#f59e0b' },
  DISABLED: { label: 'Inactive',            badge: 'badge-danger',  dotColor: '#ef4444' },
  deleted:  { label: 'Expired',             badge: 'badge-danger',  dotColor: '#ef4444' },
};

const initials = (user?.first_name?.[0] ?? user?.email?.[0] ?? 'U').toUpperCase();
const path = Astro.url.pathname;
---

<Base title="My eSIMs">
  <div class="dash-layout">
    <!-- Sidebar -->
    <aside class="dash-sidebar">
      <div style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;background:linear-gradient(135deg,#f0fdff,#e0f9ff);border-radius:1rem;margin-bottom:1rem;">
        <div style="width:38px;height:38px;background:linear-gradient(135deg,#03def3,#0ea5e9);border-radius:9999px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#162544;font-size:0.9rem;flex-shrink:0;">
          {initials}
        </div>
        <div style="min-width:0;">
          <p style="font-weight:700;color:#162544;font-size:0.825rem;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{user?.first_name ?? 'Account'}</p>
          <p style="color:#9ca3af;font-size:0.72rem;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{user?.email ?? ''}</p>
        </div>
      </div>
      <nav>
        <a href="/dashboard" class="dash-nav-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Overview
        </a>
        <a href="/dashboard/esims" class="dash-nav-item active">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          My eSIMs
        </a>
        <a href="/dashboard/invoices" class="dash-nav-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Invoices
        </a>
        <a href="/dashboard/profile" class="dash-nav-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Profile
        </a>
        <div style="border-top:1px solid #f0f0f0;margin:0.5rem 0;"></div>
        <a href="/" class="dash-nav-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-9H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.6.6-.2 1.7.7 1.7H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          Buy eSIM
        </a>
        <button id="sidebarLogout" class="dash-nav-item" style="color:#ef4444;" onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background=''">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Sign Out
        </button>
      </nav>
    </aside>

    <!-- Main -->
    <main class="dash-main">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <a href="/dashboard" style="display:inline-flex;align-items:center;gap:0.3rem;color:#9ca3af;font-size:0.8rem;text-decoration:none;margin-bottom:0.35rem;transition:color 0.15s;" onmouseover="this.style.color='#162544'" onmouseout="this.style.color='#9ca3af'">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Dashboard
          </a>
          <h1 style="font-size:1.75rem;font-weight:900;color:#162544;margin:0;letter-spacing:-0.5px;">My eSIMs</h1>
        </div>
        <a href="/" class="btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Buy New eSIM
        </a>
      </div>

      {esims.length === 0 ? (
        <div class="card" style="text-align:center;padding:4rem 2rem;">
          <div style="width:80px;height:80px;background:#f0fdff;border-radius:1.5rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
            <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 style="font-size:1.25rem;font-weight:800;color:#162544;margin:0 0 0.5rem;">No eSIMs yet</h2>
          <p style="color:#9ca3af;font-size:0.875rem;margin:0 0 1.75rem;max-width:320px;margin-left:auto;margin-right:auto;">Purchase your first eSIM and start travelling connected. Plans from $3.50.</p>
          <a href="/" class="btn-primary" style="font-size:0.925rem;padding:0.8rem 2rem;">Browse Plans →</a>
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:0.875rem;">
          {esims.map((esim: any) => {
            const statusKey = esim.state ?? 'DISABLED';
            const status = statusMap[statusKey] ?? { label: statusKey, badge: 'badge-info', dotColor: '#6b7280' };
            const countryName = esim.country ?? esim.name ?? 'eSIM';
            const iccid = esim.iccid ?? esim.eid ?? 'Unknown';
            const data = esim.quota ? `${esim.quota}GB` : '';
            const days = esim.valadity ? `${esim.valadity} days` : '';
            const metaParts = [data, days].filter(Boolean);

            return (
              <a href={`/dashboard/esim/${iccid}`}
                 style="display:flex;align-items:center;justify-content:space-between;gap:1rem;text-decoration:none;background:white;border-radius:1.25rem;padding:1.25rem 1.5rem;border:1.5px solid #f0f0f0;box-shadow:0 1px 4px rgba(0,0,0,0.05);transition:all 0.2s;"
                 onmouseover="this.style.boxShadow='0 8px 28px rgba(0,0,0,0.1)';this.style.transform='translateY(-1px)';this.style.borderColor='#e5e7eb'" onmouseout="this.style.boxShadow='0 1px 4px rgba(0,0,0,0.05)';this.style.transform='';this.style.borderColor='#f0f0f0'">
                <div style="display:flex;align-items:center;gap:1rem;">
                  <!-- Flag/icon -->
                  <div style="width:52px;height:52px;background:linear-gradient(135deg,#f0fdff,#e0f9ff);border-radius:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    {esim.flag ? (
                      <img src={esim.flag} alt="" style="width:32px;height:22px;border-radius:3px;object-fit:cover;" loading="lazy" />
                    ) : (
                      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>
                      </svg>
                    )}
                  </div>
                  <div>
                    <p style="font-weight:700;color:#162544;margin:0 0 0.2rem;font-size:0.95rem;">{countryName}</p>
                    <p style="color:#9ca3af;font-size:0.75rem;margin:0;font-family:monospace;">{iccid.length > 20 ? iccid.substring(0, 20) + '…' : iccid}</p>
                    {metaParts.length > 0 && (
                      <p style="color:#6b7280;font-size:0.75rem;margin:0.2rem 0 0;">{metaParts.join(' · ')}</p>
                    )}
                  </div>
                </div>
                <div style="display:flex;align-items:center;gap:1rem;flex-shrink:0;">
                  <span class={status.badge} style="display:flex;align-items:center;gap:0.3rem;">
                    <span style={`width:6px;height:6px;border-radius:9999px;background:${status.dotColor};flex-shrink:0;`}></span>
                    {status.label}
                  </span>
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#d1d5db" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </main>
  </div>
</Base>

<script>
  document.getElementById('sidebarLogout')?.addEventListener('click', async () => {
    try { await fetch('/api/logout', { method: 'POST' }); } catch {}
    window.location.href = '/';
  });
</script>
