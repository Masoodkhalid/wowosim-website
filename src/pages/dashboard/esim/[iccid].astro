<script define:vars={{ iccid }}>
  // Copy ICCID
  document.getElementById('copyIccid')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(iccid);
      const lbl = document.getElementById('copyLabel');
      if (lbl) { lbl.textContent = 'COPIED!'; lbl.style.color = '#03def3'; }
      setTimeout(() => { if (lbl) { lbl.textContent = 'COPY'; lbl.style.color = 'rgba(255,255,255,0.6)'; }}, 2000);
    } catch {}
  });

  // OS Tabs
  document.querySelectorAll('.os-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const os = (btn as HTMLElement).dataset.os;
      document.querySelectorAll('.os-tab').forEach((b: any) => {
        b.style.background = 'white'; b.style.color = '#6b7280'; b.style.borderColor = '#e5e7eb';
      });
      (btn as HTMLElement).style.background = '#162544';
      (btn as HTMLElement).style.color = 'white';
      (btn as HTMLElement).style.borderColor = '#162544';
      document.querySelectorAll('.os-steps').forEach((s: any) => s.style.display = 'none');
      const panel = document.getElementById(`steps-${os}`);
      if (panel) panel.style.display = 'block';
    });
  });
</script>

<style>
  @media (max-width:768px) {
    #mainGrid { grid-template-columns: 1fr !important; }
    [style*="position:sticky"] { position:static !important; }
  }
</style>
