---
const steps = [
  {
    n: '01',
    icon: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none">
      <circle cx="22" cy="22" r="20" fill="#f0fdff" stroke="#03def3" stroke-width="1.5"/>
      <path d="M22 12a10 10 0 100 20 10 10 0 000-20z" fill="none" stroke="#162544" stroke-width="1.5"/>
      <ellipse cx="22" cy="22" rx="10" ry="4" fill="none" stroke="#162544" stroke-width="1.2"/>
      <line x1="22" y1="12" x2="22" y2="32" stroke="#162544" stroke-width="1.2"/>
      <line x1="12" y1="22" x2="32" y2="22" stroke="#162544" stroke-width="1.2"/>
      <circle cx="30" cy="14" r="5" fill="#03def3"/>
      <path d="M28 14l1.5 1.5L32 12" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    title: 'Choose Destination',
    desc: 'Browse 195+ countries and regional plans. Compare data sizes, validity, and pricing to find the perfect plan for your trip.',
    color: '#03def3',
  },
  {
    n: '02',
    icon: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none">
      <circle cx="22" cy="22" r="20" fill="#fff7ed" stroke="#f59e0b" stroke-width="1.5"/>
      <rect x="13" y="12" width="18" height="20" rx="2" fill="#162544" opacity="0.9"/>
      <rect x="15" y="14" width="14" height="12" rx="1" fill="#1e3a6e"/>
      <rect x="15" y="27" width="6" height="2" rx="1" fill="#03def3"/>
      <circle cx="25" cy="28" r="2" fill="#f59e0b"/>
      <path d="M28 18l2 2-2 2" stroke="#03def3" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    title: 'Purchase Instantly',
    desc: 'Secure checkout in seconds. We accept all major cards, Apple Pay, Google Pay, and PayPal. No hidden fees or contracts.',
    color: '#f59e0b',
  },
  {
    n: '03',
    icon: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none">
      <circle cx="22" cy="22" r="20" fill="#f0fdf4" stroke="#22c55e" stroke-width="1.5"/>
      <rect x="12" y="12" width="8" height="8" rx="1" fill="#162544"/>
      <rect x="13.5" y="13.5" width="5" height="5" rx="0.5" fill="#03def3" opacity="0.5"/>
      <rect x="24" y="12" width="8" height="8" rx="1" fill="#162544"/>
      <rect x="25.5" y="13.5" width="5" height="5" rx="0.5" fill="#03def3" opacity="0.5"/>
      <rect x="12" y="24" width="8" height="8" rx="1" fill="#162544"/>
      <rect x="13.5" y="25.5" width="5" height="5" rx="0.5" fill="#03def3" opacity="0.5"/>
      <rect x="24" y="24" width="4" height="4" rx="0.5" fill="#162544"/>
      <rect x="30" y="24" width="2" height="8" rx="0.5" fill="#162544"/>
      <rect x="24" y="30" width="5" height="2" rx="0.5" fill="#162544"/>
      <path d="M27 17l1.5 1.5L31 15" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    title: 'Scan QR Code',
    desc: 'Check your email for the QR code. Open your device camera and scan — takes less than 60 seconds. No app download needed.',
    color: '#22c55e',
  },
  {
    n: '04',
    icon: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none">
      <circle cx="22" cy="22" r="20" fill="#fdf4ff" stroke="#a855f7" stroke-width="1.5"/>
      <path d="M14 22 Q18 14 22 18 Q26 22 30 14" stroke="#162544" stroke-width="1.5" stroke-linecap="round" fill="none"/>
      <circle cx="22" cy="30" r="4" fill="#162544" opacity="0.15"/>
      <path d="M18 28 Q22 24 26 28" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" fill="none"/>
      <path d="M15 25 Q22 19 29 25" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.5"/>
      <path d="M12 22 Q22 14 32 22" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.3"/>
      <circle cx="22" cy="31" r="2" fill="#a855f7"/>
    </svg>`,
    title: 'Travel Connected',
    desc: 'Your eSIM activates automatically when you land. Enjoy fast 4G/5G data in 195+ countries with no roaming surprises.',
    color: '#a855f7',
  },
];
---

<section style="padding:5rem 2rem;background:linear-gradient(180deg,white 0%,#f0fdff 100%);position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.04) 1px,transparent 1px);background-size:32px 32px;"></div>

  <div style="max-width:72rem;margin:0 auto;position:relative;z-index:1;">
    <div style="text-align:center;margin-bottom:3.5rem;">
      <span style="color:#03def3;font-weight:700;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;display:block;margin-bottom:0.75rem;">Get Connected in Minutes</span>
      <h2 style="font-size:2.25rem;font-weight:900;color:#162544;margin:0 0 0.75rem;letter-spacing:-0.5px;">How It Works</h2>
      <p style="color:#6b7280;font-size:0.95rem;max-width:440px;margin:0 auto;line-height:1.6;">From purchase to connected in under 2 minutes. No physical SIM, no store visits, no hassle.</p>
    </div>

    <!-- Steps -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;" id="stepsGrid">

      <!-- Connecting line behind steps -->
      <div style="position:absolute;top:3.5rem;left:calc(12.5% + 22px);right:calc(12.5% + 22px);height:2px;background:linear-gradient(90deg,#03def3,#a855f7);opacity:0.2;z-index:0;"></div>

      {steps.map((s, i) => (
        <div class="step-card" style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 1.5rem;position:relative;z-index:1;">
          <!-- Number + Icon stacked -->
          <div style="position:relative;margin-bottom:1.5rem;">
            <div style={`width:72px;height:72px;background:white;border-radius:9999px;display:flex;align-items:center;justify-content:center;border:2px solid ${s.color};box-shadow:0 4px 20px rgba(0,0,0,0.08);transition:transform 0.25s,box-shadow 0.25s;`}
                 onmouseover="this.style.transform='scale(1.1)';this.style.boxShadow='0 8px 28px rgba(0,0,0,0.15)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'">
              <Fragment set:html={s.icon} />
            </div>
            <span style={`position:absolute;top:-8px;right:-8px;width:24px;height:24px;background:${s.color};color:white;font-size:0.6rem;font-weight:900;border-radius:9999px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,0.2);`}>
              {i+1}
            </span>
          </div>

          <h3 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 0.6rem;">{s.title}</h3>
          <p style="font-size:0.8rem;color:#6b7280;line-height:1.6;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA row -->
    <div style="text-align:center;margin-top:3.5rem;display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;">
      <a href="/" style="display:inline-flex;align-items:center;gap:0.5rem;background:linear-gradient(135deg,#162544,#1e3a6e);color:white;font-weight:700;padding:0.9rem 2.25rem;border-radius:9999px;text-decoration:none;font-size:0.95rem;box-shadow:0 4px 16px rgba(22,37,68,0.25);transition:all 0.2s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(22,37,68,0.3)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 16px rgba(22,37,68,0.25)'">
        Get Started Now →
      </a>
      <a href="/compatible-devices" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.875rem;font-weight:700;color:#6b7280;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#162544'" onmouseout="this.style.color='#6b7280'">
        Check device compatibility →
      </a>
    </div>
  </div>
</section>

<style>
  @media (max-width:900px) {
    #stepsGrid { grid-template-columns: repeat(2,1fr) !important; gap: 2rem !important; }
    [style*="position:absolute;top:3.5rem"] { display: none; }
  }
  @media (max-width:480px) {
    #stepsGrid { grid-template-columns: 1fr !important; }
  }
</style>
