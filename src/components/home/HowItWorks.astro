---
const steps = [
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.2-5.2m0 0A7.5 7.5 0 105.2 15.8 7.5 7.5 0 0015.8 15.8z"/>
    </svg>`,
    title: 'Choose Your Plan',
    desc: 'Select a country or regional plan that matches your travel destination and data needs.',
    step: '01',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
    </svg>`,
    title: 'Purchase Instantly',
    desc: 'Pay securely with card, Apple Pay, Google Pay or PayPal in seconds.',
    step: '02',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8H3a2 2 0 00-2 2v10a2 2 0 002 2h14a2 2 0 002-2v-3"/>
    </svg>`,
    title: 'Scan QR Code',
    desc: 'Receive your eSIM QR code by email immediately. Scan it on your device.',
    step: '03',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>
    </svg>`,
    title: 'Stay Connected',
    desc: 'Arrive at your destination and your data activates automatically.',
    step: '04',
  },
];
---

<section style="padding:5rem 1.5rem;background:#f9fafb;position:relative;overflow:hidden;">
  <!-- Background decoration -->
  <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,#03def3,transparent);opacity:0.5;"></div>

  <div style="max-width:80rem;margin:0 auto;">
    <div style="text-align:center;margin-bottom:4rem;">
      <span class="section-label">Simple Setup</span>
      <h2 class="section-title">How It Works</h2>
      <p class="section-sub" style="max-width:420px;margin:0 auto;">Get connected in 4 simple steps — takes less than 5 minutes total.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;position:relative;">
      <!-- Connector -->
      <div style="position:absolute;top:3rem;left:calc(12.5% + 1rem);right:calc(12.5% + 1rem);height:2px;background:linear-gradient(to right,#03def3,rgba(3,222,243,0.2),rgba(3,222,243,0.2),#03def3);z-index:0;pointer-events:none;"></div>

      {steps.map((step, i) => (
        <div style="position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;text-align:center;" class="how-step">
          <!-- Step number + icon bubble -->
          <div class="how-icon-wrap" style="position:relative;width:6rem;height:6rem;margin-bottom:1.25rem;">
            <div class="how-icon" style="width:6rem;height:6rem;border-radius:1.5rem;background:white;box-shadow:0 4px 20px rgba(0,0,0,0.1);border:1.5px solid #f0f0f0;display:flex;align-items:center;justify-content:center;transition:all 0.3s;color:#162544;">
              <Fragment set:html={step.icon} />
            </div>
            <span style="position:absolute;top:-6px;right:-6px;width:22px;height:22px;background:#03def3;color:#162544;font-size:0.62rem;font-weight:800;border-radius:9999px;display:flex;align-items:center;justify-content:center;border:2px solid white;">
              {i+1}
            </span>
          </div>

          <p style="font-size:0.65rem;font-weight:800;color:#03def3;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.5rem;">{step.step}</p>
          <h3 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 0.6rem;">{step.title}</h3>
          <p style="font-size:0.8rem;color:#9ca3af;line-height:1.65;margin:0;max-width:180px;">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA below steps -->
    <div style="text-align:center;margin-top:3.5rem;">
      <a href="/" class="btn-primary" style="font-size:0.95rem;padding:0.875rem 2.25rem;">
        Get Your eSIM Now
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .how-step:hover .how-icon {
    background: #162544;
    color: #03def3;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(22,37,68,0.2);
  }
  @media (max-width: 768px) {
    .how-step { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .how-step { grid-column: span 4; }
  }
</style>
