---
---
<section style="background:white;border-bottom:1px solid #f3f4f6;padding:1.5rem 2rem;">
  <div style="max-width:80rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;">

    <!-- Stats -->
    <div style="display:flex;gap:2.5rem;flex-wrap:wrap;align-items:center;">
      {[
        { n: '25k+', l: 'Happy Travelers' },
        { n: '195+', l: 'Countries' },
        { n: '2000+', l: 'Plans Available' },
        { n: '< 2min', l: 'Activation Time' },
      ].map(s => (
        <div style="text-align:center;">
          <p style="font-size:1.3rem;font-weight:900;color:#162544;margin:0;line-height:1;letter-spacing:-0.5px;">{s.n}</p>
          <p style="font-size:0.7rem;color:#9ca3af;margin:0.2rem 0 0;font-weight:500;">{s.l}</p>
        </div>
      ))}
    </div>

    <!-- Trustpilot badge -->
    <div style="display:flex;align-items:center;gap:1rem;flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:0.5rem;background:#f9fafb;border:1px solid #f3f4f6;border-radius:0.875rem;padding:0.6rem 1rem;">
        <div style="display:flex;gap:0.15rem;">
          {[1,2,3,4,5].map(() => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#00b67a"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <div>
          <p style="font-size:0.7rem;font-weight:700;color:#162544;margin:0;line-height:1;">4.6/5</p>
          <p style="font-size:0.6rem;color:#9ca3af;margin:0;">Trustpilot</p>
        </div>
      </div>

      <!-- App store badges -->
      <div style="display:flex;flex-direction:column;gap:0.35rem;">
        <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;border-radius:0.5rem;padding:0.35rem 0.7rem;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span style="font-size:0.65rem;font-weight:600;">App Store</span>
        </a>
        <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;border-radius:0.5rem;padding:0.35rem 0.7rem;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M3.18 23.76c.3.17.64.2.96.08l11.8-6.77-2.44-2.44-10.32 9.13zm-1.1-20.4C2.03 3.6 2 3.86 2 4.15v15.7c0 .29.03.55.08.8l11.31-11.31L2.08 3.36zm19.5 8.97l-2.82-1.62-2.74 2.74 2.74 2.74 2.84-1.63c.81-.46.81-1.77-.02-2.23zM4.14.24L15.94 7l-2.44 2.44L3.18.31A1.1 1.1 0 014.14.24z"/></svg>
          <span style="font-size:0.65rem;font-weight:600;">Google Play</span>
        </a>
      </div>
    </div>
  </div>
</section>
