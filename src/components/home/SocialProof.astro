---
---
<section style="background:linear-gradient(135deg,#162544 0%,#1a2d50 50%,#162544 100%);border-bottom:1px solid rgba(3,222,243,0.1);padding:1.5rem 2rem;position:relative;overflow:hidden;">
  <!-- Subtle grid -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.04) 1px,transparent 1px);background-size:20px 20px;pointer-events:none;"></div>

  <div style="max-width:80rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;position:relative;z-index:1;">

    <!-- Stats -->
    <div style="display:flex;gap:0;flex-wrap:wrap;align-items:stretch;">
      {[
        { n: '50k+',   l: 'Happy Travelers', icon: '✈️',  color: '#03def3' },
        { n: '195+',   l: 'Countries',       icon: '🌍',  color: '#42BFCA' },
        { n: '2000+',  l: 'Plans Available', icon: '📦',  color: '#FF5F00' },
        { n: '< 2min', l: 'Activation Time', icon: '⚡',  color: '#03def3' },
      ].map((s, i) => (
        <div style={`display:flex;align-items:center;gap:0.75rem;padding:0.5rem 1.5rem;${i>0?'border-left:1px solid rgba(255,255,255,0.08);':''}`}>
          <div style={`width:34px;height:34px;border-radius:0.65rem;background:${s.color}15;border:1px solid ${s.color}30;display:flex;align-items:center;justify-content:center;font-size:0.9rem;flex-shrink:0;`}>{s.icon}</div>
          <div>
            <p style={`font-size:1.35rem;font-weight:900;color:${s.color};margin:0;line-height:1;letter-spacing:-0.5px;`}>{s.n}</p>
            <p style="font-size:0.68rem;color:rgba(255,255,255,0.4);margin:0.15rem 0 0;font-weight:500;">{s.l}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Right: Trustpilot + App badges -->
    <div style="display:flex;align-items:center;gap:1.25rem;flex-shrink:0;flex-wrap:wrap;">

      <!-- Trustpilot -->
      <div style="display:flex;align-items:center;gap:0.65rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:0.875rem;padding:0.6rem 1rem;">
        <div style="display:flex;gap:0.1rem;">
          {[1,2,3,4,5].map(() => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#00b67a"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <div>
          <p style="font-size:0.75rem;font-weight:800;color:white;margin:0;line-height:1;">4.6/5</p>
          <p style="font-size:0.6rem;color:rgba(255,255,255,0.4);margin:0;font-weight:500;">Trustpilot</p>
        </div>
      </div>

      <!-- App store badges -->
      <div style="display:flex;flex-direction:column;gap:0.35rem;">
        <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:rgba(255,255,255,0.08);color:white;border:1px solid rgba(255,255,255,0.12);border-radius:0.5rem;padding:0.4rem 0.8rem;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span style="font-size:0.65rem;font-weight:600;">App Store</span>
        </a>
        <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:rgba(255,255,255,0.08);color:white;border:1px solid rgba(255,255,255,0.12);border-radius:0.5rem;padding:0.4rem 0.8rem;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M3.18 23.76c.3.17.64.2.96.08l11.8-6.77-2.44-2.44-10.32 9.13zm-1.1-20.4C2.03 3.6 2 3.86 2 4.15v15.7c0 .29.03.55.08.8l11.31-11.31L2.08 3.36zm19.5 8.97l-2.82-1.62-2.74 2.74 2.74 2.74 2.84-1.63c.81-.46.81-1.77-.02-2.23zM4.14.24L15.94 7l-2.44 2.44L3.18.31A1.1 1.1 0 014.14.24z"/></svg>
          <span style="font-size:0.65rem;font-weight:600;">Google Play</span>
        </a>
      </div>
    </div>
  </div>
</section>
