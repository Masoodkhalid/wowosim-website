---
const features = [
  { label: 'Price',                  local: 'Varies ($5–$30)', wowo: 'From $3.50',      roaming: 'Very expensive' },
  { label: 'Instant Activation',     local: false,             wowo: true,              roaming: true },
  { label: 'No Physical SIM',        local: false,             wowo: true,              roaming: true },
  { label: 'Keep Your Number',       local: false,             wowo: true,              roaming: true },
  { label: 'No Hidden Fees',         local: '⚠️ Sometimes',   wowo: true,              roaming: false },
  { label: 'Works Immediately',      local: '⚠️ Needs setup', wowo: true,              roaming: true },
  { label: 'Multiple Countries',     local: false,             wowo: true,              roaming: true },
  { label: '24/7 Support',           local: false,             wowo: true,              roaming: '⚠️ Limited' },
  { label: 'Manage via App',         local: false,             wowo: true,              roaming: false },
  { label: 'QR Code Delivery',       local: false,             wowo: true,              roaming: false },
];

function icon(val: boolean | string) {
  if (val === true) return '✅';
  if (val === false) return '❌';
  return val;
}
---

<section style="padding:4rem 2rem;background:white;">
  <div style="max-width:72rem;margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="color:#03def3;font-weight:600;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.1em;">Why WoWo SIM?</span>
      <h2 style="font-size:2rem;font-weight:900;color:#162544;margin:0.5rem 0 0.5rem;letter-spacing:-0.5px;">WoWo SIM vs Alternatives</h2>
      <p style="color:#9ca3af;font-size:0.9rem;max-width:480px;margin:0 auto;">See why smart travelers choose WoWo SIM over local SIMs and roaming plans.</p>
    </div>

    <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
      <table style="width:100%;border-collapse:collapse;min-width:540px;">
        <thead>
          <tr>
            <th style="padding:0.9rem 1.25rem;text-align:left;font-size:0.78rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;border-bottom:2px solid #f3f4f6;">Feature</th>
            <th style="padding:0.9rem 1.25rem;text-align:center;font-size:0.78rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;border-bottom:2px solid #f3f4f6;">Local SIM</th>
            <th style="padding:0.9rem 1.25rem;text-align:center;background:linear-gradient(135deg,#162544,#1e3560);border-radius:0.75rem 0.75rem 0 0;">
              <span style="color:#03def3;font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;">WoWo SIM</span>
              <span style="display:block;background:#03def3;color:#162544;font-size:0.6rem;font-weight:700;padding:0.1rem 0.5rem;border-radius:9999px;margin:0.25rem auto 0;width:fit-content;">RECOMMENDED</span>
            </th>
            <th style="padding:0.9rem 1.25rem;text-align:center;font-size:0.78rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.05em;border-bottom:2px solid #f3f4f6;">Roaming</th>
          </tr>
        </thead>
        <tbody>
          {features.map((row, i) => (
            <tr style={`background:${i%2===0?'#f9fafb':'white'};transition:background 0.15s;`}
                onmouseover="this.style.background='#f0fdff'" onmouseout={`this.style.background='${i%2===0?'#f9fafb':'white'}'`}>
              <td style="padding:0.85rem 1.25rem;font-size:0.85rem;font-weight:600;color:#374151;">{row.label}</td>
              <td style="padding:0.85rem 1.25rem;text-align:center;font-size:0.85rem;color:#6b7280;">{icon(row.local)}</td>
              <td style="padding:0.85rem 1.25rem;text-align:center;font-size:0.85rem;background:rgba(22,37,68,0.03);border-left:2px solid #162544;border-right:2px solid #162544;font-weight:700;color:#162544;">{icon(row.wowo)}</td>
              <td style="padding:0.85rem 1.25rem;text-align:center;font-size:0.85rem;color:#6b7280;">{icon(row.roaming)}</td>
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr>
            <td style="padding:1rem 1.25rem;"></td>
            <td style="padding:1rem 1.25rem;text-align:center;"></td>
            <td style="padding:1rem 1.25rem;text-align:center;background:rgba(22,37,68,0.03);border:2px solid #162544;border-top:none;border-radius:0 0 0.75rem 0.75rem;">
              <a href="/" class="btn-primary" style="font-size:0.8rem;padding:0.6rem 1.25rem;">Get Started →</a>
            </td>
            <td style="padding:1rem 1.25rem;"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</section>
