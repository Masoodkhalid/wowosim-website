<script>
(function() {
  const track   = document.getElementById('bTrack');
  const dotsEl  = document.getElementById('bDots');
  const prevBtn = document.getElementById('bPrev');
  const nextBtn = document.getElementById('bNext');
  if (!track) return;

  const slides = track.querySelectorAll('.bSlide');
  const total  = slides.length;
  let cur = 0;
  let timer: ReturnType<typeof setInterval>;

  // Build dots
  slides.forEach((_, i) => {
    const d = document.createElement('button');
    d.style.cssText = `width:${i===0?'28px':'10px'};height:10px;border-radius:9999px;border:none;cursor:pointer;transition:all 0.3s;background:${i===0?'#162544':'#d1d5db'};padding:0;`;
    d.setAttribute('aria-label', `Go to slide ${i+1}`);
    d.addEventListener('click', () => goTo(i));
    dotsEl?.appendChild(d);
  });

  function goTo(n: number) {
    cur = (n + total) % total;
    track.style.transform = `translateX(-${cur * 100}%)`;
    dotsEl?.querySelectorAll('button').forEach((d, i) => {
      (d as HTMLElement).style.width    = i === cur ? '28px' : '10px';
      (d as HTMLElement).style.background = i === cur ? '#162544' : '#d1d5db';
    });
    resetTimer();
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo(cur + 1), 5000);
  }

  prevBtn?.addEventListener('click', () => goTo(cur - 1));
  nextBtn?.addEventListener('click', () => goTo(cur + 1));

  // Touch / swipe
  let touchStartX = 0;
  track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend',   e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? cur + 1 : cur - 1);
  });

  // Pause on hover
  const outer = document.getElementById('bOuter');
  outer?.addEventListener('mouseenter', () => clearInterval(timer));
  outer?.addEventListener('mouseleave', resetTimer);

  resetTimer();
})();
</script>

<style>
  @media (max-width: 768px) {
    .bSlide { grid-template-columns: 1fr !important; }
    .bSlide > div:first-child { min-height: 280px !important; }
    #bPrev, #bNext { display: none !important; }
  }
</style>
