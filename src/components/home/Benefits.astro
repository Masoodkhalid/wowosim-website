---
const benefits = [
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'No Roaming Charges',
    desc: 'Pay a fixed price for your data. No surprise bills when you get home. What you see is what you pay.',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
    title: 'Keep Your Number',
    desc: 'Your physical SIM stays active for calls and SMS. Use eSIM purely for fast data while traveling.',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
    title: 'Easy Installation',
    desc: 'Scan a QR code in your phone settings. The whole process takes under 2 minutes, no tech skills needed.',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>`,
    title: 'Reliable Internet',
    desc: 'Connect to top local networks in every country. Fast 4G LTE and 5G speeds wherever you go.',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
    title: '24/7 Support',
    desc: 'Our support team is available around the clock via live chat. We\'re here whenever you need help.',
  },
  {
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#03def3" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`,
    title: 'Global Coverage',
    desc: 'One account covers 195+ countries. Buy plans for your destinations before you even leave home.',
  },
];
---

<section style="padding:4rem 2rem;background:#f9fafb;">
  <div style="max-width:80rem;margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="color:#03def3;font-weight:600;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.1em;">Why WoWo SIM</span>
      <h2 style="font-size:2rem;font-weight:900;color:#162544;margin:0.5rem 0 0.5rem;letter-spacing:-0.5px;">Travel Smarter with eSIM</h2>
      <p style="color:#9ca3af;font-size:0.9rem;max-width:480px;margin:0 auto;">Everything you need to stay connected, nothing you don't.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
      {benefits.map(b => (
        <div style="background:white;border-radius:1.25rem;padding:1.75rem;border:1.5px solid #f0f0f0;box-shadow:0 1px 4px rgba(0,0,0,0.05);transition:all 0.25s;"
             onmouseover="this.style.borderColor='#03def3';this.style.boxShadow='0 8px 28px rgba(3,222,243,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='#f0f0f0';this.style.boxShadow='0 1px 4px rgba(0,0,0,0.05)';this.style.transform=''">
          <div style="width:52px;height:52px;background:#f0fdff;border-radius:0.875rem;display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem;">
            <Fragment set:html={b.icon} />
          </div>
          <h3 style="font-size:1rem;font-weight:800;color:#162544;margin:0 0 0.5rem;">{b.title}</h3>
          <p style="font-size:0.85rem;color:#6b7280;line-height:1.6;margin:0;">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
