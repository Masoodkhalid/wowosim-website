const input = document.getElementById('heroSearch') as HTMLInputElement;
const dropdown = document.getElementById('heroDropdown') as HTMLElement;
const wrapper = document.getElementById('searchWrapper') as HTMLElement;
const searchBtn = document.getElementById('heroSearchBtn') as HTMLButtonElement;

let highlighted = -1;
let filteredResults: typeof COUNTRIES = [];

function showDropdown(results: typeof COUNTRIES) {
  filteredResults = results;
  highlighted = -1;
  if (results.length === 0) {
    dropdown.innerHTML = '';
    dropdown.classList.remove('open');
    input.setAttribute('aria-expanded', 'false');
    return;
  }
  dropdown.innerHTML = results.slice(0, 8).map((c, i) => `
    <div class="search-option" data-slug="${c.slug}" data-idx="${i}" role="option">
      <span style="font-size:1.1rem;">${c.flag}</span>
      <span>${c.name}</span>
    </div>
  `).join('');
  dropdown.classList.add('open');
  input.setAttribute('aria-expanded', 'true');

  dropdown.querySelectorAll('.search-option').forEach(opt => {
    opt.addEventListener('mousedown', (e) => {
      e.preventDefault();
      const slug = (opt as HTMLElement).dataset.slug;
      if (slug) navigate(slug);
    });
  });
}

function hideDropdown() {
  dropdown.classList.remove('open');
  input.setAttribute('aria-expanded', 'false');
  highlighted = -1;
}

function navigate(slug: string) {
  window.location.href = `/${slug}`;
}

function filterCountries(query: string) {
  const q = query.toLowerCase().trim();
  if (!q) return [];
  return COUNTRIES.filter(c => c.name.toLowerCase().includes(q) || c.slug.includes(q));
}

input?.addEventListener('input', () => {
  const val = input.value;
  if (val.trim().length < 1) { hideDropdown(); return; }
  showDropdown(filterCountries(val));
});

input?.addEventListener('keydown', (e) => {
  const opts = dropdown.querySelectorAll('.search-option');
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    highlighted = Math.min(highlighted + 1, opts.length - 1);
    opts.forEach((o, i) => (o as HTMLElement).classList.toggle('highlighted', i === highlighted));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    highlighted = Math.max(highlighted - 1, -1);
    opts.forEach((o, i) => (o as HTMLElement).classList.toggle('highlighted', i === highlighted));
  } else if (e.key === 'Enter') {
    e.preventDefault();
    if (highlighted >= 0 && filteredResults[highlighted]) {
      navigate(filteredResults[highlighted].slug);
    } else {
      const val = input.value.trim().toLowerCase().replace(/\s+/g, '-');
      if (val) navigate(val);
    }
  } else if (e.key === 'Escape') {
    hideDropdown();
  }
});

input?.addEventListener('focus', () => {
  if (wrapper) wrapper.style.borderColor = '#03def3';
  if (input.value.trim().length >= 1) showDropdown(filterCountries(input.value));
});

input?.addEventListener('blur', () => {
  if (wrapper) wrapper.style.borderColor = '#e5e7eb';
  setTimeout(hideDropdown, 150);
});

searchBtn?.addEventListener('click', (e) => {
  const val = input?.value.trim().toLowerCase().replace(/\s+/g, '-');
  if (val) { e.preventDefault(); navigate(val); }
});
</script>

