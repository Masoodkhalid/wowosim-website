---
---
<section style="position: relative; overflow: hidden; background: linear-gradient(135deg, #ffffff 0%, #f0fdff 50%, #ffffff 100%); padding: 5rem 2rem 6rem;">
  <!-- Background blobs -->
  <div style="position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: rgba(3,222,243,0.08); border-radius: 9999px; filter: blur(60px);"></div>
  <div style="position: absolute; bottom: -80px; left: -80px; width: 300px; height: 300px; background: rgba(59,130,246,0.06); border-radius: 9999px; filter: blur(60px);"></div>

  <div style="max-width: 80rem; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; position: relative; z-index: 1;">

    <!-- Text -->
    <div class="hero-text">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(3,222,243,0.12); color: #162544; font-size: 0.8rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 9999px; margin-bottom: 1.5rem;">
        ⭐ 4.6 on Trustpilot · 50,000+ happy travelers
      </div>

      <h1 style="font-size: 3.5rem; font-weight: 900; color: #162544; line-height: 1.1; margin: 0 0 1.5rem; letter-spacing: -1px;">
        Stay Connected<br/>
        <span style="color: #03def3;">Anywhere</span> You Travel
      </h1>

      <p style="color: #6b7280; font-size: 1.1rem; line-height: 1.7; margin: 0 0 2rem; max-width: 480px;">
        Get instant eSIM data in 195+ countries. No physical SIM, no roaming fees.
        Activate in minutes before you even board your flight.
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <a href="#plans" class="btn-primary" style="font-size: 1rem; padding: 1rem 2rem;">
          Browse Plans →
        </a>
        <a href="/help-center" class="btn-outline" style="font-size: 1rem; padding: 1rem 2rem;">
          How It Works
        </a>
      </div>

      <!-- Stats -->
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #f3f4f6;">
        {[
          { number: '195+', label: 'Countries' },
          { number: '$3.50', label: 'Starting from' },
          { number: '24/7', label: 'Support' },
        ].map(s => (
          <div>
            <p style="font-size: 1.75rem; font-weight: 900; color: #162544; margin: 0 0 0.2rem;">{s.number}</p>
            <p style="font-size: 0.8rem; color: #9ca3af; margin: 0;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Character Animation Side -->
    <div style="display: flex; justify-content: center; align-items: center; position: relative;">
      <div id="heroChar" style="animation: float 3s ease-in-out infinite; width: 100%; max-width: 420px;">
        <!-- Lottie loads here via JS -->
        <!-- Fallback illustration -->
        <div style="background: linear-gradient(135deg, #f0fdff, #e0f9ff); border-radius: 2rem; padding: 3rem; text-align: center; box-shadow: 0 20px 60px rgba(3,222,243,0.15);">
          <div style="font-size: 6rem; margin-bottom: 1rem;">🌍</div>
          <div style="background: white; border-radius: 1rem; padding: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
            <p style="color: #162544; font-weight: 700; margin: 0 0 0.25rem;">eSIM Active</p>
            <p style="color: #03def3; font-size: 0.8rem; margin: 0;">Connected · 195+ Countries</p>
          </div>
        </div>
      </div>

      <!-- Floating badges -->
      <div style="position: absolute; top: 1rem; left: -1rem; background: white; border-radius: 1rem; padding: 0.6rem 0.8rem; box-shadow: 0 8px 25px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 0.5rem; animation: float 3s ease-in-out infinite; animation-delay: 0.5s;">
        <span style="font-size: 1.5rem;">✈️</span>
        <div>
          <p style="font-size: 0.7rem; font-weight: 700; color: #162544; margin: 0;">Instant</p>
          <p style="font-size: 0.65rem; color: #9ca3af; margin: 0;">Activation</p>
        </div>
      </div>
      <div style="position: absolute; bottom: 2rem; right: -1rem; background: white; border-radius: 1rem; padding: 0.6rem 0.8rem; box-shadow: 0 8px 25px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 0.5rem; animation: float 3s ease-in-out infinite; animation-delay: 1s;">
        <span style="font-size: 1.5rem;">📶</span>
        <div>
          <p style="font-size: 0.7rem; font-weight: 700; color: #162544; margin: 0;">No Roaming</p>
          <p style="font-size: 0.65rem; color: #9ca3af; margin: 0;">Fees</p>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Try to load Lottie character if JSON file exists
  fetch('/lottie/hero-character.json')
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (!data) return;
      import('https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/build/player/lottie.min.js').then((m: any) => {
        const lottie = m.default ?? m;
        document.getElementById('heroChar')!.innerHTML = '';
        lottie.loadAnimation({
          container: document.getElementById('heroChar'),
          renderer: 'svg',
          loop: true,
          autoplay: true,
          animationData: data,
        });
      });
    })
    .catch(() => {});
</script>
