---
const topDestinations = [
  { name:'United States', slug:'united-states', flag:'🇺🇸', code:'us' },
  { name:'United Kingdom', slug:'united-kingdom', flag:'🇬🇧', code:'gb' },
  { name:'Japan',          slug:'japan',          flag:'🇯🇵', code:'jp' },
  { name:'Australia',      slug:'australia',      flag:'🇦🇺', code:'au' },
  { name:'France',         slug:'france',         flag:'🇫🇷', code:'fr' },
  { name:'Germany',        slug:'germany',        flag:'🇩🇪', code:'de' },
  { name:'Italy',          slug:'italy',          flag:'🇮🇹', code:'it' },
  { name:'Canada',         slug:'canada',         flag:'🇨🇦', code:'ca' },
  { name:'Spain',          slug:'spain',          flag:'🇪🇸', code:'es' },
  { name:'Thailand',       slug:'thailand',       flag:'🇹🇭', code:'th' },
];
---

<section style="position:relative;overflow:hidden;background:linear-gradient(150deg,#f8faff 0%,#eef9ff 40%,#e3f5ff 70%,#f0f8ff 100%);padding:4rem 1.5rem 5rem;">

  <!-- Background mesh pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.07) 1.5px,transparent 1.5px);background-size:26px 26px;pointer-events:none;"></div>
  <!-- Glow blobs -->
  <div style="position:absolute;top:-120px;right:-60px;width:700px;height:500px;background:radial-gradient(ellipse,rgba(3,222,243,0.1) 0%,transparent 60%);pointer-events:none;"></div>
  <div style="position:absolute;bottom:-80px;left:-80px;width:500px;height:400px;background:radial-gradient(ellipse,rgba(22,37,68,0.05) 0%,transparent 65%);pointer-events:none;"></div>

  <div style="max-width:78rem;margin:0 auto;position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;" id="heroGrid">

      <!-- ── Left: Content ── -->
      <div>
        <!-- Trust badge -->
        <div style="display:inline-flex;align-items:center;gap:0.5rem;background:white;border:1.5px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,0.06);padding:0.45rem 1.1rem;border-radius:9999px;margin-bottom:1.75rem;font-size:0.78rem;font-weight:700;color:#374151;">
          <span style="color:#f59e0b;letter-spacing:0.05em;">★★★★★</span>
          <span>4.6 on Trustpilot</span>
          <span style="width:1px;height:12px;background:#e5e7eb;display:inline-block;"></span>
          <span style="color:#6b7280;">50k+ travelers</span>
        </div>

        <h1 style="font-size:3.5rem;font-weight:900;color:#162544;line-height:1.05;margin:0 0 1.25rem;letter-spacing:-2px;">
          Travel Smarter<br/>
          <span style="position:relative;display:inline-block;">
            with&nbsp;<span style="background:linear-gradient(100deg,#03def3 0%,#0ea5e9 50%,#42BFCA 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">eSIM</span>
            <svg style="position:absolute;bottom:-6px;left:0;width:100%;" viewBox="0 0 200 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2 6 Q50 2 100 5 Q150 8 198 4" stroke="#03def3" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6"/>
            </svg>
          </span>
        </h1>

        <p style="color:#6b7280;font-size:1.05rem;line-height:1.72;margin:0 0 2rem;max-width:440px;">
          Instant eSIM data in <strong style="color:#162544;">195+ countries</strong>. No physical SIM. No roaming charges. Activate in under 2 minutes — before you even board.
        </p>

        <!-- Search bar -->
        <div style="position:relative;max-width:460px;margin-bottom:1.75rem;">
          <div style="background:white;border:2px solid #e5e7eb;border-radius:1rem;padding:0.4rem 0.4rem 0.4rem 0.9rem;display:flex;align-items:center;gap:0.5rem;box-shadow:0 4px 24px rgba(0,0,0,0.08);transition:border-color 0.2s;" id="searchWrapper">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2.2" style="flex-shrink:0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.2-5.2m0 0A7.5 7.5 0 105.2 15.8 7.5 7.5 0 0015.8 15.8z"/>
            </svg>
            <input id="heroSearch" type="text" placeholder="Where are you traveling?"
              style="flex:1;border:none;outline:none;font-size:0.9rem;color:#374151;background:transparent;font-family:inherit;"
              autocomplete="off" aria-label="Search destinations" aria-autocomplete="list" aria-controls="heroDropdown" aria-expanded="false" />
            <button id="heroSearchBtn" class="btn-primary" style="font-size:0.825rem;padding:0.6rem 1.1rem;border-radius:0.65rem;white-space:nowrap;flex-shrink:0;">
              Find Plans
            </button>
          </div>
          <div id="heroDropdown" class="search-dropdown" role="listbox"></div>
        </div>

        <!-- Stats row -->
        <div style="display:flex;gap:2.5rem;flex-wrap:wrap;margin-bottom:2rem;">
          {[
            { n:'195+',  l:'Countries covered' },
            { n:'$3.50', l:'Plans from' },
            { n:'2 min', l:'Avg. setup time' },
            { n:'24/7',  l:'Support' },
          ].map(s => (
            <div>
              <p style="font-size:1.5rem;font-weight:900;color:#162544;margin:0;line-height:1;letter-spacing:-0.5px;">{s.n}</p>
              <p style="font-size:0.7rem;color:#9ca3af;margin:0.2rem 0 0;font-weight:500;">{s.l}</p>
            </div>
          ))}
        </div>

        <!-- App badges -->
        <div style="display:flex;gap:0.65rem;flex-wrap:wrap;">
          <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;padding:0.5rem 0.9rem;border-radius:0.75rem;font-size:0.75rem;font-weight:700;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;padding:0.5rem 0.9rem;border-radius:0.75rem;font-size:0.75rem;font-weight:700;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M3.18 23.76c.3.17.65.19.98.07l12.56-7.25-2.81-2.82-10.73 9.99zm-1.92-20.2C1.1 3.84 1 4.18 1 4.56v14.88c0 .38.1.72.26 1l10.83-10.84-10.83-10.04zM20.35 9.58l-2.61-1.5-3.19 3.19 3.19 3.19 2.63-1.52c.75-.43.75-1.93-.02-2.36zM4.16.24C3.83.12 3.48.14 3.18.31L13.88 11l-2.81 2.82L4.16.24z"/></svg>
            Google Play
          </a>
        </div>
      </div>

      <!-- ── Right: Traveler Scene ── -->
      <div id="heroVisual" style="position:relative;display:flex;justify-content:center;align-items:center;min-height:480px;">

        <!-- Background circle -->
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:380px;height:380px;background:radial-gradient(circle,rgba(3,222,243,0.08) 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
        <div class="hero-ring" style="position:absolute;top:50%;left:50%;width:360px;height:360px;border:2px dashed rgba(3,222,243,0.2);border-radius:50%;pointer-events:none;"></div>
        <div class="hero-ring-2" style="position:absolute;top:50%;left:50%;width:290px;height:290px;border:1.5px solid rgba(22,37,68,0.06);border-radius:50%;pointer-events:none;"></div>

        <!-- Central phone illustration -->
        <div class="hero-phone" style="position:relative;z-index:4;">
          <svg width="200" height="340" viewBox="0 0 200 340" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Phone shadow -->
            <ellipse cx="100" cy="325" rx="60" ry="10" fill="rgba(22,37,68,0.12)"/>
            <!-- Phone body -->
            <rect x="30" y="10" width="140" height="300" rx="24" fill="#0f172a"/>
            <rect x="34" y="14" width="132" height="292" rx="20" fill="#1e293b"/>
            <!-- Screen -->
            <rect x="38" y="18" width="124" height="284" rx="16" fill="url(#phoneGrad)"/>
            <!-- Notch -->
            <rect x="72" y="22" width="56" height="12" rx="6" fill="#0f172a"/>
            <!-- Screen content: map lines -->
            <line x1="38" y1="80" x2="162" y2="80" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
            <line x1="38" y1="130" x2="162" y2="130" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
            <line x1="38" y1="180" x2="162" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
            <line x1="88" y1="18" x2="88" y2="302" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <line x1="128" y1="18" x2="128" y2="302" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <!-- WoWo SIM logo area -->
            <rect x="50" y="40" width="100" height="28" rx="6" fill="rgba(3,222,243,0.15)"/>
            <text x="100" y="58" text-anchor="middle" fill="#03def3" font-size="10" font-weight="800" font-family="system-ui">WoWoSIM</text>
            <!-- Signal bars -->
            <rect x="50" y="85" width="8" height="8" rx="1" fill="#03def3" opacity="0.5"/>
            <rect x="61" y="80" width="8" height="13" rx="1" fill="#03def3" opacity="0.7"/>
            <rect x="72" y="75" width="8" height="18" rx="1" fill="#03def3"/>
            <!-- QR Code area -->
            <rect x="55" y="105" width="90" height="90" rx="8" fill="white" opacity="0.95"/>
            <text x="100" y="122" text-anchor="middle" fill="#162544" font-size="6.5" font-weight="700" font-family="system-ui">SCAN QR CODE</text>
            <!-- QR pattern (stylized) -->
            <rect x="63" y="128" width="16" height="16" rx="2" fill="#162544"/>
            <rect x="65" y="130" width="12" height="12" rx="1" fill="white"/>
            <rect x="67" y="132" width="8" height="8" rx="1" fill="#162544"/>
            <rect x="103" y="128" width="16" height="16" rx="2" fill="#162544"/>
            <rect x="105" y="130" width="12" height="12" rx="1" fill="white"/>
            <rect x="107" y="132" width="8" height="8" rx="1" fill="#162544"/>
            <rect x="63" y="166" width="16" height="16" rx="2" fill="#162544"/>
            <rect x="65" y="168" width="12" height="12" rx="1" fill="white"/>
            <rect x="67" y="170" width="8" height="8" rx="1" fill="#162544"/>
            <!-- QR dots pattern -->
            <rect x="83" y="128" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="91" y="128" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="83" y="136" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="91" y="136" rx="0.5" width="5" height="5" fill="#162544"/>
            <rect x="83" y="144" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="91" y="144" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="83" y="152" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="91" y="152" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="83" y="160" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="91" y="160" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="123" y="136" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="123" y="144" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="123" y="152" width="5" height="5" rx="0.5" fill="#162544"/>
            <rect x="123" y="160" width="5" height="5" rx="0.5" fill="#162544"/>
            <!-- Active status -->
            <circle cx="100" cy="210" r="6" fill="#22c55e"/>
            <text x="112" y="214" fill="#22c55e" font-size="8" font-weight="700" font-family="system-ui">ACTIVE</text>
            <!-- Data usage bar -->
            <rect x="55" y="228" width="90" height="6" rx="3" fill="rgba(255,255,255,0.1)"/>
            <rect x="55" y="228" width="60" height="6" rx="3" fill="url(#barGrad)"/>
            <text x="55" y="248" fill="rgba(255,255,255,0.5)" font-size="6.5" font-family="system-ui">3.2 GB used</text>
            <text x="145" y="248" text-anchor="end" fill="rgba(255,255,255,0.5)" font-size="6.5" font-family="system-ui">5 GB total</text>
            <!-- Bottom nav indicator -->
            <circle cx="100" cy="290" r="3" fill="rgba(255,255,255,0.3)"/>
            <!-- Defs -->
            <defs>
              <linearGradient id="phoneGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1a3060"/>
                <stop offset="100%" stop-color="#0d1a33"/>
              </linearGradient>
              <linearGradient id="barGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#03def3"/>
                <stop offset="100%" stop-color="#0ea5e9"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <!-- ── Traveler 1: Business woman (top-left) ── -->
        <div class="traveler t1" style="position:absolute;top:20px;left:0;z-index:3;">
          <svg width="90" height="130" viewBox="0 0 90 130" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Shadow -->
            <ellipse cx="45" cy="124" rx="22" ry="5" fill="rgba(22,37,68,0.1)"/>
            <!-- Legs -->
            <rect x="35" y="95" width="10" height="28" rx="5" fill="#162544"/>
            <rect x="47" y="95" width="10" height="28" rx="5" fill="#1e3a6e"/>
            <!-- Shoes -->
            <ellipse cx="40" cy="122" rx="8" ry="4" fill="#0f172a"/>
            <ellipse cx="52" cy="122" rx="8" ry="4" fill="#0f172a"/>
            <!-- Body: blazer -->
            <rect x="28" y="55" width="34" height="44" rx="8" fill="#162544"/>
            <!-- Shirt detail -->
            <rect x="40" y="55" width="10" height="20" rx="0" fill="white" opacity="0.9"/>
            <!-- Left arm with phone -->
            <path d="M28 65 Q14 70 12 82" stroke="#e8c49a" stroke-width="9" stroke-linecap="round" fill="none"/>
            <!-- Phone in hand -->
            <rect x="5" y="78" width="14" height="22" rx="3" fill="#0f172a"/>
            <rect x="7" y="80" width="10" height="18" rx="2" fill="#03def3" opacity="0.8"/>
            <!-- Right arm (down) -->
            <path d="M62 65 Q72 72 70 85" stroke="#e8c49a" stroke-width="9" stroke-linecap="round" fill="none"/>
            <!-- Briefcase -->
            <rect x="62" y="82" width="20" height="15" rx="3" fill="#374151"/>
            <rect x="69" y="79" width="6" height="5" rx="1" fill="none" stroke="#374151" stroke-width="1.5"/>
            <line x1="62" y1="89" x2="82" y2="89" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
            <!-- Neck -->
            <rect x="40" y="46" width="10" height="12" rx="5" fill="#e8c49a"/>
            <!-- Head -->
            <circle cx="45" cy="36" r="20" fill="#e8c49a"/>
            <!-- Hair (bun) -->
            <path d="M28 28 Q30 10 45 8 Q60 10 62 28" fill="#2d1810"/>
            <circle cx="45" cy="12" r="8" fill="#2d1810"/>
            <!-- Eyes -->
            <circle cx="39" cy="32" r="3" fill="white"/>
            <circle cx="51" cy="32" r="3" fill="white"/>
            <circle cx="40" cy="33" r="1.8" fill="#1a0a05"/>
            <circle cx="52" cy="33" r="1.8" fill="#1a0a05"/>
            <!-- Smile -->
            <path d="M39 40 Q45 45 51 40" stroke="#c27b5a" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Glasses -->
            <path d="M34 31 Q39 28 44 31 Q45 31 46 31 Q51 28 56 31" stroke="#374151" stroke-width="1.5" fill="none"/>
          </svg>
        </div>

        <!-- ── Traveler 2: Young man with backpack (bottom-left) ── -->
        <div class="traveler t2" style="position:absolute;bottom:10px;left:5px;z-index:3;">
          <svg width="85" height="120" viewBox="0 0 85 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="42" cy="115" rx="20" ry="4" fill="rgba(22,37,68,0.1)"/>
            <!-- Legs -->
            <rect x="30" y="88" width="10" height="26" rx="5" fill="#374151"/>
            <rect x="43" y="88" width="10" height="26" rx="5" fill="#4b5563"/>
            <!-- Sneakers -->
            <ellipse cx="35" cy="113" rx="9" ry="4" fill="#03def3"/>
            <ellipse cx="48" cy="113" rx="9" ry="4" fill="#03def3"/>
            <!-- Body: hoodie -->
            <rect x="22" y="50" width="40" height="42" rx="9" fill="#FF5F00"/>
            <!-- Hoodie pocket -->
            <rect x="32" y="72" width="20" height="12" rx="4" fill="rgba(0,0,0,0.15)"/>
            <!-- Backpack -->
            <rect x="14" y="50" width="16" height="32" rx="6" fill="#162544"/>
            <rect x="16" y="52" width="12" height="28" rx="4" fill="#1e3a6e"/>
            <rect x="16" y="62" width="12" height="1" stroke="#03def3" stroke-width="1" fill="none"/>
            <!-- Shoulder straps -->
            <path d="M22 50 Q20 42 26 40" stroke="#162544" stroke-width="3" stroke-linecap="round" fill="none"/>
            <path d="M30 50 Q28 42 26 40" stroke="#162544" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- Right arm raised (waving) -->
            <path d="M62 58 Q74 45 76 36" stroke="#f5c5a3" stroke-width="9" stroke-linecap="round" fill="none"/>
            <!-- Waving hand -->
            <circle cx="76" cy="32" r="7" fill="#f5c5a3"/>
            <!-- Neck -->
            <rect x="37" y="40" width="10" height="13" rx="5" fill="#f5c5a3"/>
            <!-- Head -->
            <circle cx="42" cy="30" r="19" fill="#f5c5a3"/>
            <!-- Hair -->
            <path d="M24 24 Q26 8 42 6 Q58 8 60 24" fill="#1a0a05"/>
            <!-- Eyes -->
            <circle cx="36" cy="27" r="3" fill="white"/>
            <circle cx="48" cy="27" r="3" fill="white"/>
            <circle cx="37" cy="28" r="1.8" fill="#1a0a05"/>
            <circle cx="49" cy="28" r="1.8" fill="#1a0a05"/>
            <!-- Big smile -->
            <path d="M35 35 Q42 42 49 35" stroke="#c27b5a" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- Earphone wire -->
            <path d="M24 26 Q20 35 22 46" stroke="white" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.7"/>
            <circle cx="22" cy="46" r="2.5" fill="white" opacity="0.7"/>
          </svg>
        </div>

        <!-- ── Traveler 3: Woman with suitcase (top-right) ── -->
        <div class="traveler t3" style="position:absolute;top:15px;right:0;z-index:3;">
          <svg width="90" height="130" viewBox="0 0 90 130" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="45" cy="125" rx="20" ry="4" fill="rgba(22,37,68,0.1)"/>
            <!-- Suitcase -->
            <rect x="54" y="88" width="28" height="32" rx="4" fill="#42BFCA"/>
            <rect x="60" y="84" width="16" height="7" rx="2" fill="none" stroke="#42BFCA" stroke-width="2"/>
            <line x1="68" y1="88" x2="68" y2="120" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <line x1="54" y1="104" x2="82" y2="104" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <circle cx="58" cy="120" r="3" fill="#0d7a8a"/>
            <circle cx="78" cy="120" r="3" fill="#0d7a8a"/>
            <!-- Arm holding suitcase -->
            <path d="M62 62 Q68 76 66 90" stroke="#d4956a" stroke-width="9" stroke-linecap="round" fill="none"/>
            <!-- Legs -->
            <rect x="30" y="92" width="10" height="28" rx="5" fill="#FF5F00"/>
            <rect x="42" y="92" width="10" height="28" rx="5" fill="#e55200"/>
            <!-- Heels -->
            <path d="M30 118 L30 124 L38 124 L40 118" fill="#1a0a05"/>
            <path d="M42 118 L42 124 L50 124 L52 118" fill="#1a0a05"/>
            <!-- Dress/skirt -->
            <path d="M22 55 Q18 80 22 95 L58 95 Q62 80 58 55 Z" fill="#162544"/>
            <!-- Left arm (down, holding bag) -->
            <path d="M22 62 Q10 70 8 80" stroke="#d4956a" stroke-width="9" stroke-linecap="round" fill="none"/>
            <!-- Small bag -->
            <rect x="2" y="76" width="16" height="20" rx="4" fill="#FF5F00"/>
            <path d="M6 76 Q10 70 14 76" fill="none" stroke="#FF5F00" stroke-width="1.5"/>
            <!-- Neck -->
            <rect x="38" y="44" width="10" height="14" rx="5" fill="#d4956a"/>
            <!-- Head -->
            <circle cx="43" cy="32" r="20" fill="#d4956a"/>
            <!-- Long hair -->
            <path d="M23 28 Q22 50 28 58" stroke="#2d1810" stroke-width="8" stroke-linecap="round" fill="none"/>
            <path d="M63 28 Q64 50 58 58" stroke="#2d1810" stroke-width="8" stroke-linecap="round" fill="none"/>
            <path d="M24 22 Q26 6 43 4 Q60 6 62 22" fill="#2d1810"/>
            <!-- Eyes with lashes -->
            <circle cx="37" cy="28" r="3.5" fill="white"/>
            <circle cx="49" cy="28" r="3.5" fill="white"/>
            <circle cx="38" cy="29" r="2" fill="#1a0a05"/>
