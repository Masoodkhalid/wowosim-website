---
const topDestinations = [
  { name:'United States', slug:'united-states', flag:'🇺🇸', code:'us' },
  { name:'United Kingdom', slug:'united-kingdom', flag:'🇬🇧', code:'gb' },
  { name:'Japan',          slug:'japan',          flag:'🇯🇵', code:'jp' },
  { name:'Australia',      slug:'australia',      flag:'🇦🇺', code:'au' },
  { name:'France',         slug:'france',         flag:'🇫🇷', code:'fr' },
  { name:'Germany',        slug:'germany',        flag:'🇩🇪', code:'de' },
  { name:'Italy',          slug:'italy',          flag:'🇮🇹', code:'it' },
  { name:'Canada',         slug:'canada',         flag:'🇨🇦', code:'ca' },
  { name:'Spain',          slug:'spain',          flag:'🇪🇸', code:'es' },
  { name:'Thailand',       slug:'thailand',       flag:'🇹🇭', code:'th' },
];
---

<section style="position:relative;overflow:hidden;background:linear-gradient(150deg,#f8faff 0%,#eef9ff 40%,#e3f5ff 70%,#f0f8ff 100%);padding:4rem 1.5rem 5rem;">

  <!-- Background mesh pattern -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(3,222,243,0.07) 1.5px,transparent 1.5px);background-size:26px 26px;pointer-events:none;"></div>
  <!-- Glow blobs -->
  <div style="position:absolute;top:-120px;right:-60px;width:700px;height:500px;background:radial-gradient(ellipse,rgba(3,222,243,0.1) 0%,transparent 60%);pointer-events:none;"></div>
  <div style="position:absolute;bottom:-80px;left:-80px;width:500px;height:400px;background:radial-gradient(ellipse,rgba(22,37,68,0.05) 0%,transparent 65%);pointer-events:none;"></div>

  <div style="max-width:78rem;margin:0 auto;position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;" id="heroGrid">

      <!-- ── Left: Content ── -->
      <div>
        <!-- Trust badge -->
        <div style="display:inline-flex;align-items:center;gap:0.5rem;background:white;border:1.5px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,0.06);padding:0.45rem 1.1rem;border-radius:9999px;margin-bottom:1.75rem;font-size:0.78rem;font-weight:700;color:#374151;">
          <span style="color:#f59e0b;letter-spacing:0.05em;">★★★★★</span>
          <span>4.6 on Trustpilot</span>
          <span style="width:1px;height:12px;background:#e5e7eb;display:inline-block;"></span>
          <span style="color:#6b7280;">50k+ travelers</span>
        </div>

        <h1 style="font-size:3.5rem;font-weight:900;color:#162544;line-height:1.05;margin:0 0 1.25rem;letter-spacing:-2px;">
          Travel Smarter<br/>
          <span style="position:relative;display:inline-block;">
            with&nbsp;<span style="background:linear-gradient(100deg,#03def3 0%,#0ea5e9 50%,#42BFCA 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">eSIM</span>
            <svg style="position:absolute;bottom:-6px;left:0;width:100%;" viewBox="0 0 200 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2 6 Q50 2 100 5 Q150 8 198 4" stroke="#03def3" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6"/>
            </svg>
          </span>
        </h1>

        <p style="color:#6b7280;font-size:1.05rem;line-height:1.72;margin:0 0 2rem;max-width:440px;">
          Instant eSIM data in <strong style="color:#162544;">195+ countries</strong>. No physical SIM. No roaming charges. Activate in under 2 minutes — before you even board.
        </p>

        <!-- Search bar -->
        <div style="position:relative;max-width:460px;margin-bottom:1.75rem;">
          <div style="background:white;border:2px solid #e5e7eb;border-radius:1rem;padding:0.4rem 0.4rem 0.4rem 0.9rem;display:flex;align-items:center;gap:0.5rem;box-shadow:0 4px 24px rgba(0,0,0,0.08);transition:border-color 0.2s;" id="searchWrapper">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2.2" style="flex-shrink:0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.2-5.2m0 0A7.5 7.5 0 105.2 15.8 7.5 7.5 0 0015.8 15.8z"/>
            </svg>
            <input id="heroSearch" type="text" placeholder="Where are you traveling?"
              style="flex:1;border:none;outline:none;font-size:0.9rem;color:#374151;background:transparent;font-family:inherit;"
              autocomplete="off" aria-label="Search destinations" aria-autocomplete="list" aria-controls="heroDropdown" aria-expanded="false" />
            <button id="heroSearchBtn" class="btn-primary" style="font-size:0.825rem;padding:0.6rem 1.1rem;border-radius:0.65rem;white-space:nowrap;flex-shrink:0;">
              Find Plans
            </button>
          </div>
          <div id="heroDropdown" class="search-dropdown" role="listbox"></div>
        </div>

        <!-- Stats row -->
        <div style="display:flex;gap:2.5rem;flex-wrap:wrap;margin-bottom:2rem;">
          {[
            { n:'195+',  l:'Countries covered' },
            { n:'$3.50', l:'Plans from' },
            { n:'2 min', l:'Avg. setup time' },
            { n:'24/7',  l:'Support' },
          ].map(s => (
            <div>
              <p style="font-size:1.5rem;font-weight:900;color:#162544;margin:0;line-height:1;letter-spacing:-0.5px;">{s.n}</p>
              <p style="font-size:0.7rem;color:#9ca3af;margin:0.2rem 0 0;font-weight:500;">{s.l}</p>
            </div>
          ))}
        </div>

        <!-- App badges -->
        <div style="display:flex;gap:0.65rem;flex-wrap:wrap;">
          <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;padding:0.5rem 0.9rem;border-radius:0.75rem;font-size:0.75rem;font-weight:700;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="#" style="display:flex;align-items:center;gap:0.4rem;background:#162544;color:white;padding:0.5rem 0.9rem;border-radius:0.75rem;font-size:0.75rem;font-weight:700;text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M3.18 23.76c.3.17.65.19.98.07l12.56-7.25-2.81-2.82-10.73 9.99zm-1.92-20.2C1.1 3.84 1 4.18 1 4.56v14.88c0 .38.1.72.26 1l10.83-10.84-10.83-10.04zM20.35 9.58l-2.61-1.5-3.19 3.19 3.19 3.19 2.63-1.52c.75-.43.75-1.93-.02-2.36zM4.16.24C3.83.12 3.48.14 3.18.31L13.88 11l-2.81 2.82L4.16.24z"/></svg>
            Google Play
          </a>
        </div>
      </div>

      <!-- ── Right: Airalo-style illustration ── -->
      <div id="heroVisual" style="position:relative;display:flex;justify-content:center;align-items:flex-end;min-height:520px;padding-bottom:0;">

        <!-- Decorative background shapes (Airalo-style) -->
        <div style="position:absolute;top:50px;right:10px;width:88px;height:88px;background:rgba(3,222,243,0.1);border-radius:18px;transform:rotate(18deg);pointer-events:none;z-index:1;"></div>
        <div style="position:absolute;top:220px;left:0;width:68px;height:68px;background:rgba(255,95,0,0.09);border-radius:14px;transform:rotate(-22deg);pointer-events:none;z-index:1;"></div>
        <div style="position:absolute;bottom:160px;right:0;width:56px;height:56px;background:rgba(66,191,202,0.12);border-radius:12px;transform:rotate(35deg);pointer-events:none;z-index:1;"></div>

        <!-- ── Main illustrated scene ── -->
        <div class="hero-scene" style="position:relative;z-index:3;">
          <svg width="480" height="490" viewBox="0 0 480 490" fill="none" xmlns="http://www.w3.org/2000/svg">

            <!-- ======= GROUND ======= -->
            <ellipse cx="245" cy="478" rx="210" ry="16" fill="rgba(22,37,68,0.07)"/>
            <rect x="38" y="460" width="410" height="20" rx="10" fill="#c8e6a0"/>
            <!-- Trees left -->
            <polygon points="68,460 84,424 100,460" fill="#2a7a40"/>
            <polygon points="76,446 86,418 96,446" fill="#359952"/>
            <!-- Trees right -->
            <polygon points="374,460 390,422 406,460" fill="#2a7a40"/>
            <polygon points="382,446 392,416 402,446" fill="#359952"/>
            <!-- Pebbles -->
            <circle cx="148" cy="462" r="6" fill="#b0d890"/>
            <circle cx="162" cy="464" r="4" fill="#b0d890"/>
            <circle cx="318" cy="463" r="5" fill="#b0d890"/>

            <!-- ===================== -->
            <!-- CHARACTER 1: MAN     -->
            <!-- Orange hoodie, left  -->
            <!-- Waving, holding phone-->
            <!-- ===================== -->

            <!-- Shadow -->
            <ellipse cx="178" cy="466" rx="52" ry="10" fill="rgba(0,0,0,0.09)"/>

            <!-- Left shoe (back foot) -->
            <path d="M128 444 Q126 455 130 462 L158 462 Q163 456 160 446" fill="#333"/>
            <path d="M131 459 L157 459" stroke="white" stroke-width="2.5" opacity="0.35"/>
            <!-- Right shoe (front foot, bigger) -->
            <path d="M160 440 Q157 453 161 462 L192 462 Q198 455 194 443" fill="#333"/>
            <path d="M162 459 L191 459" stroke="white" stroke-width="2.5" opacity="0.35"/>

            <!-- Legs (navy pants, walking) -->
            <path d="M152 300 Q143 372 130 444" stroke="#1e3a6e" stroke-width="34" stroke-linecap="round" fill="none"/>
            <path d="M204 300 Q198 370 192 443" stroke="#162544" stroke-width="34" stroke-linecap="round" fill="none"/>

            <!-- LEFT ARM (waving high — drawn before body) -->
            <path d="M132 178 Q102 158 82 130" stroke="#FF5F00" stroke-width="30" stroke-linecap="round" fill="none"/>
            <path d="M82 130 Q68 108 58 86" stroke="#f4c99e" stroke-width="24" stroke-linecap="round" fill="none"/>
            <!-- Waving hand -->
            <circle cx="57" cy="76" r="22" fill="#f4c99e"/>
            <!-- Fingers -->
            <rect x="42" y="52" width="12" height="30" rx="6" fill="#f4c99e"/>
            <rect x="56" y="47" width="12" height="32" rx="6" fill="#f4c99e"/>
            <rect x="70" y="50" width="12" height="29" rx="6" fill="#f4c99e"/>
            <rect x="83" y="58" width="11" height="24" rx="5.5" fill="#f4c99e"/>

            <!-- RIGHT ARM (down, holding phone — before body) -->
            <path d="M222 182 Q248 198 260 225" stroke="#FF5F00" stroke-width="28" stroke-linecap="round" fill="none"/>
            <path d="M260 225 Q265 245 266 260" stroke="#f4c99e" stroke-width="22" stroke-linecap="round" fill="none"/>

            <!-- HOODIE BODY -->
            <rect x="130" y="155" width="95" height="152" rx="32" fill="#FF5F00"/>
            <!-- Hoodie top sheen -->
            <rect x="130" y="155" width="95" height="50" rx="32" fill="rgba(255,255,255,0.1)"/>
            <!-- Collar / shirt underneath -->
            <path d="M165 157 L178 176 L191 157" fill="white" opacity="0.7"/>
            <!-- Hoodie pocket -->
            <rect x="152" y="255" width="52" height="36" rx="9" fill="rgba(0,0,0,0.12)"/>
            <line x1="178" y1="255" x2="178" y2="291" stroke="rgba(0,0,0,0.08)" stroke-width="1.5"/>
            <!-- Cuffs at sleeve ends (small detail) -->
            <rect x="130" y="155" width="12" height="18" rx="6" fill="#e55200" opacity="0" />

            <!-- PHONE in right hand -->
            <rect x="258" y="256" width="36" height="62" rx="9" fill="#0f172a"/>
            <rect x="262" y="262" width="28" height="50" rx="6" fill="#1e3a6e"/>
            <rect x="262" y="262" width="28" height="18" rx="5" fill="#162544"/>
            <text x="276" y="275" text-anchor="middle" fill="#03def3" font-size="6.5" font-weight="800" font-family="system-ui">WoWo</text>
            <rect x="266" y="286" width="5" height="10" rx="1.5" fill="#03def3" opacity="0.4"/>
            <rect x="273" y="283" width="5" height="13" rx="1.5" fill="#03def3" opacity="0.65"/>
            <rect x="280" y="280" width="5" height="16" rx="1.5" fill="#03def3"/>
            <circle cx="266" cy="306" r="3.5" fill="#22c55e"/>
            <text x="272" y="309" fill="#22c55e" font-size="5.5" font-family="system-ui,sans-serif">ACTIVE</text>

            <!-- NECK -->
            <rect x="165" y="138" width="25" height="24" rx="9" fill="#f4c99e"/>

            <!-- HEAD -->
            <circle cx="178" cy="96" r="46" fill="#f4c99e"/>
            <!-- Ears -->
            <circle cx="133" cy="98" r="13" fill="#f4c99e"/>
            <circle cx="133" cy="98" r="7.5" fill="#e8b87e"/>
            <circle cx="223" cy="98" r="13" fill="#f4c99e"/>
            <circle cx="223" cy="98" r="7.5" fill="#e8b87e"/>

            <!-- HAIR -->
            <path d="M134 77 Q136 46 178 40 Q220 46 222 77" fill="#2d1810"/>
            <path d="M134 68 Q130 52 136 38" stroke="#2d1810" stroke-width="8" stroke-linecap="round" fill="none"/>

            <!-- EYES -->
            <circle cx="162" cy="90" r="10" fill="white"/>
            <circle cx="194" cy="90" r="10" fill="white"/>
            <circle cx="164" cy="92" r="6.5" fill="#1a0a05"/>
            <circle cx="196" cy="92" r="6.5" fill="#1a0a05"/>
            <circle cx="166" cy="89" r="2.8" fill="white"/>
            <circle cx="198" cy="89" r="2.8" fill="white"/>

            <!-- EYEBROWS -->
            <path d="M151 79 Q162 72 173 79" stroke="#2d1810" stroke-width="3.5" stroke-linecap="round" fill="none"/>
            <path d="M183 79 Q194 72 205 79" stroke="#2d1810" stroke-width="3.5" stroke-linecap="round" fill="none"/>

            <!-- SMILE (open, happy) -->
            <path d="M160 110 Q178 128 196 110" fill="#c06040"/>
            <path d="M164 112 Q178 124 192 112" fill="white"/>

            <!-- BLUSH -->
            <ellipse cx="144" cy="103" rx="13" ry="8.5" fill="#ff8c6b" opacity="0.2"/>
            <ellipse cx="212" cy="103" rx="13" ry="8.5" fill="#ff8c6b" opacity="0.2"/>

            <!-- ======================== -->
            <!-- CHARACTER 2: WOMAN      -->
            <!-- Teal jacket, right side  -->
            <!-- Phone raised, cheerful   -->
            <!-- ======================== -->

            <!-- Shadow -->
            <ellipse cx="352" cy="466" rx="52" ry="10" fill="rgba(0,0,0,0.09)"/>

            <!-- Left shoe (step back, red) -->
            <path d="M298 444 Q296 455 300 462 L328 462 Q333 455 330 445" fill="#c0392b"/>
            <path d="M301 459 L327 459" stroke="white" stroke-width="2" opacity="0.4"/>
            <!-- Right shoe (front, red) -->
            <path d="M335 440 Q332 453 336 462 L364 462 Q370 455 366 442" fill="#c0392b"/>
            <path d="M337 459 L363 459" stroke="white" stroke-width="2" opacity="0.4"/>

            <!-- Legs (warm orange-ish trousers) -->
            <path d="M326 300 Q316 370 308 444" stroke="#FF5F00" stroke-width="34" stroke-linecap="round" fill="none"/>
            <path d="M376 300 Q370 368 364 443" stroke="#e55200" stroke-width="34" stroke-linecap="round" fill="none"/>

            <!-- LEFT ARM (casual, slightly out — before body) -->
            <path d="M308 180 Q278 172 260 160" stroke="#42BFCA" stroke-width="28" stroke-linecap="round" fill="none"/>
            <path d="M260 160 Q250 150 245 140" stroke="#8b5e3c" stroke-width="22" stroke-linecap="round" fill="none"/>
            <!-- Left hand (relaxed) -->
            <circle cx="243" cy="131" r="18" fill="#8b5e3c"/>

            <!-- RIGHT ARM (raised, holding phone up — before body) -->
            <path d="M394 178 Q422 155 436 126" stroke="#42BFCA" stroke-width="28" stroke-linecap="round" fill="none"/>
            <path d="M436 126 Q442 108 444 90" stroke="#8b5e3c" stroke-width="22" stroke-linecap="round" fill="none"/>

            <!-- TEAL JACKET BODY -->
            <rect x="306" y="152" width="92" height="158" rx="32" fill="#42BFCA"/>
            <rect x="306" y="152" width="92" height="50" rx="32" fill="rgba(255,255,255,0.12)"/>
            <!-- Collar / inner shirt -->
            <path d="M340 154 L352 174 L364 154" fill="white" opacity="0.65"/>
            <!-- Jacket bottom trim -->
            <rect x="306" y="298" width="92" height="14" rx="7" fill="rgba(0,0,0,0.08)"/>

            <!-- PHONE raised in right hand -->
            <rect x="432" y="52" width="34" height="56" rx="8" fill="#0f172a"/>
            <rect x="436" y="58" width="26" height="44" rx="6" fill="#1e3a6e"/>
            <rect x="436" y="58" width="26" height="18" rx="5" fill="#162544"/>
            <text x="449" y="71" text-anchor="middle" fill="#03def3" font-size="6" font-weight="800" font-family="system-ui">WoWo</text>
            <!-- Phone check/active -->
            <circle cx="449" cy="84" r="9" fill="rgba(34,197,94,0.18)"/>
            <path d="M445 84 L448 87 L455 80" stroke="#22c55e" stroke-width="2.2" stroke-linecap="round" fill="none"/>

            <!-- NECK -->
            <rect x="340" y="136" width="24" height="22" rx="8" fill="#8b5e3c"/>

            <!-- HEAD -->
            <circle cx="352" cy="94" r="46" fill="#8b5e3c"/>
            <!-- Ears -->
            <circle cx="307" cy="96" r="13" fill="#8b5e3c"/>
            <circle cx="307" cy="96" r="7.5" fill="#7a5030"/>
            <circle cx="397" cy="96" r="13" fill="#8b5e3c"/>
            <circle cx="397" cy="96" r="7.5" fill="#7a5030"/>

            <!-- LONG HAIR -->
            <path d="M308 74 Q310 44 352 38 Q394 44 396 74" fill="#1a0a05"/>
            <path d="M308 74 Q300 108 305 150 Q308 170 316 178" stroke="#1a0a05" stroke-width="12" stroke-linecap="round" fill="none"/>
            <path d="M396 74 Q404 108 400 150 Q397 170 390 178" stroke="#1a0a05" stroke-width="12" stroke-linecap="round" fill="none"/>
            <!-- Hair shine -->
            <path d="M330 41 Q352 36 372 40" stroke="rgba(255,255,255,0.12)" stroke-width="5" stroke-linecap="round" fill="none"/>

            <!-- EYES (happy arc style) -->
            <circle cx="337" cy="90" r="10" fill="white"/>
            <circle cx="367" cy="90" r="10" fill="white"/>
            <circle cx="339" cy="92" r="6.5" fill="#1a0a05"/>
            <circle cx="369" cy="92" r="6.5" fill="#1a0a05"/>
            <circle cx="341" cy="89" r="2.8" fill="white"/>
            <circle cx="371" cy="89" r="2.8" fill="white"/>

            <!-- EYEBROWS -->
            <path d="M325 78 Q337 70 349 78" stroke="#1a0a05" stroke-width="3.5" stroke-linecap="round" fill="none"/>
            <path d="M355 78 Q367 70 379 78" stroke="#1a0a05" stroke-width="3.5" stroke-linecap="round" fill="none"/>

            <!-- SMILE (open, teeth) -->
            <path d="M333 112 Q352 130 371 112" fill="#7a3a25"/>
            <path d="M338 114 Q352 126 366 114" fill="white"/>

            <!-- BLUSH -->
            <ellipse cx="321" cy="105" rx="13" ry="8.5" fill="#ff8c6b" opacity="0.22"/>
            <ellipse cx="383" cy="105" rx="13" ry="8.5" fill="#ff8c6b" opacity="0.22"/>

            <!-- Earring (small gold dot) -->
            <circle cx="307" cy="105" r="4.5" fill="#FFD700"/>
            <circle cx="307" cy="105" r="2.5" fill="#f5a623"/>

          </svg>
        </div>

        <!-- ── Floating info cards ── -->
        <div class="hero-card fc1" style="position:absolute;top:18px;left:50%;transform:translateX(-50%);background:white;border-radius:1rem;padding:0.6rem 1.1rem;box-shadow:0 8px 28px rgba(0,0,0,0.1);display:flex;align-items:center;gap:0.6rem;z-index:5;white-space:nowrap;border:1.5px solid #f0f0f0;">
          <span style="font-size:1.05rem;">✈️</span>
          <div>
            <p style="font-size:0.65rem;font-weight:800;color:#162544;margin:0;">247 travelers connected now</p>
            <p style="font-size:0.6rem;color:#22c55e;margin:0;font-weight:700;">● Live in 195+ countries</p>
          </div>
        </div>

        <div class="hero-card fc2" style="position:absolute;bottom:105px;left:-8px;background:#162544;border-radius:1rem;padding:0.6rem 1rem;box-shadow:0 8px 28px rgba(22,37,68,0.25);display:flex;align-items:center;gap:0.55rem;z-index:5;">
          <div style="width:28px;height:28px;background:rgba(3,222,243,0.15);border-radius:0.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.95rem;">💸</div>
          <div>
            <p style="font-size:0.7rem;font-weight:800;color:#03def3;margin:0;">From $3.50</p>
            <p style="font-size:0.6rem;color:rgba(255,255,255,0.5);margin:0;">No roaming charges</p>
          </div>
        </div>

        <div class="hero-card fc3" style="position:absolute;bottom:105px;right:-8px;background:white;border-radius:1rem;padding:0.6rem 1rem;box-shadow:0 8px 28px rgba(0,0,0,0.1);display:flex;align-items:center;gap:0.55rem;z-index:5;border:1.5px solid #f0f0f0;">
          <div style="width:28px;height:28px;background:linear-gradient(135deg,#03def3,#0ea5e9);border-radius:0.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <p style="font-size:0.7rem;font-weight:800;color:#162544;margin:0;">2-min Setup</p>
