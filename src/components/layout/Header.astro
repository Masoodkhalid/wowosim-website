---
interface Props {
  isLoggedIn: boolean;
}
const { isLoggedIn } = Astro.props;
const path = Astro.url.pathname;

const regions = ['Europe','Asia Pacific','North America','Latin America','Middle East','Caribbean','Caucasus Region'];
const popular = [
  { name: 'United States', slug: 'united-states', code: 'us' },
  { name: 'United Kingdom', slug: 'united-kingdom', code: 'gb' },
  { name: 'Japan', slug: 'japan', code: 'jp' },
  { name: 'Australia', slug: 'australia', code: 'au' },
  { name: 'France', slug: 'france', code: 'fr' },
  { name: 'Germany', slug: 'germany', code: 'de' },
  { name: 'Italy', slug: 'italy', code: 'it' },
  { name: 'Canada', slug: 'canada', code: 'ca' },
];
---

<header style="position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.97); backdrop-filter: blur(8px); border-bottom: 1px solid #f3f4f6; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
  <nav style="max-width: 80rem; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 4rem;">

    <!-- Logo -->
    <a href="/" style="font-size: 1.5rem; font-weight: 900; color: #162544; text-decoration: none; letter-spacing: -0.5px;">
      WoWo<span style="color: #03def3;">SIM</span>
    </a>

    <!-- Desktop Nav -->
    <ul style="display: flex; align-items: center; gap: 1.5rem; list-style: none; margin: 0; padding: 0; font-size: 0.875rem; font-weight: 500; color: #374151;">

      <!-- Destinations Mega Menu -->
      <li class="mega-parent" style="position: relative;">
        <button class="nav-link" style="display: flex; align-items: center; gap: 0.25rem; background: none; border: none; cursor: pointer; font-size: 0.875rem; font-weight: 500; color: #374151; padding: 0.5rem 0;">
          Destinations
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="transition: transform 0.2s;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <!-- Mega dropdown -->
        <div class="mega-menu" style="display: none; position: absolute; top: calc(100% + 0.5rem); left: 50%; transform: translateX(-50%); width: 640px; background: white; border-radius: 1rem; box-shadow: 0 10px 40px rgba(0,0,0,0.12); border: 1px solid #f3f4f6; padding: 1.5rem; z-index: 100;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div>
              <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: #9ca3af; margin: 0 0 0.75rem;">Popular</p>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem;">
                {popular.map(c => (
                  <a href={`/${c.slug}`} style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem; border-radius: 0.5rem; font-size: 0.8rem; color: #374151; text-decoration: none; transition: background 0.15s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                    <span class={`fi fi-${c.code}`} style="border-radius: 2px; width: 18px; height: 13px;"></span>
                    {c.name}
                  </a>
                ))}
              </div>
            </div>
            <div>
              <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: #9ca3af; margin: 0 0 0.75rem;">Regions</p>
              {regions.map(r => (
                <a href={`/${r.toLowerCase().replace(/ /g,'-')}`} style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem; border-radius: 0.5rem; font-size: 0.8rem; color: #374151; text-decoration: none; transition: background 0.15s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                  🌐 {r}
                </a>
              ))}
              <a href="/destinations" style="display: inline-block; margin-top: 0.75rem; font-size: 0.8rem; font-weight: 600; color: #03def3; text-decoration: none;">View all 195+ countries →</a>
            </div>
          </div>
        </div>
      </li>

      <li><a href="/help-center" style={`color: ${path === '/help-center' ? '#03def3' : '#374151'}; text-decoration: none;`} onmouseover="this.style.color='#03def3'" onmouseout={`this.style.color='${path === '/help-center' ? '#03def3' : '#374151'}'`}>Help Center</a></li>
      <li><a href="/faqs" style={`color: ${path === '/faqs' ? '#03def3' : '#374151'}; text-decoration: none;`} onmouseover="this.style.color='#03def3'" onmouseout={`this.style.color='${path === '/faqs' ? '#03def3' : '#374151'}'`}>FAQs</a></li>
      <li><a href="/blog" style={`color: ${path.startsWith('/blog') ? '#03def3' : '#374151'}; text-decoration: none;`} onmouseover="this.style.color='#03def3'" onmouseout={`this.style.color='${path.startsWith('/blog') ? '#03def3' : '#374151'}'`}>Blog</a></li>
      <li><a href="/contact" style={`color: ${path === '/contact' ? '#03def3' : '#374151'}; text-decoration: none;`} onmouseover="this.style.color='#03def3'" onmouseout={`this.style.color='${path === '/contact' ? '#03def3' : '#374151'}'`}>Contact</a></li>
      <li><a href="/partners" style={`color: ${path === '/partners' ? '#03def3' : '#374151'}; text-decoration: none;`} onmouseover="this.style.color='#03def3'" onmouseout={`this.style.color='${path === '/partners' ? '#03def3' : '#374151'}'`}>Partners</a></li>
    </ul>

    <!-- Right actions -->
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <!-- Cart -->
      <button id="cartBtn" style="position: relative; padding: 0.4rem; background: none; border: none; cursor: pointer; border-radius: 9999px; transition: background 0.15s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='none'">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#374151" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-9H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.6.6-.2 1.7.7 1.7H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <span id="cartCount" style="display: none; position: absolute; top: -4px; right: -4px; background: #03def3; color: #162544; font-size: 0.65rem; font-weight: 700; width: 16px; height: 16px; border-radius: 9999px; align-items: center; justify-content: center;">0</span>
      </button>

      {isLoggedIn ? (
        <a href="/dashboard" class="btn-primary" style="font-size: 0.8rem; padding: 0.5rem 1rem;">Dashboard</a>
      ) : (
        <a href="/login" class="btn-primary" style="font-size: 0.8rem; padding: 0.5rem 1rem;">Login</a>
      )}

      <!-- Mobile hamburger -->
      <button id="mobileMenuBtn" style="display: none; padding: 0.4rem; background: none; border: none; cursor: pointer;">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#374151" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobileMenu" style="display: none; border-top: 1px solid #f3f4f6; padding: 1rem 1.5rem; background: white;">
    <div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.875rem; font-weight: 500;">
      <a href="/help-center" style="color: #374151; text-decoration: none; padding: 0.4rem 0;">Help Center</a>
      <a href="/faqs" style="color: #374151; text-decoration: none; padding: 0.4rem 0;">FAQs</a>
      <a href="/blog" style="color: #374151; text-decoration: none; padding: 0.4rem 0;">Blog</a>
      <a href="/contact" style="color: #374151; text-decoration: none; padding: 0.4rem 0;">Contact</a>
      <a href="/partners" style="color: #374151; text-decoration: none; padding: 0.4rem 0;">Partners</a>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
    const m = document.getElementById('mobileMenu');
    if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
  });

  // Show hamburger on mobile
  function checkMobile() {
    const btn = document.getElementById('mobileMenuBtn') as HTMLElement;
    if (btn) btn.style.display = window.innerWidth < 1024 ? 'block' : 'none';
  }
  checkMobile();
  window.addEventListener('resize', checkMobile);

  // Mega menu hover
  const parent = document.querySelector('.mega-parent') as HTMLElement;
  const menu = document.querySelector('.mega-menu') as HTMLElement;
  if (parent && menu) {
    parent.addEventListener('mouseenter', () => menu.style.display = 'block');
    parent.addEventListener('mouseleave', () => menu.style.display = 'none');
  }

  // Cart count from cookie
  try {
    const raw = document.cookie.match(/wordpress_cart=([^;]+)/)?.[1];
    if (raw) {
      const cart = JSON.parse(decodeURIComponent(raw));
      const count = cart.reduce((s: number, i: any) => s + (i.quantity ?? 1), 0);
      if (count > 0) {
        const el = document.getElementById('cartCount') as HTMLElement;
        if (el) { el.textContent = String(count); el.style.display = 'flex'; }
      }
    }
  } catch {}
</script>
