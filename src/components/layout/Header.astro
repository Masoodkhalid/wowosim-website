        <path d="M71.0749 15.4579C70.0338 12.9671 66.8726 11.7207 64.0963 12.7069C64.0397 12.7279 63.957 12.7594 63.9027 12.7825C63.0434 13.1833 62.2289 13.689 61.4546 14.1779C54.5704 18.6746 48.9257 24.9466 45.9912 32.0453C45.7716 32.5783 45.5639 33.1175 45.375 33.661C45.2664 33.9695 45.1673 34.2821 45.0705 34.5927C44.8816 34.2255 44.6857 33.8646 44.4874 33.5078C42.7073 30.2533 40.7644 27.0659 38.6514 23.9771C38.4083 23.6162 38.0825 23.1462 37.4285 22.2166C37.2774 22.267 37.1783 22.3824 37.0744 22.4957C36.6707 22.949 36.2717 23.4043 35.8893 23.8638C36.0451 29.0321 36.5763 29.8735 37.6009 31.5732C39.5651 34.8823 41.3616 38.2732 43.0307 41.6977C43.739 43.1791 44.1356 44.0269 44.8934 45.6992C45.0634 45.9993 45.0988 45.886 45.1909 45.5901C45.5993 44.2787 46.1612 42.5139 46.4374 41.6977C49.1169 35.5537 51.3904 32.4734 54.2045 29.821C57.9511 26.3189 62.5453 23.4484 67.6139 21.6711C68.3623 21.4675 69.0257 21.1276 69.5805 20.6953C71.2 19.4321 71.8965 17.3674 71.0796 15.4537L71.0749 15.4579Z" fill="url(#paint0_linear_h)"/>
