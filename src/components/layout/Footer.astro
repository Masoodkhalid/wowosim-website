---
const topDests = [
  ['United States','united-states'],['United Kingdom','united-kingdom'],
  ['Japan','japan'],['Australia','australia'],['France','france'],
  ['Germany','germany'],['Italy','italy'],['Canada','canada'],
  ['Spain','spain'],['Thailand','thailand'],
];
const links = [
  ['Help Center','/help-center'],['FAQs','/faqs'],['Blog','/blog'],
  ['All Destinations','/destinations'],['Compatible Devices','/compatible-devices'],
  ['Contact Us','/contact'],['Partners','/partners'],
  ['Privacy Policy','/privacy-policy'],['Terms of Service','/terms'],
];
const socials = [
  { href: 'https://www.instagram.com/wowosim/', emoji: '📷', label: 'Instagram' },
  { href: 'https://www.facebook.com/WowoSimm/', emoji: '📘', label: 'Facebook' },
  { href: 'https://www.youtube.com/@WoWoSim', emoji: '▶️', label: 'YouTube' },
  { href: 'https://www.tiktok.com/@wowosim', emoji: '🎵', label: 'TikTok' },
];
---

<footer style="background: #162544; color: white;">
  <div style="max-width: 80rem; margin: 0 auto; padding: 4rem 2rem;">
    <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.2fr; gap: 2.5rem;">

      <!-- Brand -->
      <div>
        <div style="margin-bottom:1rem;">
          <svg width="145" height="35" viewBox="0 0 194 47" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M95.6896 28.9451L88.6631 9.68994H83.4277L76.4012 28.9451L69.8477 9.68994H64.0625L73.8027 36.5977H78.9453L86.0264 17.7607L93.1074 36.5977H98.25L108.003 9.68994H102.243L95.6896 28.9451Z" fill="#F6F5FF"/>
            <path d="M100.89 33.9161C100.89 35.4736 102.152 36.7354 103.71 36.7354C105.267 36.7354 106.529 35.4736 106.529 33.9161C106.529 32.3586 105.267 31.0967 103.71 31.0967C102.152 31.0967 100.89 32.3586 100.89 33.9161Z" fill="#F6F5FF"/>
            <path d="M132.931 28.9451L125.904 9.68994H120.669L113.643 28.9451L107.089 9.68994H101.304L111.044 36.5977H116.187L123.268 17.7607L130.349 36.5977H135.491L145.244 9.68994H139.484L132.931 28.9451Z" fill="#F6F5FF"/>
            <path d="M138.129 33.9161C138.129 35.4736 139.391 36.7354 140.949 36.7354C142.506 36.7354 143.768 35.4736 143.768 33.9161C143.768 32.3586 142.506 31.0967 140.949 31.0967C139.391 31.0967 138.129 32.3586 138.129 33.9161Z" fill="#F6F5FF"/>
            <path d="M161.862 26.1795C158.539 25.0605 155.605 24.0684 155.605 21.6064C155.605 19.5293 157.527 18.0742 160.337 18.0742C162.753 18.0742 165.091 19.1543 166.7 21.0527L170.373 17.8965C168.243 15.3438 164.97 13.7236 160.337 13.7236C154.734 13.7236 150.478 17.0234 150.478 21.7021C150.478 27.1992 155.488 28.9785 159.875 30.3926C163.237 31.4863 166.21 32.4648 166.21 35.0566C166.21 37.3242 164.053 38.9316 160.923 38.9316C157.989 38.9316 155.176 37.5566 153.503 35.3066L149.766 38.6455C151.909 41.3975 155.488 43.2822 160.923 43.2822C167.021 43.2822 171.337 39.8896 171.337 34.8418C171.337 29.1924 166.301 27.5068 161.862 26.1795Z" fill="#FF5F00"/>
            <path d="M170.325 42.0031C170.325 43.8604 171.833 45.3682 173.69 45.3682C175.547 45.3682 177.055 43.8604 177.055 42.0031C177.055 40.1458 175.547 38.6382 173.69 38.6382C171.833 38.6382 170.325 40.1458 170.325 42.0031Z" fill="#FF5F00"/>
            <path d="M185.531 28.9199L193.626 14.0566H188.103L182.838 24.4141L177.572 14.0566H172.05L180.144 28.9199V36.5977H185.531V28.9199Z" fill="#FF5F00"/>
            <path d="M71.0749 15.4579C69.1354 20.1226 65.3028 23.7841 60.5476 25.6612C55.7925 27.5383 50.4711 27.4658 45.7696 25.4595L71.0749 15.4579Z" fill="url(#paint0_linear_f)"/>
            <path d="M48.4308 11.9851C50.3703 7.32037 54.2029 3.65887 58.9581 1.78177C63.7132 -0.0953369 69.0346 -0.0228448 73.7361 1.98344L48.4308 11.9851Z" fill="url(#paint1_linear_f)"/>
            <path d="M62.6613 0.0224092C62.6613 0.0224092 54.6934 1.90137 48.4316 11.9849L73.7369 1.98486C70.4189 0.562012 66.6006 -0.162109 62.6613 0.0224092Z" fill="#F6F5FF"/>
            <path d="M53.9568 2.09558C53.9568 2.09558 47.5283 6.52246 45.7705 15.4595L71.0757 15.4595C68.9277 11.6411 65.5371 8.12207 60.9619 5.94434C58.7158 4.86768 56.2891 4.19043 53.9568 2.09558Z" fill="#F6F5FF"/>
            <defs>
              <linearGradient id="paint0_linear_f" x1="24.3756" y1="29.2125" x2="49.4168" y2="29.2125" gradientUnits="userSpaceOnUse">
                <stop stop-color="#42BFCA"/>
                <stop offset="1" stop-color="#FF5F00"/>
              </linearGradient>
              <linearGradient id="paint1_linear_f" x1="24.3764" y1="26.6819" x2="49.4176" y2="26.6819" gradientUnits="userSpaceOnUse">
                <stop stop-color="#42BFCA"/>
                <stop offset="1" stop-color="#FF5F00"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <p style="color: #9ca3af; font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.5rem;">
          Instant eSIM connectivity in 195+ countries. No physical SIM. No roaming fees. Travel smarter.
        </p>
        <div style="display: flex; gap: 0.6rem;">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}
               style="width: 36px; height: 36px; background: rgba(255,255,255,0.1); border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; transition: background 0.2s; text-decoration: none;"
               onmouseover="this.style.background='#03def3'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
              {s.emoji}
            </a>
          ))}
        </div>
      </div>

      <!-- Top Destinations -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">Top Destinations</h4>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {topDests.map(([name, slug]) => (
            <li>
              <a href={`/${slug}`} style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: color 0.15s;"
                 onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">{name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">Quick Links</h4>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {links.map(([label, href]) => (
            <li>
              <a href={href} style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: color 0.15s;"
                 onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Payment & App -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">We Accept</h4>
        <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem;">
          {['Visa','Mastercard','Google Pay','Apple Pay','Amazon Pay'].map(p => (
            <span style="background: rgba(255,255,255,0.1); color: #d1d5db; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 0.3rem;">{p}</span>
          ))}
        </div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 0.75rem;">Get the App</h4>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="#" style="background: rgba(255,255,255,0.1); color: #d1d5db; border-radius: 0.75rem; padding: 0.5rem 0.75rem; font-size: 0.75rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none; transition: background 0.2s;"
             onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">🍎 App Store</a>
          <a href="#" style="background: rgba(255,255,255,0.1); color: #d1d5db; border-radius: 0.75rem; padding: 0.5rem 0.75rem; font-size: 0.75rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none; transition: background 0.2s;"
             onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">🤖 Google Play</a>
        </div>
      </div>
    </div>

    <div style="border-top: 1px solid rgba(255,255,255,0.1); margin-top: 3rem; padding-top: 1.5rem; text-align: center; color: #6b7280; font-size: 0.75rem;">
      © {new Date().getFullYear()} WoWo SIM. All Rights Reserved.
    </div>
  </div>
</footer>
