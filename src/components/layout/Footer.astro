---
const topDests = [
  ['United States','united-states'],['United Kingdom','united-kingdom'],
  ['Japan','japan'],['Australia','australia'],['France','france'],
  ['Germany','germany'],['Italy','italy'],['Canada','canada'],
  ['Spain','spain'],['Thailand','thailand'],
];
const links = [
  ['Help Center','/help-center'],['FAQs','/faqs'],['Blog','/blog'],
  ['All Destinations','/destinations'],['Compatible Devices','/compatible-devices'],
  ['Contact Us','/contact'],['Partners','/partners'],
  ['Privacy Policy','/privacy-policy'],['Terms of Service','/terms'],
];
const socials = [
  { href: 'https://www.instagram.com/wowosim/', emoji: '📷', label: 'Instagram' },
  { href: 'https://www.facebook.com/WowoSimm/', emoji: '📘', label: 'Facebook' },
  { href: 'https://www.youtube.com/@WoWoSim', emoji: '▶️', label: 'YouTube' },
  { href: 'https://www.tiktok.com/@wowosim', emoji: '🎵', label: 'TikTok' },
];
---

<footer style="background: #162544; color: white;">
  <div style="max-width: 80rem; margin: 0 auto; padding: 4rem 2rem;">
    <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.2fr; gap: 2.5rem;">

      <!-- Brand -->
      <div>
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="9" fill="rgba(255,255,255,0.1)"/>
            <path d="M8 13l4 8 4-8" stroke="#42BFCA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 13l4 8 4-8" stroke="url(#fg1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 13h4M24 17h3M24 21h4" stroke="#FF5F00" stroke-width="2.2" stroke-linecap="round"/>
            <defs>
              <linearGradient id="fg1" x1="16" y1="13" x2="24" y2="21" gradientUnits="userSpaceOnUse">
                <stop stop-color="#42BFCA"/><stop offset="1" stop-color="#FF5F00"/>
              </linearGradient>
            </defs>
          </svg>
          <span style="font-size:1.35rem;font-weight:900;letter-spacing:-0.5px;color:white;">WoWo<span style="background:linear-gradient(90deg,#42BFCA,#FF5F00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">SIM</span></span>
        </div>
        <p style="color: #9ca3af; font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.5rem;">
          Instant eSIM connectivity in 195+ countries. No physical SIM. No roaming fees. Travel smarter.
        </p>
        <div style="display: flex; gap: 0.6rem;">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}
               style="width: 36px; height: 36px; background: rgba(255,255,255,0.1); border-radius: 9999px; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; transition: background 0.2s; text-decoration: none;"
               onmouseover="this.style.background='#03def3'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
              {s.emoji}
            </a>
          ))}
        </div>
      </div>

      <!-- Top Destinations -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">Top Destinations</h4>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {topDests.map(([name, slug]) => (
            <li>
              <a href={`/${slug}`} style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: color 0.15s;"
                 onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">{name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">Quick Links</h4>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {links.map(([label, href]) => (
            <li>
              <a href={href} style="color: #9ca3af; font-size: 0.8rem; text-decoration: none; transition: color 0.15s;"
                 onmouseover="this.style.color='#03def3'" onmouseout="this.style.color='#9ca3af'">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Payment & App -->
      <div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 1rem;">We Accept</h4>
        <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem;">
          {['Visa','Mastercard','Google Pay','Apple Pay','Amazon Pay'].map(p => (
            <span style="background: rgba(255,255,255,0.1); color: #d1d5db; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 0.3rem;">{p}</span>
          ))}
        </div>
        <h4 style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: white; margin: 0 0 0.75rem;">Get the App</h4>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="#" style="background: rgba(255,255,255,0.1); color: #d1d5db; border-radius: 0.75rem; padding: 0.5rem 0.75rem; font-size: 0.75rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none; transition: background 0.2s;"
             onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">🍎 App Store</a>
          <a href="#" style="background: rgba(255,255,255,0.1); color: #d1d5db; border-radius: 0.75rem; padding: 0.5rem 0.75rem; font-size: 0.75rem; display: flex; align-items: center; gap: 0.5rem; text-decoration: none; transition: background 0.2s;"
             onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">🤖 Google Play</a>
        </div>
      </div>
    </div>

    <div style="border-top: 1px solid rgba(255,255,255,0.1); margin-top: 3rem; padding-top: 1.5rem; text-align: center; color: #6b7280; font-size: 0.75rem;">
      © {new Date().getFullYear()} WoWo SIM. All Rights Reserved.
    </div>
  </div>
</footer>
